# E2E 테스트 환경변수 — .env.e2e 로 복사 후 실제 값 입력
E2E_BASE_URL=http://localhost:3000

# 고객 계정 (일반 user role)
E2E_USER_EMAIL=test-customer@example.com
E2E_USER_PASSWORD=password

# 마스터(전문가) 계정 (master role)
E2E_MASTER_EMAIL=test-master@example.com
E2E_MASTER_PASSWORD=password

# 관리자 계정
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=password
