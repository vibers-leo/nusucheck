# Ignore bundler config.
/.bundle
/vendor/bundle

# Ignore all environment files.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and test).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key

/node_modules

# Ignore OS files
.DS_Store
Thumbs.db
nul

# macOS AppleDouble (resource fork) files
._*

# 환경변수 (절대 커밋 금지)
.env

# E2E
.env.e2e
playwright-report/
test-results/
tests/reports/
tests/.auth/
node_modules/
package-lock.json
