# ============================================================
# nusucheck 프로덕션 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워주세요
# cp .env.example .env
# ============================================================

# Rails
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_MASTER_KEY=여기에_master.key_값_입력

# 앱 도메인
APP_DOMAIN=nusucheck.vibers.co.kr

# Database (docker-compose 서비스명으로 연결)
DATABASE_HOST=nusucheck-db
DATABASE_USERNAME=nusucheck
DATABASE_PASSWORD=안전한_DB_비밀번호_입력

# docker-compose postgres 환경변수 (DATABASE_PASSWORD와 동일하게)
DB_PASSWORD=안전한_DB_비밀번호_입력

# Redis (docker-compose 서비스명으로 연결)
REDIS_URL=redis://nusucheck-redis:6379/0

# Active Storage (로컬 디스크 사용 시 비워두기, OCI 사용 시 입력)
# OCI_ENDPOINT=
# OCI_BUCKET=
# OCI_ACCESS_KEY=
# OCI_SECRET_KEY=

# Sentry (선택사항)
# SENTRY_DSN=

# 결제 (Toss)
TOSS_SECRET_KEY=test_sk_xxx
TOSS_WEBHOOK_SECRET=whsec_xxx
TOSS_CLIENT_KEY=test_ck_xxx

# 결제 (PortOne)
PORTONE_API_KEY=xxx
PORTONE_API_SECRET=xxx
PORTONE_WEBHOOK_SECRET=xxx

# AI (Claude Vision)
ANTHROPIC_API_KEY=sk-ant-xxx

# 보험 (CODEF)
CODEF_CLIENT_ID=xxx
CODEF_CLIENT_SECRET=xxx
CODEF_PUBLIC_KEY=xxx

# 이메일
RESEND_API_KEY=re_xxx

# 기타 서비스 키 (사용하는 경우 입력)
# KAKAO_API_KEY=
# NICE_API_KEY=
