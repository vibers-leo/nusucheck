<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">의견 상세</h1>
    <%= link_to "← 목록으로", admin_feedbacks_path, class: "text-primary-600 hover:text-primary-900" %>
  </div>

  <div class="bg-white rounded-lg shadow p-6 space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-sm font-semibold text-gray-700">ID</p>
        <p class="text-gray-900">#<%= @feedback.id %></p>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-700">분류</p>
        <span class="px-2 py-1 bg-primary-100 text-primary-800 text-xs font-medium rounded-full">
          <%= @feedback.category %>
        </span>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-700">이름</p>
        <p class="text-gray-900"><%= @feedback.name %></p>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-700">이메일</p>
        <p class="text-gray-900"><%= @feedback.email %></p>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-700">상태</p>
        <% color = @feedback.status_pending? ? 'yellow' : (@feedback.status_reviewed? ? 'purple' : 'green') %>
        <span class="px-2 py-1 bg-<%= color %>-100 text-<%= color %>-800 text-xs font-medium rounded-full">
          <%= @feedback.status == 'pending' ? '대기' : (@feedback.status == 'reviewed' ? '검토완료' : '해결') %>
        </span>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-700">작성일</p>
        <p class="text-gray-900"><%= @feedback.created_at.strftime("%Y-%m-%d %H:%M") %></p>
      </div>
    </div>

    <div class="border-t pt-4">
      <p class="text-sm font-semibold text-gray-700 mb-2">의견 내용</p>
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-gray-900 whitespace-pre-wrap"><%= @feedback.message %></p>
      </div>
    </div>

    <div class="flex gap-2 pt-4 border-t">
      <% if @feedback.status_pending? %>
        <%= button_to "검토 완료", mark_reviewed_admin_feedback_path(@feedback), method: :post, class: "px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700", data: { turbo_confirm: "이 피드백을 검토 완료 처리하시겠습니까?" } %>
      <% end %>
      <% if @feedback.status_reviewed? %>
        <%= button_to "해결 완료", mark_resolved_admin_feedback_path(@feedback), method: :post, class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700", data: { turbo_confirm: "이 피드백을 해결 완료 처리하시겠습니까?" } %>
      <% end %>
    </div>
  </div>
</div>
