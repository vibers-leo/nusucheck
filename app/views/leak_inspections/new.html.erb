<div class="max-w-2xl mx-auto py-8">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">🎥 영상이 가장 정확해요!</h1>
    <p class="mt-3 text-lg text-gray-600">누수가 걱정되시나요?</p>
    <p class="text-gray-600">영상으로 촬영해서 올려주시면 더 정확하게 분석해드려요.</p>

    <!-- Toss-like 친절한 프로세스 안내 -->
    <div class="mt-6 max-w-lg mx-auto bg-gradient-to-r from-blue-50 to-indigo-50 border-2 border-blue-200 rounded-2xl p-5 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex-shrink-0 w-8 h-8 bg-blue-500 text-white rounded-full flex items-center justify-center font-bold">!</div>
        <h3 class="font-bold text-gray-900 text-base">이렇게 진행돼요</h3>
      </div>
      <div class="space-y-2 text-left text-sm text-gray-700">
        <div class="flex items-start gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-primary-500 text-white rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <p><strong>지금 바로</strong> 사진/영상만 올려주세요</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-primary-500 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <p>AI가 <strong>무료로 분석</strong>해드려요</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="flex-shrink-0 w-6 h-6 bg-primary-500 text-white rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <p><strong>전문가 매칭 후</strong> 로그인하시면 됩니다</p>
        </div>
      </div>
      <div class="mt-4 pt-3 border-t border-blue-200">
        <p class="text-xs text-gray-600 font-medium flex items-center justify-center gap-1">
          <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          로그인 없이 바로 시작하세요!
        </p>
      </div>
    </div>

    <!-- 영상 권장 메시지 -->
    <div class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-purple-50 border border-purple-200 rounded-xl">
      <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <span class="text-sm font-medium text-purple-900">💡 <strong>영상으로 촬영하면</strong> 더 정확하게 분석할 수 있어요!</span>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 p-8" data-controller="photo-upload upload-progress">

    <!-- 업로드 진행 오버레이 -->
    <div data-upload-progress-target="progressModal"
         class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl p-8 w-full max-w-sm shadow-2xl text-center">
        <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-primary-600 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 text-lg mb-1">업로드 중이에요</h3>
        <p class="text-sm text-gray-500 mb-5">잠깐만 기다려주세요 🙏</p>
        <div class="bg-gray-100 rounded-full h-3 overflow-hidden mb-2">
          <div data-upload-progress-target="progressBar"
               class="h-3 bg-primary-500 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-gray-500 mb-4">
          <span data-upload-progress-target="uploadedSize">0 Bytes</span>
          <span data-upload-progress-target="progressText" class="font-bold text-primary-600">0%</span>
          <span data-upload-progress-target="totalSize">0 Bytes</span>
        </div>
        <p data-upload-progress-target="errorMessage" class="hidden text-sm text-red-600 mb-3"></p>
        <button data-action="click->upload-progress#cancel"
                data-upload-progress-target="cancelButton"
                class="text-xs text-gray-400 hover:text-gray-600 underline">취소</button>
      </div>
    </div>

    <%= form_with(model: @inspection, url: leak_inspections_path,
                  html: { multipart: true }, class: "space-y-6",
                  data: { upload_progress_target: "form", controller: "form-validation", action: "submit->form-validation#submit" }) do |f| %>

      <%= render "shared/form_errors", resource: @inspection %>

      <!-- 영상/사진 업로드 영역 -->
      <label for="leak_inspection_photo"
           class="block border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-primary-400 transition-colors cursor-pointer"
           data-photo-upload-target="dropzone"
           data-action="dragenter->photo-upload#dragover dragover->photo-upload#dragover dragleave->photo-upload#dragleave drop->photo-upload#drop"
           aria-label="영상/사진 업로드 영역 - 클릭하거나 파일을 드래그하세요">

        <div data-photo-upload-target="placeholder">
          <div class="flex items-center justify-center gap-3 mb-3">
            <svg class="h-12 w-12 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <p class="text-gray-700 font-bold text-lg">🎬 클릭해서 영상 올리기</p>
          <p class="text-sm text-gray-500 mt-1">또는 여기로 드래그하세요</p>
          <div class="flex items-center justify-center gap-2 mt-2 flex-wrap">
            <span class="px-2.5 py-1 bg-purple-100 text-purple-700 text-xs font-semibold rounded-full">MP4, MOV, AVI</span>
            <span class="px-2.5 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">JPG, PNG</span>
            <span class="px-2.5 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full">최대 100MB</span>
          </div>
        </div>

        <!-- 이미지 프리뷰 -->
        <img data-photo-upload-target="preview" class="hidden mx-auto max-h-48 rounded-xl shadow-md" alt="업로드된 사진 미리보기" />

        <!-- 영상 프리뷰 -->
        <video data-photo-upload-target="videoPreview"
               class="hidden mx-auto max-h-48 rounded-xl shadow-md w-full max-w-sm"
               controls muted playsinline></video>

        <!-- 파일 정보 -->
        <div data-photo-upload-target="fileInfo" class="hidden mt-3"></div>

        <%= f.file_field :photo, id: "leak_inspection_photo", accept: "image/*,video/*", class: "sr-only",
              data: { photo_upload_target: "input", action: "change->photo-upload#preview" } %>
      </label>

      <!-- 위치 설명 (선택) -->
      <div>
        <%= f.label :location_description, "어디에서 발견하셨나요?",
              class: "block text-sm font-medium text-gray-900 mb-2" %>
        <p class="text-xs text-gray-500 mb-2">💡 정확한 위치를 알려주시면 더 도움이 돼요 (선택사항)</p>
        <%= f.text_field :location_description,
              placeholder: "예: 거실 천장, 화장실 벽면, 주방 싱크대 아래",
              class: input_classes(:text) %>
      </div>

      <!-- 증상 유형 (선택) -->
      <div data-controller="button-select">
        <%= f.label :symptom_type, "어떤 증상인가요?",
              class: "block text-sm font-medium text-gray-900 mb-3" %>
        <p class="text-xs text-gray-500 mb-3">💡 비슷한 증상을 선택해주세요 (선택사항)</p>

        <%= f.hidden_field :symptom_type, id: "symptom-type-input" %>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <% [
            ["wall_leak", "💧", "벽면 누수", "벽에서 물이 배어나와요"],
            ["ceiling_leak", "💧", "천장 누수", "천장에서 물이 떨어져요"],
            ["floor_leak", "💧", "바닥 누수", "바닥이 축축해요"],
            ["pipe_leak", "🔧", "배관 누수", "배관에서 새는 것 같아요"],
            ["toilet_leak", "🚽", "화장실 누수", "화장실에서 물이 새요"],
            ["outdoor_leak", "🏠", "외부 누수", "외벽, 창틀에서 새요"]
          ].each do |value, emoji, title, desc| %>
            <button type="button"
                    class="select-button relative p-4 rounded-xl border-2 border-gray-200 hover:border-primary-400 hover:bg-primary-50 transition-all text-left group <%= 'border-primary-600 bg-primary-50 selected' if @inspection.symptom_type == value %>"
                    data-action="click->button-select#select"
                    data-field="symptom_type"
                    data-value="<%= value %>"
                    role="radio"
                    aria-checked="<%= @inspection.symptom_type == value ? 'true' : 'false' %>">
              <div class="select-check <%= 'hidden' unless @inspection.symptom_type == value %> absolute top-2 right-2">
                <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="text-3xl mb-2"><%= emoji %></div>
              <p class="font-bold text-sm text-gray-900 mb-0.5"><%= title %></p>
              <p class="text-xs text-gray-500"><%= desc %></p>
            </button>
          <% end %>
        </div>
      </div>

      <!-- 제출 버튼 -->
      <div>
        <%= f.submit "🔍 3초만에 확인하기",
              class: "w-full py-4 bg-primary-600 text-white rounded-xl font-bold text-lg hover:bg-primary-700 transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed opacity-50 cursor-not-allowed shadow-lg hover:shadow-xl",
              disabled: true,
              data: { photo_upload_target: "submitBtn",
                      turbo_submits_with: "⏱️ 분석 중이에요... 잠깐만 기다려주세요" } %>
        <p class="text-xs text-center text-gray-500 mt-2">무료이며, 개인정보는 수집하지 않아요</p>
      </div>
    <% end %>
  </div>

  <!-- 안내 사항 -->
  <div class="mt-8 bg-gradient-to-br from-primary-50 to-indigo-50 rounded-2xl p-6 border border-primary-100">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-2xl">💡</span>
      <h3 class="font-bold text-gray-900">선명한 사진일수록 정확해요</h3>
    </div>
    <ul class="space-y-3 text-sm text-gray-700">
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 bg-purple-500 text-white rounded-full flex items-center justify-center text-xs font-bold">★</span>
        <span><strong>영상 촬영이 가장 좋아요!</strong> 여러 각도에서 천천히 촬영해주세요 (10~30초)</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 bg-green-500 text-white rounded-full flex items-center justify-center text-xs font-bold">✓</span>
        <span><strong>물방울, 얼룩, 곰팡이가</strong> 선명하게 보이도록</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 bg-green-500 text-white rounded-full flex items-center justify-center text-xs font-bold">✓</span>
        <span><strong>밝은 조명에서</strong> 가까이 찍어주세요</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 bg-green-500 text-white rounded-full flex items-center justify-center text-xs font-bold">✓</span>
        <span><strong>주변 환경도 함께</strong> 나오면 더 좋아요</span>
      </li>
    </ul>
    <div class="mt-4 pt-4 border-t border-primary-200">
      <p class="text-xs text-gray-600 flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <span><strong>사진 여러장과 영상을 함께 보내주시면 훨씬 정확합니다</strong></span>
      </p>
    </div>
  </div>
</div>
