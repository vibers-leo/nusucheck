<% is_my_message = message.sender_id == current_user&.id %>
<div class="my-4 flex <%= is_my_message ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-md w-full">
    <div class="bg-white border-2 border-primary-200 rounded-xl p-5 shadow-md">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="font-bold text-lg text-gray-900">견적서</h3>
      </div>

      <!-- 견적 내역 -->
      <div class="space-y-2 mb-4">
        <% message.metadata['breakdown']&.each do |item| %>
          <div class="flex justify-between text-sm">
            <span class="text-gray-700"><%= item['name'] %></span>
            <span class="font-semibold text-gray-900"><%= number_to_currency(item['price'], unit: '', precision: 0) %>원</span>
          </div>
        <% end %>
      </div>

      <!-- 총액 -->
      <div class="pt-3 border-t border-gray-200">
        <div class="flex justify-between items-center">
          <span class="font-bold text-base text-gray-900">총액</span>
          <span class="font-bold text-xl text-primary-600"><%= number_to_currency(message.metadata['amount'], unit: '', precision: 0) %>원</span>
        </div>
      </div>

      <!-- 고객만 버튼 표시 -->
      <% if request.customer == current_user && message.metadata['status'] != 'accepted' %>
        <div class="mt-4 flex gap-2">
          <%= button_to "견적 수락", accept_estimate_customers_request_path(request, estimate_id: message.metadata['estimate_id']),
                method: :post,
                class: "flex-1 py-2 bg-primary-600 text-white font-bold rounded-lg hover:bg-primary-700 transition-colors text-center",
                data: { turbo_confirm: "이 견적을 수락하시겠습니까?" } %>
          <button type="button" class="px-4 py-2 bg-gray-100 text-gray-700 font-semibold rounded-lg hover:bg-gray-200 transition-colors">
            수정 요청
          </button>
        </div>
      <% elsif message.metadata['status'] == 'accepted' %>
        <div class="mt-3 flex items-center justify-center gap-2 text-green-700">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="font-semibold">견적 수락 완료</span>
        </div>
      <% end %>

      <!-- 타임스탬프 -->
      <div class="mt-3 text-xs text-gray-400 text-center">
        <%= message.created_at.strftime("%Y년 %m월 %d일 %H:%M") %>
      </div>
    </div>
  </div>
</div>
