<%= turbo_frame_tag dom_id(message) do %>
  <% if message.estimate? %>
    <%= render "messages/widgets/estimate", message: message, request: message.request %>

  <% elsif message.payment_request? %>
    <%= render "messages/widgets/payment_request", message: message, request: message.request %>

  <% elsif message.payment_complete? %>
    <%= render "messages/widgets/payment_complete", message: message %>

  <% elsif message.schedule? %>
    <%= render "messages/widgets/schedule", message: message, request: message.request %>

  <% elsif message.insurance_claim? %>
    <%= render "messages/widgets/insurance_claim", message: message %>

  <% elsif message.system_message? %>
    <!-- 시스템 메시지 (AI 안내, 상태 변경) - 가운데 정렬 -->
    <div class="flex justify-center my-3">
      <div class="max-w-[85%]">
        <div class="bg-gray-100 rounded-2xl px-4 py-3 border border-gray-200/50">
          <div class="text-xs text-gray-500 text-center mb-1.5 font-medium">
            🔔 <%= message.sender_name %>
          </div>
          <div class="text-sm text-gray-700 text-center break-words whitespace-pre-wrap leading-relaxed">
            <%= message.content %>
          </div>
          <div class="text-center text-[10px] text-gray-400 mt-1.5">
            <%= message.created_at.strftime("%H:%M") %>
          </div>
        </div>
      </div>
    </div>

  <% else %>
    <!-- 일반 텍스트 메시지 - 카카오톡 스타일 버블 -->
    <% is_my_message = message.sender_id == current_user&.id %>
    <div class="flex <%= is_my_message ? 'justify-end' : 'justify-start' %> mb-1.5 items-end gap-2">

      <% unless is_my_message %>
        <!-- 상대방 아바타 -->
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gray-400 to-gray-600 flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mb-0.5">
          <%= message.sender&.name&.first %>
        </div>
      <% end %>

      <div class="max-w-[70%]">
        <% unless is_my_message %>
          <div class="text-xs text-gray-500 mb-1 ml-1 font-medium"><%= message.sender_name %></div>
        <% end %>

        <!-- 메시지 버블 -->
        <div class="<%= is_my_message ? 'bg-primary-500 text-white rounded-2xl rounded-br-md' : 'bg-white text-gray-900 rounded-2xl rounded-bl-md border border-gray-200/80' %> px-4 py-2.5 shadow-sm">
          <div class="text-sm break-words whitespace-pre-wrap leading-relaxed"><%= message.content %></div>

          <!-- 첨부 이미지 -->
          <% if message.images.attached? %>
            <div class="mt-2 grid <%= message.images.count == 1 ? 'grid-cols-1' : 'grid-cols-2' %> gap-1.5">
              <% message.images.each_with_index do |img, idx| %>
                <% img_url = rails_blob_url(img) rescue nil %>
                <% if img_url %>
                  <button type="button" onclick="openLightbox('<%= img_url %>')"
                          class="rounded-xl overflow-hidden block w-full cursor-zoom-in hover:opacity-90 transition">
                    <%= image_tag img_url, class: "w-full #{message.images.count == 1 ? 'h-56' : 'h-40'} object-cover" %>
                  </button>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <!-- 첨부 영상 -->
          <% if message.respond_to?(:videos) && message.videos.attached? %>
            <div class="mt-2 space-y-2">
              <% message.videos.each do |video| %>
                <div class="rounded-xl overflow-hidden bg-black">
                  <video src="<%= rails_blob_url(video) %>" controls playsinline preload="metadata"
                         class="w-full max-h-64 object-contain"></video>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- 시간 + 읽음 표시 -->
        <div class="flex items-center gap-1 mt-0.5 <%= is_my_message ? 'justify-end' : 'justify-start' %>">
          <% if is_my_message && message.read? %>
            <span class="text-[10px] text-gray-400">읽음</span>
          <% end %>
          <span class="text-[10px] text-gray-400"><%= message.created_at.strftime("%H:%M") %></span>
        </div>
      </div>

      <% if is_my_message %>
        <!-- 내 아바타 공간 (우측 정렬 균형) -->
        <div class="w-8 flex-shrink-0"></div>
      <% end %>
    </div>
  <% end %>
<% end %>
