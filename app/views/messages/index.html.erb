<%# 당근마켓 스타일 채팅 — full-screen, 모바일 최적화 %>
<% content_for :full_screen_layout, true %>
<% content_for :title, "채팅" %>

<div class="flex flex-col bg-white" style="height: calc(100vh - 4rem);"
     data-controller="chat"
     data-chat-request-id-value="<%= @request.id %>"
     data-chat-current-user-id-value="<%= current_user.id %>">

  <!-- 상단 헤더 -->
  <div class="bg-white border-b border-gray-200 px-4 py-3.5 flex items-center gap-3 flex-shrink-0 shadow-sm">
    <%= link_to :back, class: "text-gray-500 hover:text-gray-800 flex-shrink-0 p-1" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>

    <% other_user = current_user.id == @request.customer_id ? @request.master : @request.customer %>
    <div class="flex items-center gap-2.5 flex-1 min-w-0">
      <% if other_user.present? %>
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white font-bold text-base flex-shrink-0">
          <%= other_user.name&.first || "?" %>
        </div>
        <div class="min-w-0">
          <div class="flex items-center gap-1.5">
            <p class="font-bold text-gray-900 text-[15px] truncate"><%= other_user.name %></p>
            <span class="text-xs text-gray-400"><%= current_user.customer? ? "전문가" : "고객" %></span>
          </div>
          <p class="text-xs text-gray-400 truncate mt-0.5"><%= symptom_label(@request.symptom_type) %></p>
        </div>
      <% else %>
        <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-bold text-gray-900 text-[15px]">전문가 매칭 중</p>
          <p class="text-xs text-gray-400"><%= symptom_label(@request.symptom_type) %></p>
        </div>
      <% end %>
    </div>

    <% detail_path = current_user.customer? ? customers_request_path(@request) : masters_request_path(@request) %>
    <%= link_to detail_path, class: "flex-shrink-0 p-2 text-gray-400 hover:text-gray-700 rounded-lg hover:bg-gray-100 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    <% end %>
  </div>

  <!-- 진행 상태 바 -->
  <div class="bg-gray-50 border-b border-gray-100 px-4 py-2.5 flex-shrink-0">
    <%
      steps = [
        { label: "접수", statuses: ["reported", "open"] },
        { label: "매칭", statuses: ["assigned"] },
        { label: "방문·탐지", statuses: ["visiting", "detecting", "no_leak_found", "estimate_pending"] },
        { label: "견적·계약", statuses: ["estimate_submitted", "construction_agreed", "escrow_deposited"] },
        { label: "완료", statuses: ["constructing", "construction_completed", "closed"] }
      ]
      current_step_idx = steps.index { |s| s[:statuses].include?(@request.status) } || 0
    %>
    <div class="flex items-center">
      <% steps.each_with_index do |step, idx| %>
        <div class="flex items-center <%= idx < steps.length - 1 ? 'flex-1' : '' %>">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold
              <%= idx < current_step_idx ? 'bg-primary-600 text-white' : (idx == current_step_idx ? 'bg-primary-600 text-white ring-4 ring-primary-100' : 'bg-gray-200 text-gray-400') %>">
              <%= idx < current_step_idx ? '✓' : (idx + 1) %>
            </div>
            <span class="text-[9px] mt-0.5 font-medium <%= idx <= current_step_idx ? 'text-primary-600' : 'text-gray-400' %>">
              <%= step[:label] %>
            </span>
          </div>
          <% if idx < steps.length - 1 %>
            <div class="flex-1 h-0.5 mx-1 mb-3 rounded-full <%= idx < current_step_idx ? 'bg-primary-500' : 'bg-gray-200' %>"></div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 영상 재생 모달 -->
  <div id="video-modal" class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center" onclick="closeVideoModal()">
    <button type="button" onclick="closeVideoModal()" class="absolute top-4 right-4 text-white/80 hover:text-white z-10">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <video id="video-player" controls autoplay playsinline class="max-w-full max-h-[85vh] rounded-lg" onclick="event.stopPropagation()"></video>
  </div>
  <script>
    function openVideoModal(url) {
      const modal = document.getElementById('video-modal');
      const player = document.getElementById('video-player');
      player.src = url;
      modal.classList.remove('hidden');
    }
    function closeVideoModal() {
      const modal = document.getElementById('video-modal');
      const player = document.getElementById('video-player');
      player.pause();
      player.src = '';
      modal.classList.add('hidden');
    }
  </script>

  <!-- 메시지 영역 -->
  <div class="flex-1 overflow-y-auto px-4 py-4 space-y-2 bg-gray-50"
       data-chat-target="messagesContainer"
       id="messages">

    <!-- 접수 정보 카드 (시스템 메시지) -->
    <div class="flex justify-center mb-3">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm w-full max-w-sm overflow-hidden">
        <div class="bg-primary-50 border-b border-primary-100 px-4 py-2.5 flex items-center gap-2">
          <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span class="text-xs font-bold text-primary-700">접수된 체크 정보</span>
          <span class="ml-auto text-[10px] text-primary-500">#<%= @request.id %></span>
        </div>
        <div class="px-4 py-3 space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 flex-shrink-0">증상</span>
            <span class="text-xs font-semibold text-gray-800"><%= symptom_label(@request.symptom_type) %></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 flex-shrink-0">건물 유형</span>
            <span class="text-xs font-semibold text-gray-800"><%= @request.building_type_label rescue @request.building_type %></span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-xs text-gray-400 w-16 flex-shrink-0 mt-0.5">주소</span>
            <span class="text-xs font-semibold text-gray-800 leading-relaxed"><%= @request.address %></span>
          </div>
          <% if @request.description.present? %>
            <div class="flex items-start gap-2">
              <span class="text-xs text-gray-400 w-16 flex-shrink-0 mt-0.5">상세 설명</span>
              <span class="text-xs text-gray-700 leading-relaxed line-clamp-3"><%= @request.description %></span>
            </div>
          <% end %>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 flex-shrink-0">접수일</span>
            <span class="text-xs text-gray-600"><%= @request.created_at.strftime("%Y.%m.%d %H:%M") %></span>
          </div>
          <% has_media = @request.photos.attached? || @request.videos.attached? %>
          <% if has_media %>
            <div class="pt-1">
              <div class="flex gap-2 overflow-x-auto scrollbar-none">
                <% @request.videos.each do |video| %>
                  <button type="button" onclick="openVideoModal('<%= rails_blob_url(video) %>')"
                          class="flex-shrink-0 w-24 h-16 rounded-xl overflow-hidden bg-gray-900 relative cursor-pointer hover:opacity-80 transition">
                    <video src="<%= rails_blob_url(video) %>" class="w-full h-full object-cover" preload="metadata"></video>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-7 h-7 bg-white/80 rounded-full flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-gray-800 ml-0.5" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
                        </svg>
                      </div>
                    </div>
                  </button>
                <% end %>
                <% @request.photos.each do |photo| %>
                  <a href="<%= rails_blob_url(photo) %>" target="_blank"
                     class="flex-shrink-0 w-24 h-16 rounded-xl overflow-hidden cursor-pointer hover:opacity-80 transition">
                    <%= image_tag rails_blob_url(photo), class: "w-full h-full object-cover" %>
                  </a>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <div class="border-t border-gray-100 px-4 py-2 bg-gray-50">
          <p class="text-[10px] text-gray-400 text-center">추가 자료가 있으면 아래 채팅으로 올려주세요</p>
        </div>
      </div>
    </div>

    <%= render @messages %>
    <div class="hidden justify-start mb-1.5" data-chat-target="typingIndicator">
      <div class="flex items-end gap-2">
        <div class="w-8 h-8 rounded-full bg-gray-300 flex-shrink-0"></div>
        <div class="bg-white rounded-2xl rounded-bl-md border border-gray-200 px-4 py-3 shadow-sm">
          <div class="flex gap-1 items-center">
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 전문가 빠른 액션 -->
  <% if current_user.master? && @request.master_id == current_user.id %>
    <div class="bg-white border-t border-gray-100 px-3 py-2 flex gap-2 overflow-x-auto flex-shrink-0 scrollbar-none">
      <% if @request.estimate_pending? %>
        <%= link_to new_masters_request_estimate_path(@request),
              class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-primary-50 text-primary-700 rounded-xl text-xs font-semibold border border-primary-200 hover:bg-primary-100 transition-colors" do %>
          📋 견적서 보내기
        <% end %>
      <% end %>
      <% if @request.assigned? || @request.visiting? %>
        <%= button_to visit_masters_request_path(@request), method: :post,
              class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-green-50 text-green-700 rounded-xl text-xs font-semibold border border-green-200 hover:bg-green-100 transition-colors",
              form: { class: "inline-flex" } do %>
          🚗 방문 시작
        <% end %>
      <% end %>
      <% if @request.detecting? %>
        <%= button_to detection_complete_masters_request_path(@request), method: :post,
              class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-blue-50 text-blue-700 rounded-xl text-xs font-semibold border border-blue-200 hover:bg-blue-100 transition-colors",
              form: { class: "inline-flex" } do %>
          🔍 탐지 완료
        <% end %>
      <% end %>
      <% if @request.constructing? %>
        <%= button_to complete_construction_masters_request_path(@request), method: :post,
              class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-purple-50 text-purple-700 rounded-xl text-xs font-semibold border border-purple-200 hover:bg-purple-100 transition-colors",
              form: { class: "inline-flex" } do %>
          ✅ 공사 완료
        <% end %>
      <% end %>
      <% if @request.assigned? || @request.estimate_pending? || @request.estimate_submitted? %>
        <%= link_to new_masters_request_insurance_claim_path(@request),
              class: "flex-shrink-0 flex items-center gap-1.5 px-3 py-2 bg-amber-50 text-amber-700 rounded-xl text-xs font-semibold border border-amber-200 hover:bg-amber-100 transition-colors" do %>
          📋 보험서류
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- 고객 액션 버튼 -->
  <% if current_user.customer? && @request.customer_id == current_user.id %>
    <% if @request.construction_completed? %>
      <div class="bg-white border-t border-gray-100 px-4 py-2.5 flex-shrink-0">
        <%= button_to confirm_completion_customers_request_path(@request), method: :post,
              class: "w-full py-3 bg-green-600 text-white rounded-xl text-sm font-bold hover:bg-green-700 transition-colors",
              data: { confirm: "공사 완료를 확인할까요? 전문가에게 대금이 지급돼요." },
              form: { class: "w-full" } do %>
          ✅ 공사 완료 확인 및 대금 지급
        <% end %>
      </div>
    <% end %>
    <% if @request.estimate_submitted? %>
      <div class="bg-white border-t border-gray-100 px-4 py-2.5 flex-shrink-0">
        <% estimate = @request.estimates.pending.first || @request.estimates.last %>
        <% if estimate %>
          <%= button_to accept_estimate_customers_request_path(@request, estimate_id: estimate.id), method: :post,
                class: "w-full py-3 bg-primary-600 text-white rounded-xl text-sm font-bold hover:bg-primary-700 transition-colors",
                data: { confirm: "견적을 수락할까요?" },
                form: { class: "w-full" } do %>
            견적 수락하기 · <%= number_to_currency(estimate.total_amount, unit: "", precision: 0) %>원
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <!-- 고객 전용 상황별 안내 배너 -->
  <% if current_user.customer? && @request.customer_id == current_user.id %>
    <% if @request.request_source == "expert" && @request.description.blank? && %w[reported open assigned].include?(@request.status) %>
      <%# 영상 진단으로 접수했고 아직 상세 설명 미입력 %>
      <div class="bg-blue-50 border-t border-blue-200 px-4 py-2.5 flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-bold text-blue-900">증상 정보를 추가하면 더 빠르게 진행돼요</p>
          </div>
          <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "flex-shrink-0 text-xs font-bold text-white bg-blue-600 hover:bg-blue-700 px-2.5 py-1 rounded-lg transition-colors", data: { turbo: false } do %>
            입력 →
          <% end %>
        </div>
      </div>
    <% elsif %w[assigned visiting detecting].include?(@request.status) %>
      <%# 전문가 배정됨 → 안심 정보 %>
      <div class="bg-green-50 border-t border-green-200 px-4 py-2.5 flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <p class="text-xs text-green-800"><strong>에스크로 안전 결제</strong>로 보호받고 있어요 · 2년 무상 AS 보증</p>
        </div>
      </div>
    <% elsif %w[construction_completed closed].include?(@request.status) %>
      <%# 완료 → 리뷰 안내 %>
      <% unless @request.review.present? %>
        <div class="bg-amber-50 border-t border-amber-200 px-4 py-2.5 flex-shrink-0">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 bg-amber-500 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
            </div>
            <p class="flex-1 text-xs text-amber-800"><strong>리뷰를 남겨주시면</strong> 다음 체크 할인 쿠폰을 드려요</p>
            <%= link_to new_customers_request_review_path(@request), class: "flex-shrink-0 text-xs font-bold text-white bg-amber-500 hover:bg-amber-600 px-2.5 py-1 rounded-lg transition-colors" do %>
              리뷰 →
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <!-- 메시지 입력창 -->
  <div class="bg-white border-t border-gray-100 px-3 py-3 flex-shrink-0" style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));" data-controller="emoji-picker">

    <!-- 이모지 피커 패널 -->
    <div data-emoji-picker-target="panel"
         class="hidden mb-2 bg-white border border-gray-200 rounded-2xl shadow-lg p-3 max-h-52 overflow-y-auto">
      <div class="grid grid-cols-8 gap-1">
        <% %w[
          😊 😂 🥰 😍 🤣 😭 😘 🥺
          👍 👏 🙏 💪 ❤️ 🔥 ✅ 💯
          😅 🤔 😤 😎 🤩 😢 😩 😡
          💧 🏠 🔧 🚿 🪣 💦 🛁 🚽
          📷 📱 📋 📞 🗓️ ⏰ 💳 📝
          🎉 🎊 👋 🤝 💬 💌 📢 🔔
          🚗 🏃 ✈️ 🌟 ⭐ 🏆 🎯 💡
          😇 🥳 😜 🤗 😴 🤧 🤒 😷
        ].each do |emoji| %>
          <button type="button"
                  class="w-8 h-8 text-xl hover:bg-gray-100 rounded-lg flex items-center justify-center transition-colors"
                  data-action="click->emoji-picker#insert"
                  data-emoji="<%= emoji %>">
            <%= emoji %>
          </button>
        <% end %>
      </div>
    </div>

    <%= form_with(model: [@request, @message],
                 id: "message_form",
                 data: {
                   chat_target: "form",
                   action: "turbo:submit-end->chat#resetForm"
                 },
                 class: "flex items-end gap-2.5") do |f| %>

      <!-- 이모지 버튼 -->
      <button type="button"
              class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-gray-400 hover:text-yellow-500 transition-colors rounded-lg hover:bg-gray-100"
              data-action="click->emoji-picker#toggle">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </button>

      <!-- 이미지 첨부 버튼 -->
      <label class="flex-shrink-0 w-9 h-9 flex items-center justify-center text-gray-400 hover:text-primary-500 cursor-pointer transition-colors rounded-lg hover:bg-gray-100">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <%= f.file_field :images, multiple: true, accept: "image/*", class: "hidden" %>
      </label>

      <div class="flex-1">
        <%= f.text_area :content,
              rows: 1,
              placeholder: "메시지를 입력하세요",
              data: {
                chat_target: "input",
                emoji_picker_target: "textarea",
                action: "keydown->chat#handleKeydown input->chat#adjustTextareaHeight"
              },
              class: "w-full px-4 py-2 bg-gray-100 rounded-2xl focus:bg-white focus:ring-2 focus:ring-primary-400 focus:outline-none resize-none text-sm leading-snug transition-all max-h-24" %>
      </div>

      <button type="submit"
              data-chat-target="submitButton"
              class="flex-shrink-0 w-9 h-9 bg-primary-600 text-white rounded-full hover:bg-primary-700 active:bg-primary-800 transition-colors flex items-center justify-center shadow-sm">
        <svg class="w-4 h-4 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
      </button>
    <% end %>
  </div>
</div>
