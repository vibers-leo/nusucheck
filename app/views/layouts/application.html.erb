<!DOCTYPE html>
<html lang="ko">
<head>
  <title>누수체크 - 누수 전문 매칭 플랫폼</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="utf-8">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= action_cable_meta_tag %>
  <!-- Font Awesome 6 Free -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <!-- Sentry Error Tracking (프로덕션/스테이징만) -->
  <% if Rails.env.production? || Rails.env.staging? %>
    <% if ENV['SENTRY_DSN_FRONTEND'].present? %>
      <script
        src="https://js.sentry-cdn.com/sentry.browser.7.min.js"
        crossorigin="anonymous"
      ></script>
      <script>
        Sentry.init({
          dsn: "<%= ENV['SENTRY_DSN_FRONTEND'] %>",
          environment: "<%= Rails.env %>",
          release: "<%= ENV.fetch('GIT_COMMIT_SHA', 'development') %>",

          // 성능 모니터링
          tracesSampleRate: <%= ENV.fetch('SENTRY_TRACES_SAMPLE_RATE', 0.1).to_f %>,

          // 세션 재생 (선택적)
          replaysSessionSampleRate: 0.1,
          replaysOnErrorSampleRate: 1.0,

          // 통합 설정
          integrations: [
            new Sentry.BrowserTracing(),
            new Sentry.Replay({
              maskAllText: true,
              blockAllMedia: true
            })
          ],

          // 에러 필터링
          beforeSend(event, hint) {
            // 개발 도구가 열려있으면 에러를 콘솔에도 출력
            if (event.exception) {
              console.error(event.exception);
            }
            return event;
          },

          // 무시할 에러
          ignoreErrors: [
            'Non-Error promise rejection captured',
            'ResizeObserver loop limit exceeded',
            'Loading chunk',
            'ChunkLoadError'
          ]
        });

        // 현재 사용자 정보 설정 (로그인된 경우)
        <% if user_signed_in? %>
          Sentry.setUser({
            id: "<%= current_user.id %>",
            email: "<%= current_user.email %>",
            role: "<%= current_user.role %>"
          });
        <% end %>
      </script>
    <% end %>
  <% end %>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans<%= ' native-app' if hotwire_native_app? %>" data-controller="error-tracking">
  <!-- Loading Progress Bar -->
  <div data-controller="loading">
    <div data-loading-target="bar" class="loading-bar hidden"></div>
  </div>

  <!-- Navigation (네이티브 앱에서는 숨김 - 앱 자체 네비게이션 사용) -->
  <% unless hotwire_native_app? %>
  <%# 읽지 않은 채팅 수 (전역 - 모바일 메뉴 + 하단 탭 공용) %>
  <% unread_chat_count = user_signed_in? ? (begin
       reqs = current_user.master? ? current_user.assigned_requests : current_user.requests
       Message.where(request: reqs).where.not(sender_id: current_user.id).unread.count
     rescue; 0; end) : 0 %>
  <div data-controller="mobile-menu">
  <nav class="bg-white/95 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-20" aria-label="주 메뉴">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-14">

        <!-- 로고 -->
        <div class="flex items-center">
          <%= link_to root_path, class: "flex items-center gap-1.5" do %>
            <div class="w-7 h-7 bg-gradient-to-br from-primary-400 to-primary-600 rounded-lg flex items-center justify-center shadow-sm">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <span class="text-lg font-bold text-gray-900">누수체크</span>
          <% end %>

          <% if user_signed_in? %>
            <%
              nav_link = "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors"
              nav_link_active = "px-3 py-2 rounded-lg text-sm font-medium text-primary-600 bg-primary-50"
            %>
            <div class="hidden md:flex ml-6 items-center space-x-0.5">
              <% if current_user.customer? %>
                <%= link_to "홈", customers_dashboard_path, class: (controller_path == 'customers/dashboard' ? nav_link_active : nav_link) %>
                <%= link_to "내 체크", customers_requests_path, class: (controller_path == 'customers/requests' ? nav_link_active : nav_link) %>
                <%= link_to "전문가", customers_masters_path, class: (controller_path == 'customers/masters' ? nav_link_active : nav_link) %>
                <%= link_to "채팅", chats_path, class: (controller_name == 'chats' || controller_name == 'messages' ? nav_link_active : nav_link) %>

                <!-- 더보기 드롭다운 -->
                <div class="relative group">
                  <button class="<%= nav_link %> flex items-center gap-1">
                    더보기
                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div class="absolute left-0 top-full mt-1 w-44 bg-white rounded-xl shadow-lg border border-gray-100 py-1 z-30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                    <%= link_to customers_insurance_claims_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>📋</span> 보험청구
                    <% end %>
                    <%= link_to customers_payments_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>💳</span> 결제 내역
                    <% end %>
                    <div class="border-t border-gray-100 my-1"></div>
                    <%= link_to how_it_works_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>💡</span> 서비스 소개
                    <% end %>
                    <%= link_to reviews_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>⭐</span> 리뷰/후기
                    <% end %>
                    <%= link_to faq_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>💬</span> FAQ
                    <% end %>
                    <%= link_to events_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>🎁</span> 이벤트
                    <% end %>
                  </div>
                </div>

              <% elsif current_user.master? %>
                <%= link_to "홈", expert_dashboard_path, class: (controller_name == 'dashboard' ? nav_link_active : nav_link) %>
                <%= link_to "오더 피드", open_orders_masters_requests_path, class: (action_name == 'open_orders' ? nav_link_active : nav_link) %>
                <%= link_to "내 요청", masters_requests_path, class: (controller_path == 'masters/requests' && action_name != 'open_orders' ? nav_link_active : nav_link) %>
                <%= link_to "채팅", chats_path, class: (controller_name == 'chats' || controller_name == 'messages' ? nav_link_active : nav_link) %>

                <!-- 더보기 드롭다운 -->
                <div class="relative group">
                  <button class="<%= nav_link %> flex items-center gap-1">
                    더보기
                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div class="absolute left-0 top-full mt-1 w-44 bg-white rounded-xl shadow-lg border border-gray-100 py-1 z-30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                    <%= link_to expert_settlements_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>💰</span> 정산 내역
                    <% end %>
                    <%= link_to masters_insurance_claims_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>📋</span> 보험청구
                    <% end %>
                    <%= link_to masters_profile_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary-600 transition-colors" do %>
                      <span>👤</span> 내 프로필
                    <% end %>
                  </div>
                </div>

              <% elsif current_user.admin? %>
                <%= link_to "대시보드", admin_root_path, class: (controller_name == 'dashboard' ? nav_link_active : nav_link) %>
                <%= link_to "체크관리", admin_requests_path, class: (controller_name == 'requests' ? nav_link_active : nav_link) %>
                <%= link_to "마스터관리", admin_masters_path, class: (controller_name == 'masters' ? nav_link_active : nav_link) %>

                <!-- 더보기 드롭다운 -->
                <div class="relative group">
                  <button class="<%= nav_link %> flex items-center gap-1">
                    더보기
                    <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div class="absolute left-0 top-full mt-1 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-1 z-30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                    <%= link_to admin_feedbacks_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                      <span>💬</span> 피드백
                    <% end %>
                    <%= link_to admin_surveys_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                      <span>📊</span> 설문
                    <% end %>
                    <%= link_to admin_insurance_claims_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                      <span>📋</span> 보험청구
                    <% end %>
                    <%= link_to admin_payment_audit_logs_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                      <span>💳</span> 결제로그
                    <% end %>
                    <%= link_to admin_escrow_transactions_path, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                      <span>🔒</span> 에스크로
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <%= link_to "누수 체크하기", new_customers_request_path, class: "hidden sm:inline-flex ml-6 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
          <% end %>
        </div>

        <!-- 우측 액션 -->
        <div class="flex items-center gap-1">
          <% if user_signed_in? %>
            <%= render "shared/notifications_dropdown" %>

            <!-- 유저 드롭다운 -->
            <div class="relative" data-controller="user-menu">
              <button type="button"
                      data-action="click->user-menu#toggle"
                      class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">
                <span class="max-w-[80px] truncate"><%= current_user.name %></span>
                <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>

              <div data-user-menu-target="dropdown"
                   class="hidden w-44 bg-white rounded-xl shadow-xl border border-gray-100 py-1 z-[999]" style="position:fixed;top:60px;right:16px">
                <% profile_path = current_user.customer? ? customers_profile_path : (current_user.master? ? masters_profile_path : admin_root_path) %>
                <%= link_to profile_path, class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                  내 정보
                <% end %>
                <%= link_to edit_user_registration_path, class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                  </svg>
                  비밀번호 변경
                <% end %>
                <div class="border-t border-gray-100 my-1"></div>
                <%= button_to destroy_user_session_path, method: :delete,
                      class: "w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                  </svg>
                  로그아웃
                <% end %>
              </div>
            </div>

          <% else %>
            <%= link_to "로그인", new_user_session_path,
                  class: "hidden sm:inline-flex px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors" %>
            <%= link_to "시작하기", new_user_registration_path,
                  class: "hidden sm:inline-flex px-4 py-1.5 rounded-lg text-sm font-semibold bg-primary-500 text-white hover:bg-primary-600 transition-colors shadow-sm" %>
          <% end %>

          <!-- 햄버거 버튼: 고객/전문가/관리자/비로그인 모두 (모바일 전용) -->
          <button type="button"
                  class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors relative"
                  data-action="mobile-menu#toggle"
                  data-mobile-menu-target="button"
                  aria-expanded="false"
                  aria-label="메뉴 열기">
            <svg class="h-5 w-5" data-mobile-menu-target="iconOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg class="h-5 w-5 hidden" data-mobile-menu-target="iconClose" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <% if unread_chat_count > 0 %>
              <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
            <% end %>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ═══ 모바일 전체 메뉴 패널 (역할별 분기) ═══ -->
  <div class="md:hidden hidden fixed top-14 left-0 right-0 bottom-0 bg-white z-50 overflow-y-auto" data-mobile-menu-target="panel">
      <% if user_signed_in? %>
        <!-- 프로필 헤더 -->
        <div class="px-5 py-4 bg-gray-50 border-b border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white font-bold text-xl shadow-sm flex-shrink-0">
              <%= current_user.name&.first || "?" %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-bold text-gray-900 text-[15px] truncate"><%= current_user.name %></p>
              <% if current_user.admin? %>
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-violet-600 bg-violet-50 px-2 py-0.5 rounded-full mt-0.5">
                  <i class="fa-solid fa-shield-halved text-[10px]"></i> 관리자
                </span>
              <% elsif current_user.master? %>
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full mt-0.5">
                  <i class="fa-solid fa-star text-[10px]"></i> 전문가
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full mt-0.5">
                  <i class="fa-solid fa-user text-[10px]"></i> 고객
                </span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="px-3 py-3 pb-8">
          <% if current_user.customer? %>
            <%# ── 고객 메뉴 ── %>
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-wider px-3 pt-3 pb-1">메인</p>
            <%= link_to customers_dashboard_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl transition-colors #{controller_path == 'customers/dashboard' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-house w-5 text-center text-base"></i>
              <span class="font-medium">홈</span>
            <% end %>
            <%= link_to customers_requests_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl transition-colors #{controller_path == 'customers/requests' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-droplet w-5 text-center text-base"></i>
              <span class="font-medium">내 체크</span>
            <% end %>
            <%= link_to chats_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl transition-colors #{(controller_name == 'chats' || controller_name == 'messages') ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-comment-dots w-5 text-center text-base"></i>
              <span class="font-medium">채팅</span>
              <% if unread_chat_count > 0 %>
                <span class="ml-auto text-xs font-bold bg-red-500 text-white px-1.5 py-0.5 rounded-full"><%= unread_chat_count > 9 ? "9+" : unread_chat_count %></span>
              <% end %>
            <% end %>
            <%= link_to customers_masters_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl transition-colors #{controller_path == 'customers/masters' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-user-tie w-5 text-center text-base"></i>
              <span class="font-medium">전문가 찾기</span>
            <% end %>

            <div class="border-t border-gray-100 my-2"></div>
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-wider px-3 pb-1">내 활동</p>
            <%= link_to customers_insurance_claims_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-file-shield w-5 text-center text-base"></i>
              <span class="font-medium">보험청구</span>
            <% end %>
            <%= link_to customers_payments_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-credit-card w-5 text-center text-base"></i>
              <span class="font-medium">결제 내역</span>
            <% end %>
            <%= link_to customers_profile_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl transition-colors #{controller_path == 'customers/profiles' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-user w-5 text-center text-base"></i>
              <span class="font-medium">내 프로필</span>
            <% end %>

            <div class="border-t border-gray-100 my-2"></div>
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-wider px-3 pb-1">서비스</p>
            <%= link_to about_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-circle-info w-5 text-center text-base"></i>
              <span class="font-medium">서비스 소개</span>
            <% end %>
