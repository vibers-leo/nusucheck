  <script>
  var aiExpanded = false;
  function toggleAiSize() {
    var panel = document.getElementById('ai-chatbot-panel');
    if (aiExpanded) {
      panel.style.width = '420px';
      panel.style.height = '520px';
      panel.style.bottom = '80px';
      panel.style.right = '16px';
    } else {
      panel.style.width = Math.min(680, window.innerWidth * 0.9) + 'px';
      panel.style.height = Math.min(700, window.innerHeight * 0.8) + 'px';
      panel.style.bottom = '40px';
      panel.style.right = '16px';
    }
    aiExpanded = !aiExpanded;
  }

  // 좌상단 드래그 리사이즈
  (function() {
    var handle = document.getElementById('ai-resize-handle');
    if (!handle) return;
    var panel = document.getElementById('ai-chatbot-panel');
    var startX, startY, startW, startH, startLeft, startTop;

    handle.addEventListener('mousedown', function(e) {
      e.preventDefault();
      startX = e.clientX; startY = e.clientY;
      var rect = panel.getBoundingClientRect();
      startW = rect.width; startH = rect.height;
      startLeft = rect.left; startTop = rect.top;

      function onMove(e) {
        var dx = startX - e.clientX;
        var dy = startY - e.clientY;
        var newW = Math.max(320, Math.min(startW + dx, window.innerWidth * 0.9));
        var newH = Math.max(360, Math.min(startH + dy, window.innerHeight * 0.85));
        panel.style.width = newW + 'px';
        panel.style.height = newH + 'px';
      }
      function onUp() {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      }
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  })();

  function toggleAiChatbot() {
    document.getElementById('ai-chatbot-panel').classList.toggle('hidden');
    var input = document.getElementById('ai-chatbot-input');
    if (input) setTimeout(function() { input.focus(); }, 100);
  }

  function sendAiChat() {
    var input = document.getElementById('ai-chatbot-input');
    var msg = input.value.trim();
    if (!msg) return;
    input.value = '';

    var container = document.getElementById('ai-chatbot-messages');

    // 유저 메시지
    var userDiv = document.createElement('div');
    userDiv.className = 'flex justify-end';
    userDiv.innerHTML = '<div class="bg-primary-600 text-white rounded-2xl rounded-tr-sm px-3 py-2 text-sm max-w-[80%]">' + msg.replace(/</g, '&lt;') + '</div>';
    container.appendChild(userDiv);
    container.scrollTop = container.scrollHeight;

    // AI 응답 (제로클로 웹훅)
    var loadingDiv = document.createElement('div');
    loadingDiv.className = 'flex gap-2 ai-loading';
    loadingDiv.innerHTML = '<img src="/images/characters/ai-robot.png" alt="" class="w-8 h-8 max-w-[32px] max-h-[32px] object-contain flex-shrink-0"><div class="bg-gray-100 rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-400">생각 중...</div>';
    container.appendChild(loadingDiv);
    container.scrollTop = container.scrollHeight;

    fetch('/api/ai_chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
      body: JSON.stringify({ message: msg })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      container.removeChild(loadingDiv);
      var aiDiv = document.createElement('div');
      aiDiv.className = 'flex gap-2';
      aiDiv.innerHTML = '<img src="/images/characters/ai-robot.png" alt="" class="w-8 h-8 max-w-[32px] max-h-[32px] object-contain flex-shrink-0"><div class="bg-gray-100 rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-700 max-w-[80%]">' + (data.reply || '잠시 후 다시 시도해주세요.').replace(/\n/g, '<br>') + '</div>';
      container.appendChild(aiDiv);
      container.scrollTop = container.scrollHeight;
    })
    .catch(function() {
      container.removeChild(loadingDiv);
      var errDiv = document.createElement('div');
      errDiv.className = 'flex gap-2';
      errDiv.innerHTML = '<img src="/images/characters/sad.png" alt="" class="w-8 h-8 max-w-[32px] max-h-[32px] object-contain flex-shrink-0"><div class="bg-gray-100 rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-500 max-w-[80%]">잠시 연결이 어려워요. 조금 뒤에 다시 시도해주세요.</div>';
      container.appendChild(errDiv);
      container.scrollTop = container.scrollHeight;
    });
  }
  </script>

