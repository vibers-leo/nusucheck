<!DOCTYPE html>
<html lang="ko">
<head>
  <title>누수체크 - 누수 전문 매칭 플랫폼</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="utf-8">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <!-- Sentry Error Tracking (프로덕션/스테이징만) -->
  <% if Rails.env.production? || Rails.env.staging? %>
    <% if ENV['SENTRY_DSN_FRONTEND'].present? %>
      <script
        src="https://js.sentry-cdn.com/sentry.browser.7.min.js"
        crossorigin="anonymous"
      ></script>
      <script>
        Sentry.init({
          dsn: "<%= ENV['SENTRY_DSN_FRONTEND'] %>",
          environment: "<%= Rails.env %>",
          release: "<%= ENV.fetch('GIT_COMMIT_SHA', 'development') %>",

          // 성능 모니터링
          tracesSampleRate: <%= ENV.fetch('SENTRY_TRACES_SAMPLE_RATE', 0.1).to_f %>,

          // 세션 재생 (선택적)
          replaysSessionSampleRate: 0.1,
          replaysOnErrorSampleRate: 1.0,

          // 통합 설정
          integrations: [
            new Sentry.BrowserTracing(),
            new Sentry.Replay({
              maskAllText: true,
              blockAllMedia: true
            })
          ],

          // 에러 필터링
          beforeSend(event, hint) {
            // 개발 도구가 열려있으면 에러를 콘솔에도 출력
            if (event.exception) {
              console.error(event.exception);
            }
            return event;
          },

          // 무시할 에러
          ignoreErrors: [
            'Non-Error promise rejection captured',
            'ResizeObserver loop limit exceeded',
            'Loading chunk',
            'ChunkLoadError'
          ]
        });

        // 현재 사용자 정보 설정 (로그인된 경우)
        <% if user_signed_in? %>
          Sentry.setUser({
            id: "<%= current_user.id %>",
            email: "<%= current_user.email %>",
            role: "<%= current_user.role %>"
          });
        <% end %>
      </script>
    <% end %>
  <% end %>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans<%= ' native-app' if hotwire_native_app? %>" data-controller="error-tracking">
  <!-- Loading Progress Bar -->
  <div data-controller="loading">
    <div data-loading-target="bar" class="loading-bar hidden"></div>
  </div>

  <!-- Navigation (네이티브 앱에서는 숨김 - 앱 자체 네비게이션 사용) -->
  <% unless hotwire_native_app? %>
  <nav class="bg-white/95 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-20" aria-label="주 메뉴" data-controller="mobile-menu">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-14">

        <!-- 로고 -->
        <div class="flex items-center">
          <%= link_to root_path, class: "flex items-center gap-1.5" do %>
            <div class="w-7 h-7 bg-gradient-to-br from-primary-400 to-primary-600 rounded-lg flex items-center justify-center shadow-sm">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <span class="text-lg font-bold text-gray-900">누수체크</span>
          <% end %>

          <% if user_signed_in? %>
            <div class="hidden md:flex ml-6 space-x-1">
              <% if current_user.customer? %>
                <%= link_to "홈", customers_dashboard_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
                <%= link_to "내 체크", customers_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
              <% elsif current_user.master? %>
                <%= link_to "홈", expert_dashboard_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
                <%= link_to "공개 오더", open_orders_masters_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
              <% elsif current_user.admin? %>
                <%= link_to "대시보드", admin_root_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
                <%= link_to "체크관리", admin_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
                <%= link_to "마스터관리", admin_masters_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
              <% end %>
            </div>
          <% else %>
            <%= link_to "누수 체크하기", new_customers_request_path, class: "hidden sm:inline-flex ml-6 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors" %>
          <% end %>
        </div>

        <!-- 우측 액션 -->
        <div class="flex items-center gap-2">
          <% if user_signed_in? %>
            <%= render "shared/notifications_dropdown" %>
            <span class="hidden sm:inline text-sm text-gray-500"><%= current_user.name %></span>
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete,
                  class: "hidden md:inline-flex px-3 py-1.5 rounded-lg text-sm font-medium text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors" %>
          <% else %>
            <%= link_to "로그인", new_user_session_path,
                  class: "hidden sm:inline-flex px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors" %>
            <%= link_to "시작하기", new_user_registration_path,
                  class: "hidden sm:inline-flex px-4 py-1.5 rounded-lg text-sm font-semibold bg-primary-500 text-white hover:bg-primary-600 transition-colors shadow-sm" %>
          <% end %>

          <% unless user_signed_in? %>
          <button type="button"
                  class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                  data-action="mobile-menu#toggle"
                  data-mobile-menu-target="button"
                  aria-expanded="false"
                  aria-label="메뉴 열기">
            <svg class="h-5 w-5" data-mobile-menu-target="iconOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg class="h-5 w-5 hidden" data-mobile-menu-target="iconClose" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <% end %>
        </div>
      </div>
    </div>

    <!-- 모바일 드롭다운 (비로그인 전용) -->
    <% unless user_signed_in? %>
    <div class="md:hidden hidden border-t border-gray-100" data-mobile-menu-target="panel">
      <div class="px-4 py-3 space-y-1 mobile-menu-enter bg-white shadow-lg">
        <% unless controller_name == 'pages' && action_name == 'coming_soon' %>
          <%= link_to "누수 진단하기", new_leak_inspection_path,
                class: "flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-primary-50 hover:text-primary-700 transition-colors" %>
        <% end %>
        <%= link_to "서비스 소개", about_path,
              class: "flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-700 hover:bg-primary-50 hover:text-primary-700 transition-colors" %>
        <div class="pt-2 pb-1 grid grid-cols-2 gap-2 border-t border-gray-100 mt-2">
          <%= link_to "로그인", new_user_session_path,
                class: "text-center py-2.5 rounded-xl text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors" %>
          <%= link_to "시작하기", new_user_registration_path,
                class: "text-center py-2.5 rounded-xl text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors" %>
        </div>
      </div>
    </div>
    <% end %>
  </nav>
  <% end %>

  <!-- Flash messages -->
  <%= render "shared/flash_messages" %>

  <!-- Main content -->
  <main class="flex-grow<%= hotwire_native_app? ? ' px-4 py-4' : ' max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8' %> w-full">
    <%= yield %>
  </main>

  <!-- 플로팅 액션 버튼 (FAB) - 당근마켓 스타일 -->
  <% unless hotwire_native_app? %>
    <% if !user_signed_in? || (user_signed_in? && current_user.customer?) %>
      <%= link_to new_customers_request_path, class: "fixed bottom-6 right-6 z-50 w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white rounded-full shadow-2xl hover:shadow-3xl transition-all duration-300 flex items-center justify-center group hover:scale-110", data: { turbo: false } do %>
        <svg class="w-8 h-8 group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/>
        </svg>
        <span class="sr-only">누수 체크하기</span>
      <% end %>
    <% end %>
  <% end %>

  <!-- 고객/전문가용 하단 탭 네비게이션 (모바일) -->
  <% if user_signed_in? %>
    <% unless hotwire_native_app? %>
      <% unread_chat_count = begin
           reqs = current_user.master? ? current_user.assigned_requests : current_user.requests
           Message.where(request: reqs).where.not(sender_id: current_user.id).unread.count
         rescue
           0
         end %>
      <% if current_user.customer? %>
        <!-- 고객용 하단 탭 (4탭: 홈/체크하기/채팅/마이) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-4 h-16">

            <!-- 홈 -->
            <%= link_to customers_dashboard_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_path == 'customers/dashboard' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_path == 'customers/dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span class="text-[10px] font-medium">홈</span>
            <% end %>

            <!-- 체크하기 (가운데 강조) -->
            <%= link_to new_customers_request_path, class: "flex flex-col items-center justify-center gap-0.5", data: { turbo: false } do %>
              <div class="w-11 h-11 bg-primary-600 rounded-2xl flex items-center justify-center shadow-lg shadow-primary-200 -mt-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                </svg>
              </div>
              <span class="text-[10px] font-medium text-primary-600 mt-0.5">체크</span>
            <% end %>

            <!-- 채팅 (읽지 않은 메시지 뱃지) -->
            <%= link_to chats_path, class: "flex flex-col items-center justify-center gap-0.5 relative transition-colors #{controller_name == 'chats' || controller_name == 'messages' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= (controller_name == 'chats' || controller_name == 'messages') ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <% if unread_chat_count > 0 %>
                  <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center"><%= unread_chat_count > 9 ? "9+" : unread_chat_count %></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">채팅</span>
            <% end %>

            <!-- 마이 -->
            <%= link_to customers_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_path == 'customers/profiles' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_path == 'customers/profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% elsif current_user.master? %>
        <!-- 전문가용 하단 탭 (4탭: 홈/오더피드/채팅/마이) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-4 h-16">

            <!-- 홈 -->
            <%= link_to expert_dashboard_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'dashboard' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span class="text-[10px] font-medium">홈</span>
            <% end %>

            <!-- 오더 피드 -->
            <%= link_to open_orders_masters_requests_path, class: "flex flex-col items-center justify-center gap-0.5 relative transition-colors #{action_name == 'open_orders' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= action_name == 'open_orders' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                <% open_count = Request.open_orders.count rescue 0 %>
                <% if open_count > 0 %>
                  <span class="absolute -top-1 -right-1 w-4 h-4 bg-primary-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center"><%= open_count > 9 ? "9+" : open_count %></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">오더</span>
            <% end %>

            <!-- 채팅 -->
            <%= link_to chats_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'chats' || controller_name == 'messages' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= (controller_name == 'chats' || controller_name == 'messages') ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <span class="text-[10px] font-medium">채팅</span>
            <% end %>

            <!-- 마이 -->
            <%= link_to masters_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'profiles' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% elsif current_user.admin? %>
        <!-- 관리자용 하단 탭 (4탭: 대시보드/체크/전문가/마이) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-4 h-16">

            <%= link_to admin_root_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'dashboard' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
              <span class="text-[10px] font-medium">대시보드</span>
            <% end %>

            <%= link_to admin_requests_path, class: "flex flex-col items-center justify-center gap-0.5 relative transition-colors #{controller_name == 'requests' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= controller_name == 'requests' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <% pending = Request.where(status: "reported").count rescue 0 %>
                <% if pending > 0 %>
                  <span class="absolute -top-1 -right-1 w-4 h-4 bg-orange-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center"><%= pending > 9 ? "9+" : pending %></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">체크</span>
            <% end %>

            <%= link_to admin_masters_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'masters' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'masters' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-[10px] font-medium">전문가</span>
            <% end %>

            <%= link_to admin_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'profiles' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% end %>

      <!-- 하단 탭 높이만큼 여백 추가 (모바일) -->
      <div class="md:hidden h-16"></div>
    <% end %>
  <% end %>

  <!-- Footer (네이티브 앱에서는 숨김) -->
