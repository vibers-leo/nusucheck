  <!-- Footer (네이티브 앱에서는 숨김) -->
  <% unless hotwire_native_app? %>
  <% show_footer_mobile = controller_name.in?(%w[dashboard profiles]) || (controller_name == 'pages' && action_name == 'home') %>
  <footer class="bg-gray-800 text-gray-300 mt-auto <%= show_footer_mobile ? '' : 'hidden md:block' %>">

    <!-- 모바일: 접힌 사업자정보 -->
    <div class="md:hidden px-4 py-3">
      <button onclick="toggleFooterInfo(this)"
              class="w-full flex items-center justify-between text-xs text-gray-500 hover:text-gray-300 transition-colors">
        <span>사업자정보</span>
        <svg class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div class="hidden mt-3 space-y-3 text-xs text-gray-400 pb-2">
        <div>
          <p class="font-semibold text-gray-300 mb-1">누수체크</p>
          <p>누수 전문 매칭 플랫폼 · 투명한 가격, 검증된 전문가</p>
        </div>
        <div class="flex flex-wrap gap-x-4 gap-y-1">
          <%= link_to "AI 사전점검", new_customers_request_path(mode: 'diagnosis'), class: "hover:text-white transition" %>
          <%= link_to "서비스 소개", about_path, class: "hover:text-white transition" %>
          <%= link_to "가격안내", pricing_path, class: "hover:text-white transition" %>
          <%= link_to "의견 보내기", new_feedback_path, class: "hover:text-white transition" %>
          <a href="mailto:contact@nusucheck.com" class="hover:text-white transition">contact@nusucheck.com</a>
        </div>
        <p class="text-gray-600">&copy; <%= Date.current.year %> 누수체크. All rights reserved.</p>
      </div>
    </div>

    <!-- 데스크톱: 전체 푸터 -->
    <div class="hidden md:block py-8">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-3 gap-8 mb-6">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">누수체크</h3>
            <p class="text-sm text-gray-400">누수 전문 매칭 플랫폼</p>
            <p class="text-sm text-gray-400">투명한 가격, 검증된 전문가</p>
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm mb-3">서비스</h3>
            <ul class="space-y-2 text-sm">
              <li><%= link_to "AI 사전점검", new_customers_request_path(mode: 'diagnosis'), class: "text-gray-400 hover:text-white transition" %></li>
              <li><%= link_to "서비스 소개", about_path, class: "text-gray-400 hover:text-white transition" %></li>
              <li><%= link_to "가격안내", pricing_path, class: "text-gray-400 hover:text-white transition" %></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm mb-3">고객지원</h3>
            <ul class="space-y-2 text-sm">
              <li><%= link_to "의견 보내기", new_feedback_path, class: "text-gray-400 hover:text-white transition" %></li>
              <li><%= link_to "설문 참여하기", new_survey_path, class: "text-gray-400 hover:text-white transition" %></li>
              <li><a href="mailto:contact@nusucheck.com" class="text-gray-400 hover:text-white transition">contact@nusucheck.com</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 pt-6 text-center">
          <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> 누수체크. All rights reserved.</p>
        </div>
      </div>
    </div>

  </footer>
  <% end %>

  <script>
    // ── 햄버거 메뉴 ──
    function toggleMobileMenu(event) {
      event.stopPropagation();
      var panel = document.getElementById('mobile-nav-panel');
      var iconOpen = document.getElementById('hamburger-icon-open');
      var iconClose = document.getElementById('hamburger-icon-close');
      if (!panel) return;
      var isOpen = !panel.classList.contains('hidden');
      if (isOpen) {
        panel.classList.add('hidden');
        if (iconOpen) iconOpen.classList.remove('hidden');
        if (iconClose) iconClose.classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        panel.classList.remove('hidden');
        if (iconOpen) iconOpen.classList.add('hidden');
        if (iconClose) iconClose.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }

    // ── 드롭다운 포지셔닝 ──
    function positionDropdown(trigger, dropdown) {
      var rect = trigger.getBoundingClientRect();
      dropdown.style.position = 'fixed';
      dropdown.style.top = (rect.bottom + 4) + 'px';
      dropdown.style.right = (window.innerWidth - rect.right) + 'px';
      dropdown.style.left = 'auto';
      dropdown.style.zIndex = '9999';
    }

    // ── 유저 드롭다운 ──
    function toggleUserDropdown(event) {
      event.stopPropagation();
      var dd = document.getElementById('user-nav-dropdown');
      var notifDd = document.getElementById('notifications-dropdown');
      if (!dd) return;
      if (notifDd) notifDd.classList.add('hidden');
      if (dd.classList.contains('hidden')) {
        positionDropdown(event.currentTarget, dd);
        dd.classList.remove('hidden');
      } else {
        dd.classList.add('hidden');
      }
    }

    // ── 알림 드롭다운 ──
    function toggleNotifications(event) {
      event.stopPropagation();
      var dd = document.getElementById('notifications-dropdown');
      var userDd = document.getElementById('user-nav-dropdown');
      if (!dd) return;
      if (userDd) userDd.classList.add('hidden');
      if (dd.classList.contains('hidden')) {
        positionDropdown(event.currentTarget, dd);
        dd.classList.remove('hidden');
      } else {
        dd.classList.add('hidden');
      }
    }

    // ── 외부 클릭 시 드롭다운 닫기 ──
    document.addEventListener('click', function() {
      var userDd = document.getElementById('user-nav-dropdown');
      var notifDd = document.getElementById('notifications-dropdown');
      if (userDd) userDd.classList.add('hidden');
      if (notifDd) notifDd.classList.add('hidden');
    });

    // ── 사업자정보 푸터 토글 ──
    function toggleFooterInfo(btn) {
      var content = btn.nextElementSibling;
      var chevron = btn.querySelector('svg');
      var isHidden = content.classList.contains('hidden');
      content.classList.toggle('hidden', !isHidden);
      if (chevron) chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
    }

    // ── Turbo 페이지 이동 시 모바일 메뉴 닫기 ──
    document.addEventListener('turbo:before-visit', function() {
      var panel = document.getElementById('mobile-nav-panel');
      var iconOpen = document.getElementById('hamburger-icon-open');
      var iconClose = document.getElementById('hamburger-icon-close');
      if (panel) panel.classList.add('hidden');
      if (iconOpen) iconOpen.classList.remove('hidden');
      if (iconClose) iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    });
  </script>
</body>
</html>
