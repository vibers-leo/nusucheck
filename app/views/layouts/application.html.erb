<!DOCTYPE html>
<html lang="ko">
<head>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7704550771011130" crossorigin="anonymous"></script>
  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CGK1BSBM63"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CGK1BSBM63');
  </script>
  <title><%= content_for?(:title) ? "#{yield(:title)} | 누수체크" : "누수체크 - 누수 전문 매칭 플랫폼" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="utf-8">
  <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "AI 누수 진단부터 검증된 전문가 매칭까지. 투명한 가격, 문제 발생 시 중재 지원." %>">
  <meta name="keywords" content="누수, 누수탐지, 누수수리, 방수공사, 누수체크, 아파트누수, 화장실누수, 천장누수">
  <link rel="canonical" href="<%= request.original_url %>">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="ko_KR">
  <meta property="og:site_name" content="누수체크">
  <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "누수체크 - 누수 전문 매칭 플랫폼" %>">
  <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "AI 누수 진단 + 검증된 전문가 매칭 + 투명한 견적" %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:image" content="<%= asset_url('og-image.png') rescue 'https://nusucheck.com/og-image.png' %>">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "누수체크" %>">
  <meta name="twitter:description" content="AI 누수 진단 + 검증된 전문가 매칭 + 투명한 견적">
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/Freesentation/paperlogy@main/Paperlogy.css">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= action_cable_meta_tag %>
  <!-- Font Awesome 6 Free -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <!-- Driver.js — 인터랙티브 투어 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css" data-turbo-track="reload"/>
  <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js" data-turbo-track="reload"></script>

  <!-- Sentry Error Tracking (프로덕션/스테이징만) -->
  <% if Rails.env.production? || Rails.env.staging? %>
    <% if ENV['SENTRY_DSN_FRONTEND'].present? %>
      <script
        src="https://js.sentry-cdn.com/sentry.browser.7.min.js"
        crossorigin="anonymous"
      ></script>
      <script>
        Sentry.init({
          dsn: "<%= ENV['SENTRY_DSN_FRONTEND'] %>",
          environment: "<%= Rails.env %>",
          release: "<%= ENV.fetch('GIT_COMMIT_SHA', 'development') %>",

          // 성능 모니터링
          tracesSampleRate: <%= ENV.fetch('SENTRY_TRACES_SAMPLE_RATE', 0.1).to_f %>,

          // 세션 재생 (선택적)
          replaysSessionSampleRate: 0.1,
          replaysOnErrorSampleRate: 1.0,

          // 통합 설정
          integrations: [
            new Sentry.BrowserTracing(),
            new Sentry.Replay({
              maskAllText: true,
              blockAllMedia: true
            })
          ],

          // 에러 필터링
          beforeSend(event, hint) {
            // 개발 도구가 열려있으면 에러를 콘솔에도 출력
            if (event.exception) {
              console.error(event.exception);
            }
            return event;
          },

          // 무시할 에러
          ignoreErrors: [
            'Non-Error promise rejection captured',
            'ResizeObserver loop limit exceeded',
            'Loading chunk',
            'ChunkLoadError'
          ]
        });

        // 현재 사용자 정보 설정 (로그인된 경우)
        <% if user_signed_in? %>
          Sentry.setUser({
            id: "<%= current_user.id %>",
            email: "<%= current_user.email %>",
            role: "<%= current_user.role %>"
          });
        <% end %>
      </script>
    <% end %>
  <% end %>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans<%= ' native-app' if hotwire_native_app? %>" data-controller="error-tracking">
  <!-- Loading Progress Bar -->
  <div data-controller="loading">
    <div data-loading-target="bar" class="loading-bar hidden"></div>
  </div>

  <!-- Navigation (네이티브 앱에서는 숨김 - 앱 자체 네비게이션 사용) -->
  <% unless hotwire_native_app? %>
  <%# 읽지 않은 채팅 수 (전역 - 모바일 메뉴 + 하단 탭 공용) %>
  <% unread_chat_count = user_signed_in? ? (begin
       reqs = current_user.master? ? current_user.assigned_requests : current_user.requests
       Message.where(request: reqs).where.not(sender_id: current_user.id).unread.count
     rescue; 0; end) : 0 %>
  <div data-controller="mobile-menu">
  <nav class="bg-white/95 backdrop-blur-sm border-b border-gray-100 sticky top-0 z-50" aria-label="주 메뉴">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative flex items-center justify-between h-14">

        <!-- 로고 -->
        <div class="flex items-center">
          <%= link_to root_path, class: "flex items-center gap-1.5" do %>
            <div class="w-7 h-7 bg-gradient-to-br from-primary-400 to-primary-600 rounded-lg flex items-center justify-center shadow-sm">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <span class="text-lg font-bold text-gray-900">누수체크</span>
          <% end %>
        </div>

        <!-- 가운데 메뉴 -->
        <% if user_signed_in? %>
          <%
            nav_link = "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors"
            nav_link_active = "px-3 py-2 rounded-lg text-sm font-medium text-primary-600 bg-primary-50"
          %>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center space-x-0.5">
            <% if current_user.customer? %>
              <%= link_to "홈", customers_dashboard_path, id: "tnav-home", class: (controller_path == 'customers/dashboard' ? nav_link_active : nav_link) %>
              <%= link_to "내 체크", customers_requests_path, id: "tnav-requests", class: (controller_path == 'customers/requests' ? nav_link_active : nav_link) %>
              <%= link_to "커뮤니티", community_path, id: "tnav-community", class: (controller_name == 'posts' ? nav_link_active : nav_link) %>
            <% elsif current_user.master? %>
              <%= link_to "홈", expert_dashboard_path, id: "tnav-home", class: (controller_name == 'dashboard' ? nav_link_active : nav_link) %>
              <%= link_to "오더 피드", open_orders_masters_requests_path, id: "tnav-orders", class: (action_name == 'open_orders' ? nav_link_active : nav_link) %>
              <%= link_to "내 작업", masters_requests_path, id: "tnav-my-work", class: (controller_path == 'masters/requests' && action_name != 'open_orders' ? nav_link_active : nav_link) %>
              <%= link_to "구역 선점", masters_zone_claims_path, id: "cta-zone-claim", class: (controller_path == 'masters/zone_claims' ? nav_link_active : nav_link) %>
              <%= link_to "결제 관리", masters_billing_path, id: "tnav-billing", class: (controller_path == 'masters/billing' ? nav_link_active : nav_link) %>
              <%= link_to "커뮤니티", community_path, id: "tnav-community", class: (controller_name == 'posts' ? nav_link_active : nav_link) %>
            <% elsif current_user.admin? %>
              <%= link_to "관리자", admin_root_path, class: (controller_path.start_with?('admin') ? nav_link_active : nav_link) %>
              <%= link_to "고객체험", customers_dashboard_path, class: (controller_path.start_with?('customers') ? nav_link_active : nav_link) %>
              <% if respond_to?(:masters_requests_path) %>
                <%= link_to "전문가체험", masters_requests_path, class: (controller_path.start_with?('masters') ? nav_link_active : nav_link) %>
              <% end %>
              <%= link_to "커뮤니티", community_path, class: (controller_name == 'posts' ? nav_link_active : nav_link) %>
            <% end %>
          </div>
        <% end %>

        <!-- 우측 액션 -->
        <div class="flex items-center gap-1">
          <!-- 검색 버튼 -->
          <%= link_to search_path, class: "p-2 text-gray-500 hover:text-primary-600 hover:bg-gray-50 rounded-lg transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          <% end %>

          <% if user_signed_in? %>
            <!-- AI 비서 챗봇 버튼 -->
            <button type="button" id="ai-chatbot-btn"
                    onclick="toggleAiChatbot()"
                    title="AI 비서에게 물어보기"
                    class="p-2 text-gray-400 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
              </svg>
            </button>

            <div id="tnav-notifications">
              <%= render "shared/notifications_dropdown" %>
            </div>

            <!-- 유저 드롭다운 (데스크톱만 표시) -->
            <div class="relative hidden md:block" id="tnav-user-menu">
              <button type="button"
                      onclick="toggleUserDropdown(event)"
                      class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">
                <span class="max-w-[80px] truncate"><%= current_user.name %></span>
                <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>

              <div id="user-nav-dropdown"
                   class="hidden w-44 bg-white rounded-xl shadow-xl border border-gray-100 py-1" style="position:fixed;top:60px;right:16px;z-index:9999">
                <% profile_path = current_user.customer? ? customers_profile_path : (current_user.master? ? masters_profile_path : admin_root_path) %>
                <%= link_to profile_path, class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                  내 정보
                <% end %>
                <%= link_to edit_user_registration_path, class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors" do %>
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                  </svg>
                  비밀번호 변경
                <% end %>
                <% if current_user.admin? %>
                  <div class="border-t border-gray-100 my-1"></div>
                  <%= link_to admin_root_path, class: "flex items-center gap-2.5 px-4 py-2.5 text-sm text-purple-600 hover:bg-purple-50 transition-colors font-medium" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    관리자 페이지
                  <% end %>
                <% end %>
                <div class="border-t border-gray-100 my-1"></div>
                <%= button_to destroy_user_session_path, method: :delete,
                      class: "w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                  </svg>
                  로그아웃
                <% end %>
              </div>
            </div>

          <% else %>
            <%= link_to "로그인", new_user_session_path,
                  class: "hidden sm:inline-flex px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors" %>
            <%= link_to "시작하기", new_user_registration_path,
                  class: "hidden sm:inline-flex px-4 py-1.5 rounded-lg text-sm font-semibold bg-primary-500 text-white hover:bg-primary-600 transition-colors shadow-sm" %>
          <% end %>

          <!-- 햄버거 버튼: 고객/전문가/관리자/비로그인 모두 (모바일 전용) -->
          <button type="button"
                  id="hamburger-btn"
                  class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors relative"
                  onclick="toggleMobileMenu(event)"
                  aria-expanded="false"
                  aria-label="메뉴 열기">
            <svg id="hamburger-icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="hamburger-icon-close" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
            <% if unread_chat_count > 0 %>
              <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
            <% end %>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ═══ 모바일 전체 메뉴 패널 (역할별 분기) ═══ -->
  <div id="mobile-nav-panel" class="md:hidden hidden fixed top-14 left-0 right-0 bottom-0 bg-white z-[200] overflow-y-auto">
      <% if user_signed_in? %>
        <div class="px-3 py-3 pb-8">
          <% if current_user.customer? %>
            <%# 하단 탭에 없는 보조 메뉴만 표시 (홈/커뮤니티/채팅/마이는 하단 탭에 있음) %>
            <%= link_to customers_requests_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl transition-colors #{controller_path == 'customers/requests' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-droplet w-5 text-center"></i>
              <span class="font-medium">내 체크 목록</span>
            <% end %>
            <%= link_to customers_masters_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl transition-colors #{controller_path == 'customers/masters' ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-user-tie w-5 text-center"></i>
              <span class="font-medium">전문가 찾기</span>
            <% end %>
            <div class="border-t border-gray-100 my-2"></div>
            <%= link_to customers_insurance_claims_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-file-shield w-5 text-center"></i>
              <span class="font-medium">보험청구</span>
            <% end %>
            <%= link_to customers_payments_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-credit-card w-5 text-center"></i>
              <span class="font-medium">결제 내역</span>
            <% end %>
            <div class="border-t border-gray-100 my-2"></div>
            <%= link_to faq_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-circle-question w-5 text-center"></i>
              <span class="font-medium">FAQ</span>
            <% end %>

          <% elsif current_user.master? %>
            <%# 하단 탭에 없는 보조 메뉴만 (홈/오더피드/채팅/마이는 하단 탭에 있음) %>
            <%= link_to masters_requests_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl transition-colors #{(controller_path == 'masters/requests' && action_name != 'open_orders') ? 'bg-primary-50 text-primary-600' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <i class="fa-solid fa-clipboard-list w-5 text-center"></i>
              <span class="font-medium">내 작업 목록</span>
            <% end %>
            <div class="border-t border-gray-100 my-2"></div>
            <%= link_to expert_settlements_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-money-bill-wave w-5 text-center"></i>
              <span class="font-medium">정산 내역</span>
            <% end %>
            <%= link_to masters_insurance_claims_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-file-shield w-5 text-center"></i>
              <span class="font-medium">보험청구</span>
            <% end %>
            <%= link_to masters_billing_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-credit-card w-5 text-center"></i>
              <span class="font-medium">결제 관리</span>
              <% if current_user.master? && current_user.subscription&.zone? %>
                <span class="ml-auto text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">마스터</span>
              <% end %>
            <% end %>

          <% elsif current_user.admin? %>
            <%# 하단 탭에 없는 보조 메뉴만 (대시보드/체크/마스터/커뮤니티/마이는 하단 탭에 있음) %>
            <%= link_to admin_expert_inquiries_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl hover:bg-amber-50 transition-colors #{controller_path == 'admin/expert_inquiries' ? 'bg-amber-50 text-amber-700' : 'text-gray-700'}" do %>
              <i class="fa-solid fa-user-plus w-5 text-center"></i>
              <span class="font-medium">전문가 등록 문의</span>
              <% pending = ExpertInquiry.pending.count %>
              <% if pending > 0 %>
                <span class="ml-auto bg-amber-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= pending %></span>
              <% end %>
            <% end %>
            <%= link_to admin_feedbacks_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-comments w-5 text-center"></i>
              <span class="font-medium">피드백</span>
            <% end %>
            <%= link_to admin_surveys_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-chart-bar w-5 text-center"></i>
              <span class="font-medium">설문</span>
            <% end %>
            <div class="border-t border-gray-100 my-2"></div>
            <%= link_to admin_disputes_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-gavel w-5 text-center"></i>
              <span class="font-medium">분쟁 관리</span>
            <% end %>
            <%= link_to admin_service_zones_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-map-location-dot w-5 text-center"></i>
              <span class="font-medium">구역 관리</span>
            <% end %>
            <div class="border-t border-gray-100 my-2"></div>
            <%= link_to admin_insurance_claims_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-file-shield w-5 text-center"></i>
              <span class="font-medium">보험청구</span>
            <% end %>
            <%= link_to admin_payment_audit_logs_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-credit-card w-5 text-center"></i>
              <span class="font-medium">결제 로그</span>
            <% end %>
            <%= link_to admin_escrow_transactions_path, class: "flex items-center gap-3 px-3 py-3.5 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-lock w-5 text-center"></i>
              <span class="font-medium">결제</span>
            <% end %>
          <% end %>

          <!-- 로그아웃 -->
          <div class="border-t border-gray-100 mt-3 pt-2">
            <%= button_to destroy_user_session_path, method: :delete,
                  class: "w-full flex items-center gap-3 px-3 py-3 text-red-500 hover:bg-red-50 rounded-xl transition-colors text-left" do %>
              <i class="fa-solid fa-right-from-bracket w-5 text-center text-base"></i>
              <span class="font-medium">로그아웃</span>
            <% end %>
          </div>
        </div>

      <% else %>
        <!-- 비로그인 메뉴 -->
        <div class="px-3 py-4">
          <% unless controller_name == 'pages' && action_name == 'coming_soon' %>
            <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
              <i class="fa-solid fa-magnifying-glass w-5 text-center text-base text-primary-500"></i>
              <span class="font-medium">AI 사전점검</span>
            <% end %>
          <% end %>
          <%= link_to about_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <i class="fa-solid fa-circle-info w-5 text-center text-base text-primary-500"></i>
            <span class="font-medium">서비스 소개</span>
          <% end %>
          <%= link_to pricing_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <i class="fa-solid fa-tag w-5 text-center text-base text-primary-500"></i>
            <span class="font-medium">가격 안내</span>
          <% end %>
          <%= link_to faq_path, class: "flex items-center gap-3 px-3 py-3 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <i class="fa-solid fa-circle-question w-5 text-center text-base text-primary-500"></i>
            <span class="font-medium">FAQ</span>
          <% end %>

          <div class="border-t border-gray-100 mt-3 pt-3 px-3 grid grid-cols-2 gap-2">
            <%= link_to "로그인", new_user_session_path,
                  class: "text-center py-3 rounded-xl text-sm font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors" %>
            <%= link_to "시작하기", new_user_registration_path,
                  class: "text-center py-3 rounded-xl text-sm font-semibold text-white bg-primary-500 hover:bg-primary-600 transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <!-- Flash messages -->
  <%= render "shared/flash_messages" %>

  <!-- Main content -->
  <% if content_for?(:full_screen_layout) %>
    <main class="flex-grow flex flex-col overflow-hidden min-h-0">
      <%= yield %>
    </main>
  <% else %>
    <main class="flex-grow<%= hotwire_native_app? ? ' px-4 py-4' : ' max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8' %> w-full">
      <%= yield %>
    </main>
  <% end %>


  <!-- 고객/전문가용 하단 탭 네비게이션 (모바일) -->
  <% if user_signed_in? %>
    <% unless hotwire_native_app? %>
      <% if current_user.customer? %>
        <!-- 고객용 하단 탭 (5탭: 홈/커뮤니티/누수체크/채팅/마이페이지) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-5 h-16">

            <!-- 홈 -->
            <%= link_to customers_dashboard_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_path == 'customers/dashboard' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= controller_path == 'customers/dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
