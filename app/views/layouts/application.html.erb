  <script>
    // ── 햄버거 메뉴 ──
    function toggleMobileMenu(event) {
      event.stopPropagation();
      var panel = document.getElementById('mobile-nav-panel');
      var iconOpen = document.getElementById('hamburger-icon-open');
      var iconClose = document.getElementById('hamburger-icon-close');
      if (!panel) return;
      var isOpen = !panel.classList.contains('hidden');
      if (isOpen) {
        panel.classList.add('hidden');
        if (iconOpen) iconOpen.classList.remove('hidden');
        if (iconClose) iconClose.classList.add('hidden');
        document.body.style.overflow = '';
      } else {
        panel.classList.remove('hidden');
        if (iconOpen) iconOpen.classList.add('hidden');
        if (iconClose) iconClose.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }

    // ── 드롭다운 포지셔닝 ──
    function positionDropdown(trigger, dropdown) {
      var rect = trigger.getBoundingClientRect();
      dropdown.style.position = 'fixed';
      dropdown.style.top = (rect.bottom + 4) + 'px';
      dropdown.style.right = (window.innerWidth - rect.right) + 'px';
      dropdown.style.left = 'auto';
      dropdown.style.zIndex = '9999';
    }

    // ── 유저 드롭다운 ──
    function toggleUserDropdown(event) {
      event.stopPropagation();
      var dd = document.getElementById('user-nav-dropdown');
      var notifDd = document.getElementById('notifications-dropdown');
      if (!dd) return;
      if (notifDd) notifDd.classList.add('hidden');
      if (dd.classList.contains('hidden')) {
        positionDropdown(event.currentTarget, dd);
        dd.classList.remove('hidden');
      } else {
        dd.classList.add('hidden');
      }
    }

    // ── 알림 드롭다운 ──
    function toggleNotifications(event) {
      event.stopPropagation();
      var dd = document.getElementById('notifications-dropdown');
      var userDd = document.getElementById('user-nav-dropdown');
      if (!dd) return;
      if (userDd) userDd.classList.add('hidden');
      if (dd.classList.contains('hidden')) {
        positionDropdown(event.currentTarget, dd);
        dd.classList.remove('hidden');
      } else {
        dd.classList.add('hidden');
      }
    }

    // ── 외부 클릭 시 드롭다운 닫기 ──
    document.addEventListener('click', function() {
      var userDd = document.getElementById('user-nav-dropdown');
      var notifDd = document.getElementById('notifications-dropdown');
      if (userDd) userDd.classList.add('hidden');
      if (notifDd) notifDd.classList.add('hidden');
    });

    // ── 사업자정보 푸터 토글 ──
    function toggleFooterInfo(btn) {
      var content = btn.nextElementSibling;
      var chevron = btn.querySelector('svg');
      var isHidden = content.classList.contains('hidden');
      content.classList.toggle('hidden', !isHidden);
      if (chevron) chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
    }

    // ── Turbo 페이지 이동 시 모바일 메뉴 닫기 ──
    document.addEventListener('turbo:before-visit', function() {
      var panel = document.getElementById('mobile-nav-panel');
      var iconOpen = document.getElementById('hamburger-icon-open');
      var iconClose = document.getElementById('hamburger-icon-close');
      if (panel) panel.classList.add('hidden');
      if (iconOpen) iconOpen.classList.remove('hidden');
      if (iconClose) iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    });
  </script>
