<!DOCTYPE html>
<html lang="ko">
<head>
  <title>누수체크 - 누수 전문 매칭 플랫폼</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta charset="utf-8">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col font-sans<%= ' native-app' if hotwire_native_app? %>">
  <!-- Loading Progress Bar -->
  <div data-controller="loading">
    <div data-loading-target="bar" class="loading-bar hidden"></div>
  </div>

  <!-- Navigation (네이티브 앱에서는 숨김 - 앱 자체 네비게이션 사용) -->
  <% unless hotwire_native_app? %>
  <nav class="bg-blue-700 text-white shadow-lg" aria-label="주 메뉴" data-controller="mobile-menu">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <%= link_to root_path, class: "flex items-center space-x-2" do %>
            <span class="text-2xl font-bold">누수체크</span>
          <% end %>

          <% if user_signed_in? %>
            <div class="hidden md:flex ml-4 space-x-1">
              <% if current_user.customer? %>
                <%= link_to "홈", customers_dashboard_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
                <%= link_to "내 요청", customers_requests_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
              <% elsif current_user.master? %>
                <%= link_to "홈", expert_dashboard_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
                <%= link_to "공개 오더", open_orders_masters_requests_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
              <% elsif current_user.admin? %>
                <%= link_to "대시보드", admin_root_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
                <%= link_to "체크관리", admin_requests_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
                <%= link_to "마스터관리", admin_masters_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
              <% end %>
            </div>
          <% else %>
            <%= link_to "누수 체크하기", new_customers_request_path, class: "hidden sm:inline-flex ml-6 px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
          <% end %>
        </div>

        <div class="flex items-center space-x-3">
          <% if user_signed_in? %>
            <%= render "shared/notifications_dropdown" %>
            <span class="hidden sm:inline text-sm"><%= current_user.name %> (<%= current_user.display_role %>)</span>
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "hidden md:inline-flex px-3 py-2 rounded-md text-sm font-medium bg-blue-800 hover:bg-blue-900" %>
          <% else %>
            <%= link_to "로그인", new_user_session_path, class: "hidden sm:inline-flex px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-600" %>
            <%= link_to "회원가입", new_user_registration_path, class: "hidden sm:inline-flex px-3 py-2 rounded-md text-sm font-medium bg-white text-blue-700 hover:bg-gray-100" %>
          <% end %>

          <button type="button"
                  class="md:hidden inline-flex items-center justify-center p-2 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-white"
                  data-action="mobile-menu#toggle"
                  data-mobile-menu-target="button"
                  aria-expanded="false"
                  aria-label="메뉴 열기">
            <svg class="h-6 w-6" data-mobile-menu-target="iconOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg class="h-6 w-6 hidden" data-mobile-menu-target="iconClose" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="md:hidden hidden" data-mobile-menu-target="panel">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-blue-600 mobile-menu-enter">
        <% unless controller_name == 'pages' && action_name == 'coming_soon' %>
          <%= link_to "누수 진단하기", new_leak_inspection_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
        <% end %>
        <% if user_signed_in? %>
          <div class="border-t border-blue-600 my-2 pt-2">
            <p class="px-3 py-1 text-blue-200 text-sm"><%= current_user.name %> (<%= current_user.display_role %>)</p>
          </div>
          <% if current_user.customer? %>
            <%= link_to "내 체크", customers_requests_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "보험 신청", customers_insurance_claims_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
          <% elsif current_user.master? %>
            <%= link_to "배정된 체크", masters_requests_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "내 프로필", masters_profile_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
          <% elsif current_user.admin? %>
            <%= link_to "대시보드", admin_root_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "체크관리", admin_requests_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "마스터관리", admin_masters_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "에스크로", admin_escrow_transactions_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "보험관리", admin_insurance_claims_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "의견관리", admin_feedbacks_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "설문조사", admin_surveys_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
          <% end %>
          <div class="border-t border-blue-600 my-2 pt-2">
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "w-full text-left px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
          </div>
        <% else %>
          <div class="border-t border-blue-600 my-2 pt-2">
            <%= link_to "로그인", new_user_session_path, class: "block px-3 py-2 rounded-md text-base font-medium hover:bg-blue-600" %>
            <%= link_to "회원가입", new_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium bg-white text-blue-700 hover:bg-gray-100 text-center mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </nav>
  <% end %>

  <!-- Flash messages -->
  <%= render "shared/flash_messages" %>

  <!-- Main content -->
  <main class="flex-grow<%= hotwire_native_app? ? ' px-4 py-4' : ' max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8' %> w-full">
    <%= yield %>
  </main>

  <!-- 플로팅 액션 버튼 (FAB) - 당근마켓 스타일 -->
  <% unless hotwire_native_app? %>
    <% if !user_signed_in? || (user_signed_in? && current_user.customer?) %>
      <%= link_to new_customers_request_path, class: "fixed bottom-6 right-6 z-50 w-16 h-16 bg-gradient-to-br from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-full shadow-2xl hover:shadow-3xl transition-all duration-300 flex items-center justify-center group hover:scale-110", data: { turbo: false } do %>
        <svg class="w-8 h-8 group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/>
        </svg>
        <span class="sr-only">누수 체크하기</span>
      <% end %>
    <% end %>
  <% end %>

  <!-- 고객/전문가용 하단 탭 네비게이션 (모바일) -->
  <% if user_signed_in? %>
    <% unless hotwire_native_app? %>
      <% if current_user.customer? %>
        <!-- 고객용 하단 탭 -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-4 h-16">
            <%
              customer_tabs = [
                { path: customers_dashboard_path, icon: 'home', label: '홈', active: controller_path == 'customers/dashboard' },
                { path: new_customers_request_path, icon: 'plus', label: '체크', active: controller_path == 'customers/requests' && action_name == 'new' },
                { path: customers_requests_path, icon: 'list', label: '내요청', active: controller_path == 'customers/requests' && action_name == 'index' },
                { path: customers_insurance_claims_path, icon: 'document', label: '보험', active: controller_path == 'customers/insurance_claims' }
              ]
            %>

            <% customer_tabs.each do |tab| %>
              <%= link_to tab[:path], class: "flex flex-col items-center justify-center gap-1 transition-colors #{tab[:active] ? 'text-blue-600' : 'text-gray-500'}" do %>
                <% if tab[:icon] == 'home' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                  </svg>
                <% elsif tab[:icon] == 'plus' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2.5' %>" d="M12 4v16m8-8H4"/>
                  </svg>
                <% elsif tab[:icon] == 'list' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                <% elsif tab[:icon] == 'document' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                <% end %>
                <span class="text-xs font-medium"><%= tab[:label] %></span>
              <% end %>
            <% end %>
          </div>
        </nav>
      <% elsif current_user.master? %>
        <!-- 전문가용 하단 탭 -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-4 h-16">
            <%
              master_tabs = [
                { path: expert_dashboard_path, icon: 'home', label: '홈', active: controller_name == 'dashboard' && action_name == 'index' },
                { path: open_orders_masters_requests_path, icon: 'clipboard', label: '공개오더', active: controller_name == 'requests' && action_name == 'open_orders' },
                { path: masters_requests_path, icon: 'folder', label: '내오더', active: controller_name == 'requests' && action_name == 'index' },
                { path: masters_profile_path, icon: 'user', label: '프로필', active: controller_name == 'profiles' }
              ]
            %>

            <% master_tabs.each do |tab| %>
              <%= link_to tab[:path], class: "flex flex-col items-center justify-center gap-1 transition-colors #{tab[:active] ? 'text-blue-600' : 'text-gray-500'}" do %>
                <% if tab[:icon] == 'home' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                  </svg>
                <% elsif tab[:icon] == 'clipboard' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                <% elsif tab[:icon] == 'folder' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                <% elsif tab[:icon] == 'user' %>
                  <svg class="w-6 h-6" fill="<%= tab[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= tab[:active] ? '0' : '2' %>" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                <% end %>
                <span class="text-xs font-medium"><%= tab[:label] %></span>
              <% end %>
            <% end %>
          </div>
        </nav>
      <% end %>

      <!-- 하단 탭 높이만큼 여백 추가 (모바일) -->
      <div class="md:hidden h-16"></div>
    <% end %>
  <% end %>

  <!-- Footer (네이티브 앱에서는 숨김) -->
  <% unless hotwire_native_app? %>
  <footer class="bg-gray-800 text-gray-300 py-8 mt-auto">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-6">
        <!-- 회사 정보 -->
        <div>
          <h3 class="text-white font-bold text-lg mb-3">누수체크</h3>
          <p class="text-sm text-gray-400">누수 전문 매칭 플랫폼</p>
          <p class="text-sm text-gray-400">투명한 가격, 검증된 전문가</p>
        </div>

        <!-- 서비스 -->
        <div>
          <h3 class="text-white font-semibold text-sm mb-3">서비스</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "누수 진단하기", new_leak_inspection_path, class: "text-gray-400 hover:text-white transition" %></li>
            <li><%= link_to "서비스 소개", about_path, class: "text-gray-400 hover:text-white transition" %></li>
            <li><%= link_to "가격안내", pricing_path, class: "text-gray-400 hover:text-white transition" %></li>
          </ul>
        </div>

        <!-- 고객지원 -->
        <div>
          <h3 class="text-white font-semibold text-sm mb-3">고객지원</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "의견 보내기", new_feedback_path, class: "text-gray-400 hover:text-white transition" %></li>
            <li><%= link_to "설문 참여하기", new_survey_path, class: "text-gray-400 hover:text-white transition" %></li>
            <li><a href="mailto:contact@nusucheck.com" class="text-gray-400 hover:text-white transition">contact@nusucheck.com</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-gray-700 pt-6 text-center">
        <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> 누수체크. All rights reserved.</p>
      </div>
    </div>
  </footer>
  <% end %>
</body>
</html>
