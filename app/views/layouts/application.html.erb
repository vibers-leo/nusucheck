                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
              </div>
              <span class="text-[10px] font-medium text-primary-600 mt-0.5">진단/접수</span>
            <% end %>

            <!-- 내체크 -->
            <% my_check_active = controller_path == 'customers/requests' %>
            <%= link_to customers_requests_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{my_check_active ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= my_check_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
              </svg>
              <span class="text-[10px] font-medium">내체크</span>
            <% end %>

            <!-- 마이페이지 -->
            <%= link_to customers_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_path == 'customers/profiles' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= controller_path == 'customers/profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% elsif current_user.master? %>
        <!-- 전문가용 하단 탭 (5탭: 홈/오더피드/채팅/커뮤니티/마이) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-5 h-16">

            <!-- 홈 -->
            <%= link_to expert_dashboard_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'dashboard' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-6 h-6" fill="<%= controller_name == 'dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span class="text-[10px] font-medium">홈</span>
            <% end %>

            <!-- 오더 피드 -->
            <%= link_to open_orders_masters_requests_path, class: "flex flex-col items-center justify-center gap-0.5 relative transition-colors #{action_name == 'open_orders' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= action_name == 'open_orders' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                <% open_count = Request.open_orders.count rescue 0 %>
                <% if open_count > 0 %>
                  <span class="absolute -top-1 -right-1 w-4 h-4 bg-primary-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center"><%= open_count > 9 ? "9+" : open_count %></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">오더</span>
            <% end %>

            <!-- 채팅 -->
            <%= link_to chats_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'chats' || controller_name == 'messages' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-6 h-6" fill="<%= (controller_name == 'chats' || controller_name == 'messages') ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <% if unread_chat_count > 0 %>
                  <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[9px] font-bold rounded-full flex items-center justify-center"><%= unread_chat_count > 9 ? "9+" : unread_chat_count %></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">채팅</span>
            <% end %>

            <!-- 커뮤니티 -->
            <% master_community_active = controller_name == 'posts' %>
            <%= link_to community_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{master_community_active ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= master_community_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-[10px] font-medium">커뮤니티</span>
            <% end %>

            <!-- 마이 -->
            <%= link_to masters_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'profiles' ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% elsif current_user.admin? %>
        <!-- 관리자용 하단 탭 (5탭: 관리자/고객체험/채팅/체크하기/마이) -->
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 pb-safe">
          <div class="grid grid-cols-5 h-16">

            <% admin_active = controller_path.start_with?('admin') %>
            <%= link_to admin_root_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{admin_active ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= admin_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-[10px] font-medium">관리자</span>
            <% end %>

            <% customer_active = controller_path.start_with?('customers') %>
            <%= link_to customers_dashboard_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{customer_active ? 'text-primary-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= customer_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span class="text-[10px] font-medium">고객</span>
            <% end %>

            <% chat_active = controller_name == 'chats' || controller_name == 'messages' %>
            <%= link_to chats_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{chat_active ? 'text-primary-600' : 'text-gray-400'}" do %>
              <div class="relative">
                <svg class="w-5 h-5" fill="<%= chat_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <% if unread_chat_count > 0 %>
                  <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-red-500 rounded-full border-2 border-white"></span>
                <% end %>
              </div>
              <span class="text-[10px] font-medium">채팅</span>
            <% end %>

            <%= link_to new_customers_request_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors text-gray-400", data: { turbo: false } do %>
              <div class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center -mt-3 shadow-lg">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
              </div>
              <span class="text-[10px] font-medium -mt-0.5">체크</span>
            <% end %>

            <%= link_to admin_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'profiles' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-[10px] font-medium">마이</span>
            <% end %>

          </div>
        </nav>
      <% end %>

      <!-- 하단 탭 높이만큼 여백 추가 (모바일) -->
      <div class="md:hidden h-20"></div>
    <% end %>
  <% end %>

  <!-- AI 챗봇 패널 (제로클로) -->
  <div id="ai-chatbot-panel" class="hidden fixed bg-white rounded-2xl shadow-2xl border border-gray-200 z-50 flex flex-col" style="width: 420px; height: 520px; bottom: 80px; right: 16px; min-width: 320px; min-height: 360px; max-width: 90vw; max-height: 85vh;">
    <!-- 리사이즈 핸들 (좌상단) -->
    <div id="ai-resize-handle" class="absolute -top-1 -left-1 w-5 h-5 cursor-nw-resize z-10 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity">
      <svg class="w-3 h-3 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M3 21V3h2v16h16v2H3z"/></svg>
    </div>
    <div class="bg-primary-600 px-4 py-3 flex items-center justify-between rounded-t-2xl flex-shrink-0 cursor-move" id="ai-chatbot-header">
      <div class="flex items-center gap-2">
        <img src="/images/characters/ai-robot.png" alt="" class="w-7 h-7 object-contain">
        <span class="text-white font-semibold text-sm">AI 비서</span>
      </div>
      <div class="flex items-center gap-1">
        <!-- 크기 토글 -->
        <button onclick="toggleAiSize()" class="text-white/50 hover:text-white p-1" title="크기 변경">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
