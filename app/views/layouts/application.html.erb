    {
      popover: {
        title: "이제 시작해볼까요?",
        description: "오더 피드에서 첫 번째 견적을 보내보세요! 모르는 게 있으면 <strong>?</strong> 버튼을 눌러 다시 볼 수 있어요.",
        side: "bottom", align: "center"
      }
    }
  ];

  // ── Driver.js 초기화 ───────────────────────────
  function buildDriver(steps) {
    if (typeof window.driver === 'undefined' || typeof window.driver.js === 'undefined') return null;
    var driverJs = window.driver.js.driver;

    // 존재하지 않는 element 스텝 필터링 (페이지 이동 전 실행 대비)
    var filtered = steps.filter(function(s) {
      if (!s.element) return true;
      return document.querySelector(s.element) !== null;
    });

    return driverJs({
      showProgress: true,
      progressText: "{{current}} / {{total}}",
      nextBtnText: "다음 →",
      prevBtnText: "← 이전",
      doneBtnText: "완료 ✓",
      smoothScroll: true,
      animate: true,
      overlayOpacity: 0.6,
      popoverClass: "nusu-tour-popover",
      onDestroyStarted: function() {
        localStorage.setItem(STORE_KEY, "1");
        if (window._nusuDriverInstance) window._nusuDriverInstance.destroy();
      },
      steps: filtered
    });
  }

  // ── 전역 API ──────────────────────────────────
  window.nusuTutorial = {
    start: function() {
      var steps = ROLE === "master" ? MASTER_STEPS : CUSTOMER_STEPS;
      var d = buildDriver(steps);
      if (!d) { return; }
      window._nusuDriverInstance = d;
      d.drive();
    },
    reset: function() {
      localStorage.removeItem(STORE_KEY);
      window.nusuTutorial.start();
    }
  };

  // ── 첫 방문자 자동 시작 ───────────────────────
  function autoStart() {
    if (localStorage.getItem(STORE_KEY)) return;
    // Driver.js 로드 완료 대기 (CDN 비동기)
    var attempts = 0;
    var timer = setInterval(function() {
      attempts++;
      if (attempts > 20) { clearInterval(timer); return; }
      if (typeof window.driver !== 'undefined' && typeof window.driver.js !== 'undefined') {
        clearInterval(timer);
        setTimeout(function() { window.nusuTutorial.start(); }, 800);
      }
    }, 200);
  }

  document.addEventListener("turbo:load", autoStart);
  if (document.readyState !== "loading") autoStart();
  else document.addEventListener("DOMContentLoaded", autoStart);
})();
</script>

<style>
/* Driver.js 커스텀 스타일 */
.nusu-tour-popover .driver-popover-title {
  font-size: 15px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 6px;
}
.nusu-tour-popover .driver-popover-description {
  font-size: 13px;
  line-height: 1.6;
  color: #4b5563;
}
.nusu-tour-popover .driver-popover-footer button {
  font-size: 13px;
  font-weight: 600;
  border-radius: 8px;
  padding: 6px 14px;
}
.nusu-tour-popover .driver-popover-next-btn {
  background: #2563eb;
  color: #fff;
  border: none;
}
.nusu-tour-popover .driver-popover-next-btn:hover {
  background: #1d4ed8;
}
.nusu-tour-popover .driver-popover-prev-btn {
  background: #f3f4f6;
  color: #374151;
  border: 1px solid #e5e7eb;
}
.nusu-tour-popover .driver-popover-progress-text {
  font-size: 11px;
  color: #9ca3af;
}
.nusu-tour-popover {
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.18);
  min-width: 280px;
  max-width: 340px;
}
</style>
<% end %>

</body>
</html>
