            <%= link_to admin_profile_path, class: "flex flex-col items-center justify-center gap-0.5 transition-colors #{controller_name == 'profiles' ? 'text-violet-600' : 'text-gray-400'}" do %>
              <svg class="w-5 h-5" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
