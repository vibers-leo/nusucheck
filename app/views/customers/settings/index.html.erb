<!-- 설정 페이지 (당근마켓 스타일) -->

<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <!-- 헤더 -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">
        ⚙️ 설정
      </h1>
      <p class="text-gray-600">
        계정 및 앱 설정을 관리하세요
      </p>
    </div>

    <!-- 프로필 섹션 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
      <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
        </svg>
        <span>계정 정보</span>
      </h2>

      <div class="space-y-4">
        <!-- 프로필 보기 -->
        <%= link_to customers_profile_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">내 프로필</p>
            <p class="text-sm text-gray-500">이름, 이메일, 전화번호 관리</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <!-- 프로필 편집 -->
        <%= link_to edit_customers_profile_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">프로필 편집</p>
            <p class="text-sm text-gray-500">개인정보 수정</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <!-- 비밀번호 변경 -->
        <%= link_to edit_user_registration_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">비밀번호 변경</p>
            <p class="text-sm text-gray-500">보안을 위해 주기적으로 변경하세요</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- 알림 설정 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
      <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
        </svg>
        <span>알림 설정</span>
      </h2>

      <%= link_to customers_settings_notifications_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
        <div>
          <p class="font-semibold text-gray-900">알림 설정</p>
          <p class="text-sm text-gray-500">이메일, 푸시, SMS 알림 관리</p>
        </div>
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <!-- 결제 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
      <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        <span>결제 관리</span>
      </h2>

      <%= link_to customers_payments_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
        <div>
          <p class="font-semibold text-gray-900">결제 내역</p>
          <p class="text-sm text-gray-500">모든 결제 내역 확인</p>
        </div>
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <!-- 기타 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
      <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
        </svg>
        <span>기타</span>
      </h2>

      <div class="space-y-4">
        <!-- FAQ -->
        <%= link_to faq_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">자주 묻는 질문</p>
            <p class="text-sm text-gray-500">궁금한 점을 찾아보세요</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <!-- 고객센터 -->
        <%= link_to new_feedback_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">고객센터</p>
            <p class="text-sm text-gray-500">1:1 문의하기</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <!-- 이용약관 -->
        <%= link_to terms_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">서비스 이용약관</p>
            <p class="text-sm text-gray-500">누수체크 이용약관</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <!-- 개인정보처리방침 -->
        <%= link_to privacy_path, class: "flex items-center justify-between py-3 hover:bg-gray-50 rounded-xl px-3 -mx-3 transition-colors" do %>
          <div>
            <p class="font-semibold text-gray-900">개인정보처리방침</p>
            <p class="text-sm text-gray-500">개인정보 수집 및 이용 안내</p>
          </div>
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- 계정 탈퇴 -->
    <div class="bg-white rounded-2xl border border-red-200 p-6">
      <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-red-600">계정 관리</span>
      </h2>

      <button type="button"
              data-action="click->confirm#show"
              data-confirm-message-param="정말로 탈퇴하시겠습니까? 모든 데이터가 삭제되며 복구할 수 없습니다."
              class="flex items-center justify-between py-3 hover:bg-red-50 rounded-xl px-3 -mx-3 transition-colors w-full">
        <div class="text-left">
          <p class="font-semibold text-red-600">회원 탈퇴</p>
          <p class="text-sm text-red-400">탈퇴 시 모든 데이터가 삭제됩니다</p>
        </div>
        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- 버전 정보 -->
    <div class="mt-8 text-center">
      <p class="text-sm text-gray-400">
        누수체크 v1.0.0
      </p>
      <p class="text-xs text-gray-400 mt-1">
        © 2026 NusuCheck. All rights reserved.
      </p>
    </div>
  </div>
</div>
