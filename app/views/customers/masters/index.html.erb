<!-- 전문가 목록 페이지 (당근마켓 스타일) -->

<div class="min-h-screen bg-gray-50 <%= user_signed_in? ? 'pb-20 md:pb-8' : '' %>">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- 헤더 -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
        검증된 누수 전문가
      </h1>
      <p class="text-lg text-gray-600">
        <%= @masters.count %>명의 전문가가 활동 중이에요
      </p>
    </div>

    <!-- 필터 (간단한 버전) -->
    <div class="mb-8 flex flex-wrap gap-3">
      <%= link_to "전체", customers_masters_path, class: "px-4 py-2 rounded-full #{params[:area].blank? ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <%= link_to "서울 강남구", customers_masters_path(area: "서울 강남구"), class: "px-4 py-2 rounded-full #{params[:area] == '서울 강남구' ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <%= link_to "서울 서초구", customers_masters_path(area: "서울 서초구"), class: "px-4 py-2 rounded-full #{params[:area] == '서울 서초구' ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <%= link_to "서울 송파구", customers_masters_path(area: "서울 송파구"), class: "px-4 py-2 rounded-full #{params[:area] == '서울 송파구' ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <%= link_to "서울 강동구", customers_masters_path(area: "서울 강동구"), class: "px-4 py-2 rounded-full #{params[:area] == '서울 강동구' ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
    </div>

    <!-- 전문가 카드 그리드 -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @masters.each do |master| %>
        <%= link_to customers_master_path(master), class: "bg-white rounded-2xl p-6 border border-gray-200 hover:shadow-lg hover:-translate-y-1 transition-all" do %>
          <div class="flex items-start gap-4 mb-4">
            <!-- 프로필 이미지 -->
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-purple-500 rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-2xl text-white font-bold">
                <%= master.name[0] %>
              </span>
            </div>

            <div class="flex-1 min-w-0">
              <!-- 이름 + 인증 배지 -->
              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-bold text-lg text-gray-900 truncate">
                  <%= master.name %>
                </h3>
                <% if master.master_profile.verified? %>
                  <svg class="w-5 h-5 text-primary-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                <% end %>
              </div>

              <!-- 평점 + 리뷰 개수 -->
              <div class="flex items-center gap-1 mb-2">
                <% if master.reviews.any? %>
                  <% avg_rating = master.average_rating %>
                  <% 5.times do |i| %>
                    <svg class="w-4 h-4 <%= i < avg_rating.round ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  <% end %>
                  <span class="text-sm font-semibold text-gray-900 ml-1">
                    <%= sprintf("%.1f", avg_rating) %>
                  </span>
                  <span class="text-sm text-gray-500">
                    (<%= master.reviews.count %>)
                  </span>
                <% else %>
                  <span class="text-sm text-gray-400">리뷰 없음</span>
                <% end %>
              </div>

              <!-- 경력 -->
              <p class="text-sm text-gray-600">
                경력 <%= master.master_profile.experience_years %>년
              </p>
            </div>
          </div>

          <!-- 보유 장비 -->
          <div class="mb-4">
            <p class="text-xs font-semibold text-gray-500 mb-2">보유 장비</p>
            <div class="flex flex-wrap gap-2">
              <% master.master_profile.equipment.first(4).each do |equip| %>
                <span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-medium">
                  <%= equip %>
                </span>
              <% end %>
            </div>
          </div>

          <!-- 서비스 지역 -->
          <div class="border-t border-gray-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 mb-2">서비스 지역</p>
            <p class="text-sm text-gray-700">
              <%= master.master_profile.service_areas.first(2).join(', ') %>
              <% if master.master_profile.service_areas.count > 2 %>
                외 <%= master.master_profile.service_areas.count - 2 %>곳
              <% end %>
            </p>
          </div>

          <!-- CTA -->
          <div class="mt-4">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-xl font-semibold text-sm w-full justify-center hover:bg-primary-700 transition-colors">
              <span>상담 요청</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- 전문가 없을 때 -->
    <% if @masters.empty? %>
      <div class="text-center py-20">
        <div class="inline-block p-6 bg-gray-100 rounded-full mb-4">
          <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">
          해당 지역에 전문가가 없습니다
        </h3>
        <p class="text-gray-600 mb-6">
          다른 지역을 선택해보세요
        </p>
        <%= link_to "전체 보기", customers_masters_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold hover:bg-primary-700 transition-colors" %>
      </div>
    <% end %>

    <!-- CTA (하단) -->
    <% unless user_signed_in? %>
      <div class="mt-16 text-center bg-white rounded-3xl p-10 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          지금 바로 전문가에게 상담받으세요
        </h2>
        <p class="text-gray-600 mb-6">
          무료로 가입하고 24시간 내 견적 받아보세요
        </p>
        <%= link_to "무료로 시작하기", new_user_registration_path, class: "inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-2xl font-bold text-lg hover:shadow-lg transition-all" %>
      </div>
    <% end %>
  </div>
</div>
