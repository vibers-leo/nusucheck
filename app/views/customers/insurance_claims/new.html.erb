<div class="min-h-screen bg-white" data-controller="insurance-step" data-insurance-step-total-steps-value="11">

  <!-- 상단 헤더 (sticky) -->
  <div class="sticky top-0 z-10 bg-white">
    <div class="flex items-center justify-between px-5 py-4">
      <button type="button"
              data-insurance-step-target="prevBtn"
              data-action="click->insurance-step#prev"
              class="hidden p-1 -ml-1 text-gray-800 hover:text-gray-600 transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <!-- 첫 단계엔 닫기 버튼 -->
      <%= link_to customers_insurance_claims_path,
            class: "p-1 -ml-1 text-gray-800 hover:text-gray-600 transition",
            id: "close-btn" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>

      <span class="text-sm text-gray-400 absolute left-1/2 -translate-x-1/2">
        <span data-insurance-step-target="progress">1</span> / 11
      </span>

      <span id="autoSaveIndicator" class="text-xs text-gray-400">자동 저장됨</span>
    </div>

    <!-- 프로그레스 바 -->
    <div class="h-0.5 bg-gray-100">
      <div data-insurance-step-target="progressBar"
           class="h-0.5 bg-primary-500 transition-all duration-400 ease-out"
           style="width: 9.09%"></div>
    </div>
  </div>

  <%= form_with(model: [:customers, @insurance_claim],
                html: { multipart: true },
                data: { controller: "button-loading", action: "submit->button-loading#submit" }) do |f| %>

    <%= render "shared/form_errors", resource: @insurance_claim %>

    <% if @insurance_claim.request.present? %>
      <%= f.hidden_field :request_id, value: @insurance_claim.request.id %>
    <% end %>

    <div class="px-5 pt-10 pb-40 max-w-lg mx-auto">

      <!-- ① 일상배상책임보험 가입 여부 확인 -->
      <div data-insurance-step-target="step">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">보험 확인</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">일상배상책임보험이<br>있으신가요?</h1>
        <p class="text-sm text-gray-400 mb-8">운전자보험·상해보험의 특약으로 가입되어 있는 경우가 많아요</p>

        <!-- 선택 버튼 (정보 수집용, 필수 아님) -->
        <div class="space-y-3" id="insurance-yn-group">
          <button type="button"
                  class="insurance-yn-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  onclick="selectInsuranceYn(this, 'yes')">
            <span class="text-2xl">✅</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">있어요</p>
              <p class="text-xs text-gray-400 mt-0.5">일상배상책임 특약이 있어요</p>
            </div>
            <div class="insurance-yn-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>

          <button type="button"
                  class="insurance-yn-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  onclick="selectInsuranceYn(this, 'unknown')">
            <span class="text-2xl">🤔</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">잘 모르겠어요</p>
              <p class="text-xs text-gray-400 mt-0.5">확인 후 진행할게요</p>
            </div>
            <div class="insurance-yn-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>

          <button type="button"
                  class="insurance-yn-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  onclick="selectInsuranceYn(this, 'no')">
            <span class="text-2xl">❌</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">없어요</p>
              <p class="text-xs text-gray-400 mt-0.5">해당 보험이 없어요</p>
            </div>
            <div class="insurance-yn-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>
        </div>

        <p class="text-xs text-gray-400 text-center mt-5">선택하지 않아도 다음으로 넘어갈 수 있어요</p>

        <!-- 확인 방법 안내 -->
        <div class="bg-blue-50 rounded-2xl p-4 mt-6">
          <p class="text-xs font-bold text-blue-700 mb-2.5">📋 이렇게 확인해보세요</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-xs text-blue-700">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0 mt-1.5"></span>
              가입하신 보험사 앱 → 가입 내역 → "일상배상책임" 또는 "배상책임 특약" 검색
            </li>
            <li class="flex items-start gap-2 text-xs text-blue-700">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0 mt-1.5"></span>
              보험사 고객센터에 전화해서 "일상배상책임 특약이 있나요?" 라고 물어보세요
            </li>
            <li class="flex items-start gap-2 text-xs text-blue-700">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0 mt-1.5"></span>
              카카오페이·네이버파이낸셜 등 금융앱에서 내 보험 한눈에 조회 가능해요
            </li>
          </ul>
        </div>
      </div>

      <!-- ② 실거주지 확인 + 보험 적용 안내 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">보험 확인</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">가입하신 주소지와<br>실거주지가 동일한가요?</h1>
        <p class="text-sm text-gray-400 mb-8">실거주지일 때 보험 대상자가 돼요</p>

        <!-- 주소지 선택 버튼 -->
        <div class="space-y-3 mb-8" id="address-match-group">
          <button type="button"
                  class="address-match-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  onclick="selectAddressMatch(this, 'yes')">
            <span class="text-2xl">🏠</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">동일해요</p>
              <p class="text-xs text-gray-400 mt-0.5">보험 주소지 = 실제 살고 있는 곳</p>
            </div>
            <div class="address-match-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>

          <button type="button"
                  class="address-match-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  onclick="selectAddressMatch(this, 'no')">
            <span class="text-2xl">📍</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">달라요</p>
              <p class="text-xs text-gray-400 mt-0.5">보험 주소지가 지금 사는 곳과 달라요</p>
            </div>
            <div class="address-match-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>
        </div>

        <!-- 주소지 불일치 경고 (숨김 처리) -->
        <div id="address-mismatch-warning" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-6">
          <p class="text-sm font-bold text-amber-800 mb-1">⚠️ 보험 적용이 어려울 수 있어요</p>
          <p class="text-xs text-amber-700 leading-relaxed">보험 가입 주소지와 사고 발생 주소지가 다른 경우, 보험사에서 보상을 거절할 수 있어요. 먼저 보험사에 확인해보세요.</p>
        </div>

        <!-- 일상배상책임보험 안내 -->
        <div class="bg-gray-50 rounded-2xl p-4 space-y-3">
          <p class="text-xs font-bold text-gray-700">💡 일상배상책임보험에 대해 알아두세요</p>

          <div class="flex items-start gap-3">
            <span class="text-base flex-shrink-0">🏘️</span>
            <div>
              <p class="text-xs font-semibold text-gray-800">남에게 끼친 손해를 배상하는 게 주 목적이에요</p>
              <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">아랫집 피해(도배·장판 교체 등)처럼 누수로 인해 타인에게 발생한 재산 피해를 보상해요</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-base flex-shrink-0">💰</span>
            <div>
              <p class="text-xs font-semibold text-gray-800">자기부담금이 발생할 수 있어요</p>
              <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">보험사마다 다르지만, 일반적으로 피해액의 10~20% 또는 최소 10만원 이상을 본인이 부담해요</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-base flex-shrink-0">🔧</span>
            <div>
              <p class="text-xs font-semibold text-gray-800">내 집 수리비는 별도예요</p>
              <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">누수 원인 수리비(배관 공사 등)는 일상배상책임보험 대상이 아니에요. 실손의료보험과는 달리 재산 손해만 보상해요</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ③ 성함 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">신청자 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">성함이 어떻게 되세요?</h1>
        <p class="text-sm text-gray-400 mb-10">보험청구 서류에 들어갈 이름이에요</p>

        <%= f.text_field :applicant_name, required: true,
              placeholder: "홍길동",
              autocomplete: "name",
              class: "w-full text-xl border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent" %>
      </div>

      <!-- ④ 연락처 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">신청자 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">연락처를 알려주세요</h1>
        <p class="text-sm text-gray-400 mb-10">보험사에서 연락드릴 번호예요</p>

        <div class="space-y-9">
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-3">휴대폰 번호</label>
            <%= f.text_field :applicant_phone, required: true,
                  placeholder: "010-1234-5678",
                  inputmode: "tel", autocomplete: "tel",
                  class: "w-full text-xl border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent" %>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-3">
              이메일
              <span class="text-gray-300 font-normal ml-1">(선택)</span>
            </label>
            <%= f.email_field :applicant_email,
                  placeholder: "example@email.com",
                  autocomplete: "email",
                  class: "w-full text-xl border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent" %>
            <p class="text-xs text-gray-400 mt-2">진행 상황을 이메일로 알려드려요</p>
          </div>
        </div>
      </div>

      <!-- ⑤ 사고 발생일 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">사고 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">사고가 언제 발생했나요?</h1>
        <p class="text-sm text-gray-400 mb-10">대략적인 날짜도 괜찮아요</p>

        <%= f.date_field :incident_date, required: true,
              max: Date.today,
              class: "w-full text-xl border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 transition-colors bg-transparent" %>
      </div>

      <!-- ⑥ 사고 주소 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">사고 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">어디서 발생했나요?</h1>
        <p class="text-sm text-gray-400 mb-10">사고가 일어난 장소를 알려주세요</p>

        <div class="space-y-9">
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-3">주소</label>
            <%= f.text_field :incident_address, required: true,
                  placeholder: "서울시 강남구 테헤란로 123",
                  class: "w-full text-base border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent" %>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-400 mb-3">
              상세 주소
              <span class="text-gray-300 font-normal ml-1">(선택)</span>
            </label>
            <%= f.text_field :incident_detail_address,
                  placeholder: "101동 1234호",
                  class: "w-full text-base border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent" %>
          </div>
        </div>
      </div>

      <!-- ⑦ 피해 유형 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">사고 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">어떤 피해가 발생했나요?</h1>
        <p class="text-sm text-gray-400 mb-8">해당되는 항목을 선택해주세요</p>

        <%= f.hidden_field :damage_type, id: "damage-type-input" %>

        <div class="space-y-3" id="damage-type-group">
          <button type="button"
                  class="damage-type-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  data-value="property_damage"
                  onclick="selectDamageType(this, 'property_damage')">
            <span class="text-3xl">🏠</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">재산 피해</p>
              <p class="text-xs text-gray-400 mt-0.5">물건, 집기, 건물 등 재산 손해</p>
            </div>
            <div class="damage-type-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>

          <button type="button"
                  class="damage-type-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  data-value="personal_injury"
                  onclick="selectDamageType(this, 'personal_injury')">
            <span class="text-3xl">🤕</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">인적 피해</p>
              <p class="text-xs text-gray-400 mt-0.5">사람이 다치거나 부상을 입은 경우</p>
            </div>
            <div class="damage-type-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>

          <button type="button"
                  class="damage-type-btn w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-100 hover:border-primary-200 bg-white transition-all text-left"
                  data-value="both"
                  onclick="selectDamageType(this, 'both')">
            <span class="text-3xl">🔰</span>
            <div class="flex-1">
              <p class="font-bold text-gray-900 text-sm">재산 + 인적 피해</p>
              <p class="text-xs text-gray-400 mt-0.5">두 가지 모두 해당돼요</p>
            </div>
            <div class="damage-type-check hidden">
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </button>
        </div>
      </div>

      <!-- ⑧ 예상 피해 금액 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">사고 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">예상 피해 금액이 얼마예요?</h1>
        <p class="text-sm text-gray-400 mb-10">대략적인 금액도 괜찮아요</p>

        <div class="relative">
          <%= f.number_field :estimated_damage_amount, min: 0, step: 10000,
                placeholder: "500,000",
                inputmode: "numeric",
                class: "w-full text-2xl font-semibold border-0 border-b-2 border-gray-200 focus:border-primary-500 focus:outline-none py-3 px-0 placeholder-gray-300 transition-colors bg-transparent pr-8" %>
          <span class="absolute right-0 bottom-3.5 text-xl font-medium text-gray-400">원</span>
        </div>
        <p class="text-xs text-gray-400 mt-3">입력하지 않아도 계속 진행할 수 있어요</p>
      </div>

      <!-- ⑨ 사고 내용 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">사고 정보</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">어떤 일이 있었는지<br>알려주세요</h1>
        <p class="text-sm text-gray-400 mb-8">자세할수록 심사가 빨라져요</p>

        <%= f.text_area :incident_description, rows: 6, required: true,
              placeholder: "예: 화장실 배관에서 누수가 발생하여 아래층 천장과 벽지가 훼손되었습니다. 아래층 주민이 천장에 물이 떨어진다고 알려줘 긴급 수리를 진행했습니다.",
              class: "w-full text-base border-2 border-gray-100 rounded-2xl focus:border-primary-400 focus:outline-none p-4 placeholder-gray-300 transition-colors bg-gray-50 resize-none leading-relaxed" %>
      </div>

      <!-- ⑩ 서류 첨부 -->
      <div data-insurance-step-target="step" class="hidden">
        <p class="text-xs font-bold text-primary-500 mb-3 tracking-widest uppercase">서류 첨부</p>
        <h1 class="text-[1.75rem] font-bold text-gray-900 leading-tight mb-2">관련 서류가 있나요?</h1>
        <p class="text-sm text-gray-400 mb-8">나중에 추가해도 돼요, 지금 없어도 괜찮아요</p>

        <div class="bg-gray-50 rounded-2xl p-4 mb-5">
          <p class="text-xs font-bold text-gray-600 mb-3">이런 서류가 도움이 돼요</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2.5 text-xs text-gray-500">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
              누수 현장 사진 (여러 각도면 좋아요)
            </li>
            <li class="flex items-center gap-2.5 text-xs text-gray-500">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
              수리 견적서 또는 영수증
            </li>
            <li class="flex items-center gap-2.5 text-xs text-gray-500">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
              피해 확인서 (이웃 서명)
            </li>
          </ul>
        </div>

        <%= f.file_field :supporting_documents, multiple: true, accept: "image/*,application/pdf",
              class: "hidden", id: "file-upload" %>
        <label for="file-upload"
               class="flex items-center gap-4 p-5 border-2 border-dashed border-gray-200 rounded-2xl cursor-pointer hover:border-primary-300 hover:bg-primary-50 transition-all">
          <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-gray-900 text-sm">파일 선택하기</p>
            <p class="text-xs text-gray-400 mt-0.5">사진, PDF · 최대 10개 · 각 10MB</p>
          </div>
        </label>
        <p id="selected-files" class="text-xs text-primary-600 font-semibold mt-3 hidden"></p>
      </div>

      <!-- ⑪ 확인 및 제출 -->
      <div data-insurance-step-target="step" class="hidden">
        <div class="text-center pt-6 pb-8">
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-gray-900 mb-2">거의 다 됐어요!</h1>
          <p class="text-sm text-gray-400">저장하고 나중에 이어서 작성해도 돼요</p>
        </div>

        <div class="space-y-2.5">
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="text-sm text-gray-700">128bit 암호화로 안전하게 보호돼요</span>
          </div>
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="text-sm text-gray-700">저장 후에도 언제든지 수정할 수 있어요</span>
          </div>
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl">
            <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="text-sm text-gray-700">평균 7~14일 후 보험금이 입금돼요</span>
          </div>
        </div>
      </div>

    </div>

    <!-- 하단 고정 버튼 -->
    <div class="fixed bottom-16 left-0 right-0 bg-white px-5 pt-3 pb-4 md:bottom-0 md:pb-8 z-40" style="box-shadow: 0 -1px 0 rgba(0,0,0,0.06)">
      <div class="max-w-lg mx-auto">
        <!-- 다음 버튼 -->
        <button type="button"
                data-insurance-step-target="nextBtn"
                data-action="click->insurance-step#next"
                class="w-full h-14 rounded-2xl bg-primary-500 text-white font-bold text-base hover:bg-primary-600 active:scale-[0.98] transition-all">
          다음
        </button>

        <!-- 저장하기 버튼 (마지막 단계) -->
        <button type="submit"
                data-insurance-step-target="submitBtn"
                data-button-loading-target="button"
                data-button-loading-loading-text-value="저장하는 중..."
                class="hidden w-full h-14 rounded-2xl bg-primary-500 text-white font-bold text-base hover:bg-primary-600 active:scale-[0.98] transition-all">
          <span data-button-loading-target="spinner" class="btn-spinner hidden"></span>
          <span data-button-loading-target="text">저장하기</span>
        </button>
      </div>
    </div>

  <% end %>
</div>

<script>
  // 보험 가입 여부 선택
  function selectInsuranceYn(button, value) {
    document.querySelectorAll('.insurance-yn-btn').forEach(btn => {
      btn.classList.remove('border-primary-500', 'bg-primary-50')
      btn.classList.add('border-gray-100')
      btn.querySelector('.insurance-yn-check').classList.add('hidden')
    })
    button.classList.remove('border-gray-100')
    button.classList.add('border-primary-500', 'bg-primary-50')
    button.querySelector('.insurance-yn-check').classList.remove('hidden')
  }

  // 실거주지 일치 여부 선택
  function selectAddressMatch(button, value) {
    document.querySelectorAll('.address-match-btn').forEach(btn => {
      btn.classList.remove('border-primary-500', 'bg-primary-50')
      btn.classList.add('border-gray-100')
      btn.querySelector('.address-match-check').classList.add('hidden')
    })
    button.classList.remove('border-gray-100')
    button.classList.add('border-primary-500', 'bg-primary-50')
    button.querySelector('.address-match-check').classList.remove('hidden')

    const warning = document.getElementById('address-mismatch-warning')
    if (value === 'no') {
      warning.classList.remove('hidden')
    } else {
      warning.classList.add('hidden')
    }
  }

  // 피해 유형 선택
  function selectDamageType(button, value) {
    document.querySelectorAll('.damage-type-btn').forEach(btn => {
      btn.classList.remove('border-primary-500', 'bg-primary-50')
      btn.classList.add('border-gray-100')
      btn.querySelector('.damage-type-check').classList.add('hidden')
    })
    button.classList.remove('border-gray-100')
    button.classList.add('border-primary-500', 'bg-primary-50')
    button.querySelector('.damage-type-check').classList.remove('hidden')
    document.getElementById('damage-type-input').value = value
  }

  document.addEventListener('DOMContentLoaded', function() {
    // 기존 값 복원
    const currentDamageType = '<%= @insurance_claim.damage_type %>'
    if (currentDamageType) {
      const button = document.querySelector(`.damage-type-btn[data-value="${currentDamageType}"]`)
      if (button) selectDamageType(button, currentDamageType)
    }

    // 파일 선택 표시
    document.getElementById('file-upload')?.addEventListener('change', function() {
      const el = document.getElementById('selected-files')
      if (el && this.files.length > 0) {
        el.textContent = `${this.files.length}개 파일 선택됨`
        el.classList.remove('hidden')
      }
    })

    // step 1에선 닫기 버튼, step 2+에선 뒤로가기 버튼
    const observer = new MutationObserver(function() {
      const closeBtn = document.getElementById('close-btn')
      const prevBtn = document.querySelector('[data-insurance-step-target="prevBtn"]')
      if (closeBtn && prevBtn) {
        const isFirstStep = prevBtn.classList.contains('hidden')
        closeBtn.classList.toggle('hidden', !isFirstStep)
      }
    })
    const prevBtn = document.querySelector('[data-insurance-step-target="prevBtn"]')
    if (prevBtn) observer.observe(prevBtn, { attributes: true, attributeFilter: ['class'] })
  })
</script>
