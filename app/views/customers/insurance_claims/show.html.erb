<div class="max-w-3xl mx-auto py-8">
  <!-- 상단 -->
  <div class="mb-6">
    <%= link_to customers_insurance_claims_path, class: "text-sm text-primary-600 hover:text-primary-800 flex items-center mb-3" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      목록으로
    <% end %>
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">💼 보험 신청서</h1>
        <span class="text-sm font-mono text-gray-500"><%= @insurance_claim.claim_number %></span>
      </div>
      <span class="px-4 py-2 rounded-full text-sm font-semibold
        <%= case @insurance_claim.status
            when 'draft' then 'bg-gray-100 text-gray-700'
            when 'submitted' then 'bg-primary-100 text-primary-700'
            when 'under_review' then 'bg-yellow-100 text-yellow-700'
            when 'approved' then 'bg-green-100 text-green-700'
            when 'rejected' then 'bg-red-100 text-red-700'
            when 'completed' then 'bg-purple-100 text-purple-700'
            end %>">
        <%= @insurance_claim.status_label %>
      </span>
    </div>
  </div>

  <!-- 전문가 작성 정보 -->
  <% if @insurance_claim.prepared_by_master? %>
    <div class="mb-6 bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-4 border border-purple-100">
      <div class="flex items-center gap-2 text-sm">
        <span class="text-lg">👨‍🔧</span>
        <span class="font-semibold text-gray-900">전문가가 대신 작성한 신청서예요</span>
        <span class="text-gray-600">• 작성자: <%= @insurance_claim.prepared_by_master.name %></span>
      </div>
    </div>
  <% end %>

  <!-- 진행 상태 스텝퍼 -->
  <% steps = [
    { key: %w[draft pending_customer_review], label: "작성중", icon: "✏️" },
    { key: %w[submitted], label: "작성완료", icon: "📄" },
    { key: %w[under_review], label: "제출완료", icon: "📬" },
    { key: %w[approved rejected completed], label: "심사완료", icon: "✅" }
  ]
  current_step = steps.index { |s| s[:key].include?(@insurance_claim.status) } || 0
  %>
  <div class="mb-6 bg-white rounded-2xl border border-gray-100 p-4">
    <div class="flex items-center justify-between relative">
      <div class="absolute top-5 left-0 right-0 h-0.5 bg-gray-100 mx-8"></div>
      <% steps.each_with_index do |step, i| %>
        <% done = i < current_step %>
        <% active = i == current_step %>
        <div class="flex flex-col items-center gap-1.5 relative z-10">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-base font-bold
            <%= done ? 'bg-primary-600 text-white' : active ? 'bg-primary-100 text-primary-700 ring-2 ring-primary-400' : 'bg-gray-100 text-gray-400' %>">
            <%= done ? "✓" : step[:icon] %>
          </div>
          <span class="text-[11px] font-medium <%= active ? 'text-primary-700' : done ? 'text-gray-600' : 'text-gray-400' %>"><%= step[:label] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 상태별 안내 메시지 -->
  <% case @insurance_claim.status %>
  <% when 'pending_customer_review' %>
    <div class="mb-6 bg-gradient-to-r from-yellow-50 to-amber-50 rounded-2xl p-6 border-l-4 border-yellow-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">📋</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">전문가가 작성한 보험청구서를 확인해주세요</h3>
          <p class="text-gray-700 text-sm mb-3">내용을 검토하신 후 <strong>승인</strong>하시면 자동으로 보험사에 제출돼요</p>
          <div class="text-xs text-gray-600 space-y-1">
            <p>✅ 승인하면 즉시 보험사에 접수돼요</p>
            <p>✏️ 수정이 필요하면 전문가에게 요청할 수 있어요</p>
            <p>⚠️ 승인 후에는 수정할 수 없으니 내용을 꼼꼼히 확인해주세요</p>
          </div>
        </div>
      </div>
    </div>
  <% when 'draft' %>
    <div class="mb-6 bg-gradient-to-r from-gray-50 to-slate-50 rounded-2xl p-6 border-l-4 border-gray-400">
      <div class="flex items-start gap-3">
        <span class="text-3xl">✏️</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">작성 중이에요</h3>
          <p class="text-gray-700 text-sm mb-3">내용을 확인하고 제출하시면 보험사에 접수돼요</p>
          <p class="text-xs text-gray-600">💡 임시 저장된 상태예요. 언제든지 수정할 수 있어요</p>
        </div>
      </div>
    </div>
  <% when 'submitted' %>
    <div class="mb-6 bg-gradient-to-r from-primary-50 to-indigo-50 rounded-2xl p-6 border-l-4 border-primary-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">📥</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">신청서가 준비되었어요!</h3>
          <p class="text-gray-700 text-sm mb-4">아래 버튼을 눌러 보험사에 제출해주세요</p>

          <!-- PDF 다운로드 + 보험사 바로가기 버튼 -->
          <div class="flex flex-col sm:flex-row gap-3 mb-4">
            <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
                        class: "inline-flex items-center justify-center px-5 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              📄 신청서 PDF 다운로드
            <% end %>

            <button type="button" onclick="openInsuranceGuide()"
                    class="inline-flex items-center justify-center px-5 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              🏢 보험사 바로가기
            </button>

          </div>

          <div class="text-xs text-gray-600 space-y-1">
            <p>📱 보험사 앱/웹에서 1분 안에 제출 완료!</p>
            <p>💡 제출 후 "보험사 제출 완료" 버튼을 눌러주시면 진행 상황을 추적해드려요</p>
          </div>
        </div>
      </div>
    </div>
  <% when 'under_review' %>
    <div class="mb-6 bg-gradient-to-r from-yellow-50 to-amber-50 rounded-2xl p-6 border-l-4 border-yellow-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">🔍</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">심사 중이에요</h3>
          <p class="text-gray-700 text-sm mb-3">보험사에서 서류를 검토하고 있어요</p>
          <div class="text-xs text-gray-600 space-y-1">
            <p>⏱️ 평균 7~14일 정도 소요돼요</p>
            <p>📞 심사 관련 문의사항이 있으면 연락드릴 거예요</p>
          </div>
        </div>
      </div>
    </div>
  <% when 'approved' %>
    <div class="mb-6 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-6 border-l-4 border-green-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">✅</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">승인되었어요!</h3>
          <p class="text-gray-700 text-sm mb-3">보험금 지급 절차가 진행될 거예요</p>
          <div class="text-xs text-gray-600 space-y-1">
            <p>💰 곧 계좌로 보험금이 입금될 예정이에요</p>
            <p>📧 지급 완료되면 알려드릴게요</p>
          </div>
        </div>
      </div>
    </div>
  <% when 'rejected' %>
    <div class="mb-6 bg-gradient-to-r from-red-50 to-rose-50 rounded-2xl p-6 border-l-4 border-red-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">❌</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">반려되었어요</h3>
          <p class="text-gray-700 text-sm mb-3">보험사 심사 결과 승인이 어렵다고 판단되었어요</p>
          <div class="text-xs text-gray-600 space-y-1">
            <p>📞 자세한 사유는 보험사로 문의해주세요</p>
            <p>💡 필요한 경우 이의신청을 할 수 있어요</p>
          </div>
        </div>
      </div>
    </div>
  <% when 'completed' %>
    <div class="mb-6 bg-gradient-to-r from-purple-50 to-violet-50 rounded-2xl p-6 border-l-4 border-purple-500">
      <div class="flex items-start gap-3">
        <span class="text-3xl">🎉</span>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 text-lg mb-1">모든 절차가 완료되었어요</h3>
          <p class="text-gray-700 text-sm mb-3">보험금 지급이 완료되었어요</p>
          <p class="text-xs text-gray-600">💰 계좌를 확인해보세요</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 정보 카드 -->
  <div class="bg-white rounded-2xl border border-gray-100 divide-y">
    <!-- 신청자 정보 -->
    <div class="p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <span>👤</span>
        <span>신청자 정보</span>
      </h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
        <div>
          <dt class="text-gray-500">성명</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_name %></dd>
        </div>
        <div>
          <dt class="text-gray-500">연락처</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_phone %></dd>
        </div>
        <div>
          <dt class="text-gray-500">이메일</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_email || "-" %></dd>
        </div>
        <div>
          <dt class="text-gray-500">생년월일</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.birth_date&.strftime("%Y.%m.%d") || "-" %></dd>
        </div>
      </dl>
    </div>

    <!-- 사고 정보 -->
    <div class="p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <span>🚨</span>
        <span>사고 정보</span>
      </h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
        <div>
          <dt class="text-gray-500">사고 발생일</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.incident_date.strftime("%Y.%m.%d") %></dd>
        </div>
        <div>
          <dt class="text-gray-500">피해 유형</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.damage_type_label %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-500">사고 장소</dt>
          <dd class="font-medium text-gray-900">
            <%= @insurance_claim.incident_address %>
            <% if @insurance_claim.incident_detail_address.present? %>
              <span class="text-gray-500"><%= @insurance_claim.incident_detail_address %></span>
            <% end %>
          </dd>
        </div>
        <% if @insurance_claim.estimated_damage_amount.present? %>
          <div>
            <dt class="text-gray-500">예상 피해 금액</dt>
            <dd class="font-medium text-gray-900"><%= number_to_currency(@insurance_claim.estimated_damage_amount, unit: "₩", precision: 0) %></dd>
          </div>
        <% end %>
        <div class="sm:col-span-2">
          <dt class="text-gray-500">사고 내용</dt>
          <dd class="font-medium text-gray-900 whitespace-pre-line"><%= @insurance_claim.incident_description %></dd>
        </div>
      </dl>
    </div>

    <!-- 보험 정보 -->
    <div class="p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <span>🛡️</span>
        <span>보험 정보</span>
      </h3>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
        <div>
          <dt class="text-gray-500">보험사</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.insurance_company || "-" %></dd>
        </div>
        <div>
          <dt class="text-gray-500">증권번호</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.policy_number || "-" %></dd>
        </div>
      </dl>
    </div>

    <!-- 피해자 정보 -->
    <% if @insurance_claim.victim_name.present? %>
      <div class="p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <span>👥</span>
          <span>피해자 정보</span>
        </h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
          <div>
            <dt class="text-gray-500">성명</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_name %></dd>
          </div>
          <div>
            <dt class="text-gray-500">연락처</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_phone || "-" %></dd>
          </div>
          <% if @insurance_claim.victim_address.present? %>
            <div class="sm:col-span-2">
              <dt class="text-gray-500">주소</dt>
              <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_address %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>

    <!-- 연결된 체크 -->
    <% if @insurance_claim.request.present? %>
      <div class="p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <span>🔗</span>
          <span>연관 누수 체크</span>
        </h3>
        <div class="flex items-center justify-between bg-gray-50 rounded-lg p-3">
          <div class="text-sm">
            <span class="font-mono text-gray-500">NSC-<%= @insurance_claim.request.id.to_s.rjust(6, '0') %></span>
            <span class="ml-2 text-gray-700"><%= @insurance_claim.request.address.truncate(30) %></span>
          </div>
          <%= link_to "상세보기", customers_request_path(@insurance_claim.request),
                class: "text-sm text-primary-600 hover:text-primary-800" %>
        </div>
      </div>
    <% end %>

    <!-- 증빙 서류 -->
    <% if @insurance_claim.supporting_documents.attached? %>
      <div class="p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <span>📎</span>
          <span>증빙 서류</span>
          <span class="text-sm font-normal text-gray-500">(<%= @insurance_claim.supporting_documents.count %>개)</span>
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <% @insurance_claim.supporting_documents.each do |doc| %>
            <% if doc.content_type.start_with?("image/") %>
              <%= image_tag doc, class: "rounded-lg object-cover h-32 w-full" %>
            <% else %>
              <div class="bg-gray-50 rounded-lg p-4 flex items-center text-sm text-gray-600">
                <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
                <%= doc.filename %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 액션 버튼 -->
  <div class="mt-8">
    <% if @insurance_claim.pending_customer_review? %>
      <div class="bg-gradient-to-br from-yellow-50 to-amber-50 rounded-2xl p-6 border border-yellow-100 mb-4">
        <p class="text-sm text-gray-700 mb-4 flex items-start gap-2">
          <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
          <span>전문가가 작성한 내용을 확인해주세요. <strong>승인하시면 자동으로 보험사에 제출</strong>돼요</span>
        </p>
        <div class="flex flex-col gap-3">
          <div class="flex flex-wrap gap-3 justify-end">
            <%= button_to customer_approve_customers_insurance_claim_path(@insurance_claim),
                  method: :post,
                  class: "inline-flex items-center px-8 py-3 bg-primary-600 text-white rounded-xl font-bold hover:bg-primary-700 transition shadow-lg hover:shadow-xl",
                  data: { turbo_confirm: "✅ 보험청구서를 승인하시겠어요?\n\n승인하시면 즉시 보험사로 제출됩니다. 내용을 다시 한번 확인해주세요." } do %>
              ✅ 승인하고 보험사에 제출하기
            <% end %>
          </div>
          <details class="bg-white rounded-lg p-4 border border-yellow-200">
            <summary class="text-sm font-medium text-gray-900 cursor-pointer hover:text-gray-700">📝 수정이 필요하신가요? (클릭하여 수정 요청)</summary>
            <%= form_with url: customer_request_changes_customers_insurance_claim_path(@insurance_claim), method: :post, class: "mt-3 space-y-3" do |f| %>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">수정 요청사항을 자세히 적어주세요</label>
                <%= text_area_tag :customer_review_notes, nil, rows: 4,
                      required: true,
                      placeholder: "예시:\n- 공사 금액을 550,000원으로 수정해주세요\n- 사고 내용에 아래층 피해 내용도 추가해주세요\n- 피해자 연락처를 010-9876-5432로 변경해주세요",
                      class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500 focus:border-transparent text-sm" %>
                <p class="text-xs text-gray-500 mt-1">전문가가 확인하고 수정해드릴 거예요</p>
              </div>
              <div class="flex justify-end">
                <%= button_tag type: :submit,
                      class: "inline-flex items-center px-6 py-2.5 bg-yellow-600 text-white rounded-lg font-medium hover:bg-yellow-700 transition" do %>
                  📤 수정 요청 보내기
                <% end %>
              </div>
            <% end %>
          </details>
        </div>
      </div>
    <% elsif @insurance_claim.draft? && !@insurance_claim.prepared_by_master? %>
      <div class="bg-gradient-to-br from-primary-50 to-indigo-50 rounded-2xl p-6 border border-primary-100 mb-4">
        <p class="text-sm text-gray-700 mb-4 flex items-start gap-2">
          <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
          <span>내용을 확인하셨나요? <strong>제출하시면 보험사로 접수</strong>돼요. 제출 후에는 수정할 수 없으니 신중하게 확인해주세요</span>
        </p>
        <div class="flex flex-wrap gap-3 justify-end">
          <%= link_to edit_customers_insurance_claim_path(@insurance_claim),
                class: "inline-flex items-center px-5 py-2.5 rounded-lg font-medium text-gray-700 bg-white hover:bg-gray-50 transition border border-gray-300" do %>
            ✏️ 수정하기
          <% end %>
          <%= button_to submit_claim_customers_insurance_claim_path(@insurance_claim),
                method: :post,
                class: "inline-flex items-center px-8 py-3 bg-primary-600 text-white rounded-xl font-bold hover:bg-primary-700 transition shadow-lg hover:shadow-xl",
                data: { turbo_confirm: "✅ 신청서를 제출하시겠어요?\n\n제출 후에는 수정할 수 없으니 내용을 다시 한번 확인해주세요." } do %>
            📤 보험사에 제출하기
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="flex flex-wrap gap-3 justify-end">
        <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
              class: "inline-flex items-center gap-2 px-6 py-3 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 transition shadow-lg" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          PDF로 다운로드
        <% end %>
      </div>
      <p class="text-xs text-center text-gray-500 mt-3">신청서를 PDF 파일로 저장할 수 있어요</p>
    <% end %>
  </div>
</div>

<!-- 보험사 청구 안내 모달 -->
<div id="insuranceGuideModal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4" onclick="if(event.target === this) closeInsuranceGuide()">
  <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">

    <!-- 모달 헤더 -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
      <div>
        <h2 class="text-xl font-bold text-gray-900">보험사 청구 안내</h2>
        <p class="text-xs text-gray-500 mt-0.5">아래 보험사에 직접 청구서를 제출하세요</p>
      </div>
      <button onclick="closeInsuranceGuide()" class="text-gray-400 hover:text-gray-600 transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-6 space-y-3">
      <!-- 보험사별 카드 -->
      <% InsuranceSubmissionService.all_companies_guide.each do |company| %>
        <div class="border border-gray-200 rounded-xl overflow-hidden hover:border-gray-300 hover:shadow-sm transition-all">
          <div class="flex items-center gap-4 px-4 py-3.5">
            <!-- 이니셜 배지 -->
            <div class="w-10 h-10 rounded-lg <%= company[:badge_color] %> flex items-center justify-center flex-shrink-0">
              <span class="text-white text-sm font-bold"><%= company[:company_name].first(2) %></span>
            </div>

            <!-- 회사 정보 -->
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-900 text-sm"><%= company[:company_name] %></p>
              <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-1">
                <span class="text-xs text-gray-500">앱 · <%= company[:app_name] %></span>
                <span class="text-xs text-gray-500">대표전화 <%= company[:phone] %></span>
              </div>
            </div>

            <!-- 바로가기 -->
            <a href="<%= company[:website] %>" target="_blank" rel="noopener"
               class="flex-shrink-0 px-3 py-1.5 border border-gray-300 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-50 transition-colors">
              홈페이지
            </a>
          </div>
        </div>
      <% end %>

      <!-- 제출 시 유의사항 -->
      <div class="mt-2 p-4 bg-gray-50 rounded-xl border border-gray-200">
        <h4 class="text-sm font-semibold text-gray-800 mb-3">제출 시 유의사항</h4>
        <ul class="space-y-2">
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>보험사 앱 또는 홈페이지에서 <strong>일상배상책임보험</strong> 항목으로 청구하세요</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>다운로드한 PDF 청구서와 누수 피해 사진을 함께 첨부하세요</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>사고 발생일: <strong><%= @insurance_claim.incident_date.strftime("%Y년 %m월 %d일") %></strong></span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>제출 완료 후 이 페이지에서 <strong>심사 시작</strong> 버튼을 눌러 진행 상황을 확인하세요</span>
          </li>
        </ul>
      </div>

      <!-- 안내 -->
      <div class="p-4 bg-blue-50 rounded-xl border border-blue-100">
        <p class="text-sm text-blue-900 leading-relaxed">
          보험사에 제출이 완료되면 아래 <strong>심사 시작</strong> 버튼을 눌러주세요. 심사 진행 상황을 이 페이지에서 추적할 수 있습니다.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- 심사 시작 버튼 (submitted 상태일 때만) -->
<% if @insurance_claim.submitted? %>
  <div class="max-w-3xl mx-auto mt-6">
    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 mb-2">보험사에 제출을 완료하셨나요?</h3>
          <p class="text-sm text-gray-600 mb-4">제출하신 후 아래 버튼을 눌러주시면 심사 진행 상황을 추적해드려요</p>
          <%= button_to start_review_customers_insurance_claim_path(@insurance_claim),
                        method: :patch,
                        data: { confirm: "보험사에 제출을 완료하셨나요?\n\n확인하시면 심사 중 상태로 변경됩니다." },
                        class: "w-full sm:w-auto px-6 py-3 bg-yellow-500 text-white font-semibold rounded-lg hover:bg-yellow-600 transition-colors inline-flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            ✅ 보험사 제출 완료 → 심사 시작
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
function openInsuranceGuide() {
  document.getElementById('insuranceGuideModal').classList.remove('hidden');
  document.body.style.overflow = 'hidden'; // 배경 스크롤 방지
}

function closeInsuranceGuide() {
  document.getElementById('insuranceGuideModal').classList.add('hidden');
  document.body.style.overflow = 'auto'; // 배경 스크롤 복원
}

// ESC 키로 모달 닫기
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeInsuranceGuide();
  }
});
</script>
