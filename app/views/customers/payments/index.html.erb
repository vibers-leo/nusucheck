<!-- 결제 내역 페이지 (토스 스타일) -->
<%= render "shared/customer_nav" %>

<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- 헤더 -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">
        💳 결제 내역
      </h1>
      <p class="text-gray-600">
        모든 결제 내역을 확인하세요
      </p>
    </div>

    <!-- 통계 카드 -->
    <div class="grid md:grid-cols-2 gap-4 mb-8">
      <!-- 총 결제 금액 -->
      <div class="bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl p-6 text-white">
        <div class="flex items-center justify-between mb-3">
          <p class="text-primary-100 font-medium">총 결제 금액</p>
          <svg class="w-8 h-8 text-primary-200" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
        </div>
        <p class="text-3xl font-bold">
          <%= number_to_currency(@total_amount, unit: '₩', precision: 0) %>
        </p>
      </div>

      <!-- 진행 중 금액 -->
      <div class="bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl p-6 text-white">
        <div class="flex items-center justify-between mb-3">
          <p class="text-primary-100 font-medium">진행 중 금액</p>
          <svg class="w-8 h-8 text-primary-200" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
          </svg>
        </div>
        <p class="text-3xl font-bold">
          <%= number_to_currency(@pending_amount, unit: '₩', precision: 0) %>
        </p>
      </div>
    </div>

    <!-- 필터 -->
    <div class="mb-6 flex flex-wrap gap-3">
      <%= link_to "전체", customers_payments_path, class: "px-4 py-2 rounded-full #{params[:status].blank? ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>

      <% {
        pending: "대기 중",
        deposited: "입금 완료",
        completed: "완료",
        refunded: "환불"
      }.each do |status, label| %>
        <%= link_to label, customers_payments_path(status: status), class: "px-4 py-2 rounded-full #{params[:status] == status.to_s ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <% end %>
    </div>

    <!-- 결제 내역 리스트 -->
    <div class="space-y-4">
      <% @payments.each do |payment| %>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="flex-1">
              <!-- 제목 -->
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-bold text-gray-900 text-lg">
                  <%= payment.escrow_type.present? ? I18n.t("activerecord.attributes.escrow_transaction.escrow_types.#{payment.escrow_type}") : "결제" %>
                </h3>

                <!-- 상태 배지 -->
                <% if payment.status == 'completed' %>
                  <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-semibold">
                    완료
                  </span>
                <% elsif payment.status == 'pending' %>
                  <span class="px-3 py-1 bg-yellow-50 text-yellow-700 rounded-full text-xs font-semibold">
                    대기 중
                  </span>
                <% elsif payment.status == 'deposited' %>
                  <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-xs font-semibold">
                    입금 완료
                  </span>
                <% elsif payment.status == 'refunded' %>
                  <span class="px-3 py-1 bg-gray-50 text-gray-700 rounded-full text-xs font-semibold">
                    환불
                  </span>
                <% end %>
              </div>

              <!-- 요청 정보 -->
              <p class="text-sm text-gray-600 mb-1">
                체크 #<%= payment.request_id %> - <%= payment.request.symptom_type_label %>
              </p>

              <!-- 날짜 -->
              <p class="text-sm text-gray-500">
                <%= l(payment.created_at, format: :long) %>
              </p>
            </div>

            <!-- 금액 -->
            <div class="text-right">
              <p class="text-2xl font-bold text-gray-900">
                <%= number_to_currency(payment.amount, unit: '₩', precision: 0) %>
              </p>
              <% if payment.payment_method.present? %>
                <p class="text-sm text-gray-500 mt-1">
                  <%= payment.payment_method_label %>
                </p>
              <% end %>
            </div>
          </div>

          <!-- 결제 상세 정보 -->
          <div class="border-t border-gray-100 pt-4 grid grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-gray-500 mb-1">주문번호</p>
              <p class="font-mono text-gray-900">
                <%= payment.order_id || payment.payment_key || "-" %>
              </p>
            </div>
            <div class="text-right">
              <%= link_to "상세 보기", customers_request_path(payment.request), class: "inline-flex items-center gap-1 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg font-semibold hover:bg-gray-200 transition-colors" do %>
                <span>상세 보기</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 결제 내역 없을 때 -->
    <% if @payments.empty? %>
      <div class="text-center py-20">
        <div class="inline-block p-6 bg-gray-100 rounded-full mb-4">
          <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">
          결제 내역이 없습니다
        </h3>
        <p class="text-gray-600 mb-6">
          누수 체크를 시작해보세요!
        </p>
        <%= link_to "새 체크 요청", new_customers_request_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-xl font-semibold hover:shadow-lg transition-all" %>
      </div>
    <% end %>

    <!-- 페이지네이션 -->
    <div class="mt-8 flex justify-center">
      <%= paginate @payments, theme: 'twitter-bootstrap-4' %>
    </div>

    <!-- 안내 -->
    <div class="mt-12 bg-blue-50 rounded-2xl p-6">
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <div>
          <p class="font-bold text-blue-900 mb-2">영수증이 필요하신가요?</p>
          <p class="text-sm text-blue-800 mb-3">
            각 체크 상세 페이지에서 영수증을 PDF로 다운로드하실 수 있습니다.
          </p>
          <p class="text-sm text-blue-800">
            <strong>문의:</strong> support@nusucheck.kr
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
