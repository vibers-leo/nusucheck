<% content_for :title, "결제 내역" %>

<div class="min-h-screen bg-gray-50 pb-24 md:pb-10 overflow-x-hidden">
  <div class="max-w-2xl mx-auto px-4 pt-6">

    <!-- 헤더 -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">결제 내역</h1>
      <p class="text-sm text-gray-500 mt-1">에스크로 안전결제로 처리된 내역이에요</p>
    </div>

    <!-- 요약 카드 -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <p class="text-xs text-gray-500 mb-1">총 결제</p>
        <p class="text-lg font-bold text-gray-900"><%= number_to_currency(@total_amount, unit: '₩', precision: 0, delimiter: ',') %></p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <p class="text-xs text-gray-500 mb-1">진행 중</p>
        <p class="text-lg font-bold text-primary-600"><%= number_to_currency(@pending_amount, unit: '₩', precision: 0, delimiter: ',') %></p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <p class="text-xs text-gray-500 mb-1">환불</p>
        <p class="text-lg font-bold text-gray-500"><%= number_to_currency(@refunded_amount, unit: '₩', precision: 0, delimiter: ',') %></p>
      </div>
    </div>

    <!-- 상태 필터 탭 -->
    <div class="flex gap-2 overflow-x-auto pb-1 mb-5 scrollbar-hide">
      <% filter_tabs = {
        nil       => "전체",
        "pending"   => "대기",
        "deposited" => "입금완료",
        "held"      => "보류",
        "released"  => "지급",
        "settled"   => "정산완료",
        "refunded"  => "환불"
      } %>
      <% filter_tabs.each do |status, label| %>
        <%= link_to label,
              customers_payments_path(status: status),
              class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors whitespace-nowrap
                      #{params[:status].to_s == status.to_s ? 'bg-primary-600 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50'}" %>
      <% end %>
    </div>

    <!-- 결제 목록 -->
    <% if @payments.empty? %>
      <div class="bg-white rounded-2xl border border-gray-100 py-16 text-center">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
        </div>
        <p class="font-semibold text-gray-800 mb-1">결제 내역이 없어요</p>
        <p class="text-sm text-gray-500 mb-6">누수 체크를 시작하면 결제 내역이 쌓여요</p>
        <%= link_to "새 체크 요청하기", new_customers_request_path,
              class: "inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white rounded-xl text-sm font-semibold hover:bg-primary-700 transition-colors" %>
      </div>

    <% else %>
      <div class="space-y-3">
        <% @payments.each do |payment| %>
          <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
            <!-- 상단: 에스크로 타입 + 상태 -->
            <div class="flex items-center justify-between px-5 pt-4 pb-3">
              <div class="flex items-center gap-2">
                <!-- 에스크로 타입 아이콘 -->
                <div class="w-9 h-9 rounded-xl flex items-center justify-center
                  <%= case payment.escrow_type
                      when 'trip'         then 'bg-orange-100'
                      when 'detection'    then 'bg-blue-100'
                      when 'construction' then 'bg-purple-100'
                      else                     'bg-gray-100'
                      end %>">
                  <% case payment.escrow_type %>
                  <% when 'trip' %>
                    <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  <% when 'detection' %>
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                  <% when 'construction' %>
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                  <% else %>
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                    </svg>
                  <% end %>
                </div>

                <div>
                  <p class="font-semibold text-gray-900 text-sm">
                    <%= payment.escrow_type_label %>
                  </p>
                  <p class="text-xs text-gray-400">체크 #<%= payment.request_id %></p>
                </div>
              </div>

              <!-- 상태 배지 -->
              <% badge_styles = case payment.status
                 when 'pending'    then 'bg-yellow-50 text-yellow-700'
                 when 'deposited'  then 'bg-blue-50 text-blue-700'
                 when 'held'       then 'bg-orange-50 text-orange-700'
                 when 'released'   then 'bg-green-50 text-green-700'
                 when 'settled'    then 'bg-emerald-50 text-emerald-700'
                 when 'refunded'   then 'bg-gray-100 text-gray-600'
                 when 'disputed'   then 'bg-red-50 text-red-700'
                 else                   'bg-gray-50 text-gray-600'
                 end %>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= badge_styles %>">
                <%= payment.status_label %>
              </span>
            </div>

            <!-- 구분선 -->
            <div class="mx-5 border-t border-gray-50"></div>

            <!-- 금액 + 결제수단 -->
            <div class="flex items-center justify-between px-5 py-3">
              <div>
                <p class="text-xl font-bold text-gray-900">
                  <%= number_to_currency(payment.amount, unit: '₩', precision: 0, delimiter: ',') %>
                </p>
                <p class="text-xs text-gray-400 mt-0.5">
                  <% method_label = case payment.payment_method
                     when 'card'            then '카드'
                     when 'virtual_account' then '가상계좌'
                     when 'bank_transfer'   then '계좌이체'
                     when 'mobile'          then '휴대폰'
                     when 'easy_pay'        then '간편결제'
                     else payment.payment_method
                     end %>
                  <%= method_label.present? ? "#{method_label} 결제" : "결제 수단 미정" %>
                  · <%= l(payment.created_at, format: :short) %>
                </p>
              </div>

              <%= link_to customers_request_path(payment.request_id),
                    class: "flex items-center gap-1 text-sm text-primary-600 font-semibold hover:text-primary-700" do %>
                상세 보기
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            </div>

            <!-- 주문번호 (있을 때만) -->
            <% if payment.toss_order_id.present? %>
              <div class="px-5 pb-4">
                <p class="text-xs text-gray-400 font-mono">주문번호 <%= payment.toss_order_id %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- 페이지네이션 -->
      <% if @payments.respond_to?(:total_pages) && @payments.total_pages > 1 %>
        <div class="mt-6 flex justify-center gap-2">
          <%= paginate @payments %>
        </div>
      <% end %>
    <% end %>

    <!-- 에스크로 안내 -->
    <div class="mt-8 bg-primary-50 rounded-2xl p-5 flex gap-3">
      <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-primary-900">에스크로 안전결제란?</p>
        <p class="text-xs text-primary-700 mt-1 leading-relaxed">
          결제 금액은 에스크로에 안전하게 보관되고, 서비스 완료 확인 후 전문가에게 지급돼요.
          문제가 생기면 전액 환불이 가능해요.
        </p>
        <p class="text-xs text-primary-600 mt-2">문의 · contact@nusucheck.com</p>
      </div>
    </div>

  </div>
</div>
