<div class="min-h-screen bg-white" data-controller="check-wizard analytics" data-check-wizard-total-steps-value="7" data-analytics-category-value="Request Form">
  <!-- 상단 헤더 (Toss 스타일) -->
  <div class="bg-white sticky top-0 z-20">
    <div class="max-w-lg mx-auto px-4">
      <div class="flex items-center justify-between h-14">
        <button type="button" data-action="click->check-wizard#prevOrClose" class="w-10 h-10 flex items-center justify-center -ml-2 rounded-full hover:bg-gray-100 transition">
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>

        <button type="button" data-action="click->check-wizard#close" class="w-10 h-10 flex items-center justify-center -mr-2 rounded-full hover:bg-gray-100 transition">
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- 프로그레스 바 (Toss 스타일 - 얇고 미니멀) -->
      <div class="h-1 bg-gray-100 rounded-full overflow-hidden -mt-1" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="14" aria-label="폼 작성 진행률">
        <div data-check-wizard-target="progressBar" class="h-full bg-primary-500 rounded-full transition-all duration-500 ease-out" style="width: 14%"></div>
      </div>
    </div>
  </div>

  <!-- 메인 콘텐츠 -->
  <%= form_with(model: @request, url: customers_requests_path,
                html: { multipart: true, id: "check-form" },
                data: {
                  controller: "button-loading upload-progress",
                  action: "submit->button-loading#submit submit->upload-progress#handleSubmit",
                  upload_progress_target: "form",
                  upload_progress_redirect_url_value: customers_requests_path,
                  check_wizard_target: "form"
                }) do |f| %>

    <%= render "shared/form_errors", resource: @request %>

    <!-- Step 1: 증상 선택 (버튼 스타일) -->
    <div data-check-wizard-target="step" class="wizard-step">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-8">
          <p class="text-sm font-medium text-primary-600 mb-2">누수체크</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            어떤 증상이<br>발생했나요?
          </h1>
        </div>

        <div class="space-y-3" data-check-wizard-target="buttonGroup" data-field="symptom_type">
          <% [
            ["wall_leak", "💧", "벽면 누수", "벽에서 물이 배어나와요"],
            ["ceiling_leak", "💧", "천장 누수", "천장에서 물이 떨어져요"],
            ["floor_leak", "💧", "바닥 누수", "바닥이 축축해요"],
            ["pipe_leak", "🔧", "배관 누수", "배관에서 새는 것 같아요"],
            ["toilet_leak", "🚽", "화장실 누수", "화장실에서 물이 새요"],
            ["outdoor_leak", "🏠", "외부 누수", "외벽, 창틀에서 새요"]
          ].each do |value, icon, title, desc| %>
            <button type="button"
                    class="w-full flex items-center gap-4 p-4 rounded-2xl border-2 border-gray-200 bg-white hover:border-primary-300 hover:bg-primary-50/30 transition-all duration-200 text-left group select-button focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
                    data-action="click->check-wizard#selectOption keydown->check-wizard#handleKeydown"
                    data-value="<%= value %>"
                    role="radio"
                    aria-checked="false"
                    tabindex="0">
              <span class="text-2xl flex-shrink-0"><%= icon %></span>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 text-[15px]"><%= title %></p>
                <p class="text-sm text-gray-500 mt-0.5"><%= desc %></p>
              </div>
              <!-- 선택 시에만 체크마크 표시 -->
              <div class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center transition-all select-check hidden">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </button>
          <% end %>
        </div>
        <%= f.hidden_field :symptom_type, data: { check_wizard_target: "hiddenField" } %>
      </div>
    </div>

    <!-- Step 2: 건물 종류 (버튼 스타일) -->
    <div data-check-wizard-target="step" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-8">
          <p class="text-sm font-medium text-primary-600 mb-2">건물 정보</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            어떤 건물에서<br>발생했나요?
          </h1>
          <p class="text-gray-500 text-[15px] mt-3">건물에 맞는 전문가를 매칭해드려요</p>
        </div>

        <div class="grid grid-cols-3 gap-3" data-check-wizard-target="buttonGroup" data-field="building_type">
          <% [
            ["apartment", "🏢", "아파트"],
            ["villa", "🏘️", "빌라/연립"],
            ["house", "🏠", "단독주택"],
            ["office", "🏬", "사무실"],
            ["retail_store", "🏪", "상가"],
            ["factory", "🏭", "공장"],
            ["other_building", "📦", "기타"]
          ].each do |value, icon, label| %>
            <button type="button"
                    class="relative flex flex-col items-center gap-2 p-5 rounded-2xl border-2 border-gray-200 bg-white hover:border-primary-300 hover:bg-primary-50/30 transition-all duration-200 select-button focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
                    data-action="click->check-wizard#selectOption keydown->check-wizard#handleKeydown"
                    data-value="<%= value %>"
                    role="radio"
                    aria-checked="false"
                    aria-label="<%= label %>"
                    tabindex="0">
              <!-- 선택 시에만 체크마크 표시 -->
              <div class="absolute top-2 right-2 w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center transition-all select-check hidden">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-3xl"><%= icon %></span>
              <span class="text-sm font-medium text-gray-700"><%= label %></span>
            </button>
          <% end %>
        </div>
        <%= f.hidden_field :building_type, data: { check_wizard_target: "hiddenField" } %>
      </div>
    </div>

    <!-- Step 3: 주소 입력 -->
    <div data-check-wizard-target="step" data-controller="address-search" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-8">
          <p class="text-sm font-medium text-primary-600 mb-2">방문 위치</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            어디로 방문하면<br>될까요?
          </h1>
        </div>

        <div class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-2">주소</label>
            <div class="flex gap-2">
              <%= f.text_field :address,
                    placeholder: "주소를 검색해주세요",
                    required: true,
                    readonly: true,
                    data: {
                      action: "input->check-wizard#validateStep",
                      address_search_target: "address",
                      check_wizard_target: "requiredInput"
                    },
                    class: "flex-1 px-4 py-4 text-[15px] border-2 border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition" %>
              <button type="button"
                      data-action="click->address-search#open"
                      class="px-5 py-4 rounded-xl font-bold text-white bg-primary-600 hover:bg-primary-700 transition-all whitespace-nowrap">
                검색
              </button>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-2">상세 주소</label>
            <%= f.text_field :detailed_address,
                  placeholder: "101동 502호",
                  data: { address_search_target: "detailedAddress" },
                  class: "w-full px-4 py-4 text-[15px] border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition" %>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-2">층수 <span class="text-gray-400 font-normal">(선택)</span></label>
            <%= f.text_field :floor_info,
                  placeholder: "5층",
                  class: "w-full px-4 py-4 text-[15px] border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 4: 상황 설명 -->
    <div data-check-wizard-target="step" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-8">
          <p class="text-sm font-medium text-primary-600 mb-2">상세 정보</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            어떤 상황인지<br>알려주세요
          </h1>
          <p class="text-gray-500 text-[15px] mt-3">자세할수록 정확한 진단이 가능해요</p>
        </div>

        <div class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-2">상황 설명 <span class="text-gray-400 font-normal">(선택)</span></label>
            <%= f.text_area :description,
                  rows: 5,
                  placeholder: "예: 일주일 전부터 천장에서 물방울이 떨어지기 시작했어요. 점점 심해지고 있습니다.",
                  class: "w-full px-4 py-4 text-[15px] border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition resize-none leading-relaxed" %>
            <p class="text-xs text-gray-400 mt-2">언제부터, 얼마나 심한지 알려주시면 좋아요</p>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-2">방문 희망일 <span class="text-gray-400 font-normal">(선택)</span></label>
            <%= f.datetime_local_field :preferred_date,
                  min: DateTime.now.strftime("%Y-%m-%dT%H:%M"),
                  class: "w-full px-4 py-4 text-[15px] border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition" %>
            <p class="text-xs text-gray-400 mt-2">급하시면 비워두세요. 최대한 빨리 연락드릴게요</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 5: 영상 촬영/업로드 (영상만, 토스 스타일) -->
    <div data-check-wizard-target="step" data-controller="file-counter video-compressor" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-6 text-center">
          <p class="text-sm font-medium text-primary-600 mb-2">영상 촬영</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            📹 영상을 찍어주세요
          </h1>
          <p class="text-[15px] text-gray-600 mt-3">10초 이상 촬영하면 전문가가 정확히 진단해요</p>
        </div>

        <!-- 영상이 중요함을 강조하는 배너 -->
        <div class="mb-6 p-5 bg-gradient-to-br from-primary-50 via-blue-50 to-indigo-50 border-2 border-primary-300 rounded-2xl shadow-sm">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-primary-600 to-blue-600 rounded-full flex items-center justify-center shadow-md">
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="font-bold text-primary-900 text-base mb-1.5">
                📹 영상이 사진보다 10배 더 정확해요!
              </p>
              <p class="text-primary-800 text-sm leading-relaxed">
                10초 이상의 영상으로 누수 상황을 보여주시면 전문가가 <strong>현장 방문 전에도 정확한 진단</strong>이 가능합니다.
              </p>
            </div>
          </div>
        </div>

        <!-- 영상 업로드 영역 (더 크고 눈에 띄게) -->
        <div class="border-4 border-dashed border-primary-500 rounded-3xl p-12 text-center hover:border-primary-600 hover:bg-primary-50 bg-gradient-to-br from-primary-50/50 to-blue-50/30 transition-all cursor-pointer shadow-sm hover:shadow-md video-upload-box"
             id="video-drop-zone"
             role="button"
             tabindex="0"
             aria-label="영상 파일 업로드: 촬영하거나 기존 영상을 선택하세요. 10초 이상 권장, 최대 2GB까지 업로드 가능"
             aria-describedby="video-upload-help">
          <%= f.file_field :videos,
                multiple: true,
                accept: "video/mp4,video/quicktime,video/avi,video/webm,video/3gpp",
                capture: "environment",
                class: "hidden",
                id: "video-upload",
                aria-label="영상 파일 선택",
                data: {
                  file_counter_target: "videoInput",
                  video_compressor_target: "input",
                  action: "change->file-counter#updateVideoCounts change->check-wizard#onFileChange"
                } %>
          <label for="video-upload" class="cursor-pointer block">
            <div class="inline-block p-8 bg-gradient-to-br from-primary-600 to-blue-600 rounded-3xl mb-6 shadow-lg" aria-hidden="true">
              <svg class="w-16 h-16 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
              </svg>
            </div>
            <p class="text-2xl font-bold text-gray-900 mb-3">📱 촬영하거나 기존 영상 선택</p>
            <p class="text-lg text-primary-700 font-semibold mb-2">10초 이상 권장</p>
            <p id="video-upload-help" class="text-base text-gray-600"><strong class="text-primary-600">최대 2GB까지</strong> 업로드 가능 · MP4, MOV, WebM</p>
            <p class="text-sm text-gray-500 mt-3">또는 영상 파일을 이 영역으로 드래그하세요</p>
          </label>
        </div>

        <!-- 업로드된 파일 표시 (스크린 리더 알림) -->
        <div data-file-counter-target="videoCount"
             class="mt-4 text-center text-sm font-medium text-gray-500"
             role="status"
             aria-live="polite"
             aria-atomic="true">
        </div>

        <!-- 영상 미리보기 영역 -->
        <div data-file-counter-target="videoPreview" class="mt-6 hidden">
          <h3 class="text-sm font-bold text-gray-900 mb-3">📹 선택한 영상</h3>
          <div data-file-counter-target="videoPreviewContainer" class="grid grid-cols-1 gap-3">
            <!-- 미리보기가 여기에 동적으로 추가됩니다 -->
          </div>
        </div>

        <!-- 촬영 팁 (노란색 박스로 눈에 띄게) -->
        <div class="mt-6 p-4 bg-gradient-to-r from-yellow-50 to-amber-50 rounded-xl border border-yellow-200 shadow-sm">
          <p class="font-bold mb-2 text-gray-900 flex items-center gap-2">
            <span class="text-lg">🎬</span>
            이렇게 촬영하면 전문가가 더 정확히 진단해요
          </p>
          <ul class="space-y-1.5 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-primary-600 font-bold">1.</span>
              <span><strong>10초 이상</strong> 연속으로 촬영해주세요 (중간에 멈추지 마세요)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-600 font-bold">2.</span>
              <span>누수 부위를 <strong>천천히 클로즈업</strong>하세요</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-600 font-bold">3.</span>
              <span>주변 환경(천장, 벽, 바닥)도 함께 보여주세요</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary-600 font-bold">4.</span>
              <span><strong>물 떨어지는 소리</strong>도 함께 녹음되면 더욱 좋아요</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Step 6: 연락처 확인 -->
    <div data-check-wizard-target="step" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-32">
        <div class="mb-8">
          <p class="text-sm font-medium text-primary-600 mb-2">연락 정보</p>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            연락받으실 정보를<br>확인해주세요
          </h1>
        </div>

        <div class="space-y-5">
          <% if current_user %>
            <div class="bg-gray-50 rounded-2xl p-5">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900"><%= current_user.name || current_user.email %></p>
                  <p class="text-sm text-gray-500"><%= current_user.email %></p>
                  <% if current_user.respond_to?(:phone) && current_user.phone.present? %>
                    <p class="text-sm text-gray-500"><%= current_user.phone %></p>
                  <% end %>
                </div>
              </div>
            </div>
            <p class="text-xs text-gray-400 text-center">전문가가 이 연락처로 연락드려요</p>
          <% else %>
            <div class="p-5 bg-primary-50 rounded-2xl border border-primary-200 text-center">
              <p class="text-sm text-primary-900 mb-3">로그인하시면 더 빠르게 접수할 수 있어요</p>
              <%= link_to "로그인하기", new_user_session_path, class: "inline-block px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Step 7: 최종 확인 & 제출 -->
    <div data-check-wizard-target="step" class="wizard-step hidden">
      <div class="max-w-lg mx-auto px-5 pt-8 pb-40">
        <div class="mb-8 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h1 class="text-[26px] font-bold text-gray-900 leading-tight tracking-tight">
            거의 다 됐어요!
          </h1>
          <p class="text-gray-500 text-[15px] mt-2">내용을 확인하고 요청해주세요</p>
        </div>

        <!-- 요약 카드 -->
        <div class="space-y-3">
          <div class="bg-gray-50 rounded-2xl p-5">
            <div class="space-y-4">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-xs text-gray-400 mb-1">증상</p>
                  <p class="font-semibold text-gray-900" data-check-wizard-target="summarySymptom">-</p>
                </div>
                <button type="button" data-action="click->check-wizard#goToStep" data-step="1" class="text-primary-600 text-sm font-medium">수정</button>
              </div>
              <div class="border-t border-gray-200"></div>
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-xs text-gray-400 mb-1">건물</p>
                  <p class="font-semibold text-gray-900" data-check-wizard-target="summaryBuilding">-</p>
                </div>
                <button type="button" data-action="click->check-wizard#goToStep" data-step="2" class="text-primary-600 text-sm font-medium">수정</button>
              </div>
              <div class="border-t border-gray-200"></div>
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-xs text-gray-400 mb-1">주소</p>
                  <p class="font-semibold text-gray-900" data-check-wizard-target="summaryAddress">-</p>
                </div>
                <button type="button" data-action="click->check-wizard#goToStep" data-step="3" class="text-primary-600 text-sm font-medium">수정</button>
              </div>
            </div>
          </div>

          <!-- 안심 보증 -->
          <div class="bg-primary-50 rounded-2xl p-5 border border-primary-100">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-primary-900">누수체크 안심 보증</p>
              </div>
            </div>
            <div class="space-y-2 text-sm text-primary-800">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span>원인 못 찾으면 <strong>출장비 0원</strong></span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span>에스크로 <strong>안전 결제</strong></span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-primary-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span><strong>2년 무상 AS</strong> 보증</span>
              </div>
            </div>
          </div>

          <div class="p-4 bg-gray-50 rounded-xl">
            <p class="text-xs text-gray-500 text-center">
              예상 비용: 탐지 10~15만원, 수리 30만원~ (현장 상황에 따라 달라져요)
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- 하단 고정 버튼 (Toss 스타일) -->
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 z-10 pb-safe">
      <div class="max-w-lg mx-auto px-5 py-4">
        <!-- 다음 버튼 -->
        <button type="button"
                data-check-wizard-target="nextBtn"
                data-action="click->check-wizard#next"
                class="w-full py-4 rounded-2xl font-bold text-[17px] transition-all duration-200 bg-gray-200 text-gray-400 cursor-not-allowed"
                disabled>
          다음
        </button>

        <!-- 건너뛰기 + 다음 (선택사항 스텝용) -->
        <div data-check-wizard-target="skipNextGroup" class="hidden space-y-2">
          <button type="button"
                  data-action="click->check-wizard#next"
                  class="w-full py-4 rounded-2xl font-bold text-[17px] bg-primary-600 text-white hover:bg-primary-700 transition-all">
            다음
          </button>
          <button type="button"
                  data-action="click->check-wizard#skip"
                  class="w-full py-3 rounded-xl font-medium text-[15px] text-gray-500 hover:text-gray-700 hover:bg-gray-50 transition">
            건너뛰기
          </button>
        </div>

        <!-- 제출 버튼 -->
        <button type="submit"
                data-check-wizard-target="submitBtn"
                data-button-loading-target="button"
                data-button-loading-loading-text-value="영상 업로드 중... 잠시만 기다려주세요"
                class="hidden w-full py-4 rounded-2xl font-bold text-[17px] bg-primary-600 text-white hover:bg-primary-700 transition-all shadow-lg">
          <span data-button-loading-target="spinner" class="btn-spinner hidden"></span>
          <span data-button-loading-target="text">전문가에게 요청하기</span>
        </button>
      </div>
    </div>

  <% end %>

  <!-- 업로드 진행률 모달 -->
  <div data-upload-progress-target="progressModal"
       class="hidden fixed inset-0 z-50 items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm">
    <div class="bg-white rounded-3xl p-8 max-w-md w-full mx-4 shadow-2xl">
      <!-- 헤더 -->
      <div class="text-center mb-6">
        <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-primary-600 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">영상 업로드 중</h3>
        <p class="text-sm text-gray-500">잠시만 기다려주세요...</p>
      </div>

      <!-- 진행률 바 -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-700">진행률</span>
          <span data-upload-progress-target="progressText" class="text-sm font-bold text-primary-600">0%</span>
        </div>
        <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden shadow-inner">
          <div data-upload-progress-target="progressBar"
               class="h-full bg-gradient-to-r from-primary-500 to-primary-600 rounded-full transition-all duration-300 ease-out shadow-sm"
               style="width: 0%"></div>
        </div>
      </div>

      <!-- 파일 크기 정보 -->
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500">업로드 중</p>
            <p class="text-sm font-medium text-gray-900">
              <span data-upload-progress-target="uploadedSize">0 MB</span> /
              <span data-upload-progress-target="totalSize">0 MB</span>
            </p>
          </div>
        </div>
      </div>

      <!-- 에러 메시지 -->
      <div data-upload-progress-target="errorMessage"
           class="hidden mb-4 p-4 bg-red-50 border-2 border-red-200 rounded-xl">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <p class="text-sm text-red-800"></p>
        </div>
      </div>

      <!-- 취소 버튼 -->
      <button type="button"
              data-upload-progress-target="cancelButton"
              data-action="click->upload-progress#cancel"
              class="w-full py-3 rounded-xl font-medium text-gray-600 hover:bg-gray-100 transition">
        업로드 취소
      </button>

      <!-- 힌트 -->
      <p class="text-xs text-gray-400 text-center mt-4">
        💡 대용량 영상은 시간이 걸릴 수 있어요
      </p>
    </div>
  </div>

  <!-- 영상 압축 모달 -->
  <div data-video-compressor-target="compressionModal"
       class="hidden fixed inset-0 z-50 items-center justify-center bg-black bg-opacity-50 backdrop-blur-sm">
    <div class="bg-white rounded-3xl p-8 max-w-md w-full mx-4 shadow-2xl">
      <!-- 헤더 -->
      <div class="text-center mb-6">
        <div class="w-16 h-16 mx-auto mb-4 bg-purple-100 rounded-full flex items-center justify-center">
          <svg class="w-8 h-8 text-purple-600 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">영상 압축 중</h3>
        <p class="text-sm text-gray-500">업로드 속도를 빠르게 만들고 있어요</p>
      </div>

      <!-- 진행률 바 -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-700">진행률</span>
          <span data-video-compressor-target="compressionText" class="text-sm font-bold text-purple-600">0%</span>
        </div>
        <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden shadow-inner">
          <div data-video-compressor-target="compressionProgress"
               class="h-full bg-gradient-to-r from-purple-500 to-purple-600 rounded-full transition-all duration-300 ease-out shadow-sm"
               style="width: 0%"></div>
        </div>
      </div>

      <!-- 파일 정보 -->
      <div class="flex items-center justify-between p-4 bg-purple-50 rounded-xl mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-500">압축 중</p>
            <p class="text-sm font-medium text-gray-900">
              <span data-video-compressor-target="currentFile">1</span> /
              <span data-video-compressor-target="totalFiles">1</span> 파일
            </p>
          </div>
        </div>
      </div>

      <!-- 상태 메시지 -->
      <div class="mb-4 p-3 bg-gray-50 rounded-xl">
        <p data-video-compressor-target="statusMessage" class="text-xs text-gray-600 text-center">
          압축 준비 중...
        </p>
      </div>

      <!-- 건너뛰기 버튼 -->
      <button type="button"
              data-video-compressor-target="skipButton"
              data-action="click->video-compressor#skip"
              class="w-full py-3 rounded-xl font-medium text-gray-600 hover:bg-gray-100 transition">
        압축 건너뛰기 (원본 사용)
      </button>

      <!-- 힌트 -->
      <p class="text-xs text-gray-400 text-center mt-4">
        💡 50MB 이상 영상은 자동으로 압축돼요
      </p>
    </div>
  </div>
</div>
