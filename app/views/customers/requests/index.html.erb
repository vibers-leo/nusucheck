<%# 당근마켓 스타일 체크 목록 - 리스트 뷰 %>

<!-- 헤더 -->
<div class="mb-5">
  <h1 class="text-xl font-bold text-gray-900">내 체크</h1>
  <p class="text-sm text-gray-500 mt-0.5">전문가 매칭부터 수리 완료까지 한눈에</p>
</div>

<!-- 필터 -->
<div class="bg-white rounded-2xl border border-gray-100 p-4 mb-4">
  <%= search_form_for @q, url: customers_requests_path, html: { method: :get, class: "flex flex-col sm:flex-row gap-3" } do |f| %>
    <div class="flex-1">
      <%= f.select :status_eq,
            options_for_select([
              ["전체 상태", ""],
              ["접수됨", "reported"],
              ["마스터 배정", "assigned"],
              ["방문 중", "visiting"],
              ["탐지 중", "detecting"],
              ["견적 대기", "estimate_pending"],
              ["견적 제출", "estimate_submitted"],
              ["공사 합의", "construction_agreed"],
              ["공사 진행", "constructing"],
              ["공사 완료", "construction_completed"],
              ["종료", "closed"],
              ["취소", "cancelled"]
            ], params.dig(:q, :status_eq)),
            {}, class: input_classes(:select) %>
    </div>
    <div class="flex-1">
      <%= f.select :symptom_type_eq,
            options_for_select([
              ["전체 증상", ""],
              ["벽면 누수", "wall_leak"],
              ["천장 누수", "ceiling_leak"],
              ["바닥 누수", "floor_leak"],
              ["배관 누수", "pipe_leak"],
              ["화장실 누수", "toilet_leak"],
              ["외부 누수", "outdoor_leak"]
            ], params.dig(:q, :symptom_type_eq)),
            {}, class: input_classes(:select) %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "검색", class: btn_classes(:primary, :md) %>
      <%= link_to "초기화", customers_requests_path, class: btn_classes(:secondary, :md) %>
    </div>
  <% end %>
</div>

<!-- 리스트 뷰 -->
<% if @requests.any? %>
  <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
    <% @requests.each do |request| %>
      <%= link_to customers_request_path(request), class: "block list-item-touch" do %>
        <div class="px-4 py-4">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <%= render "shared/status_badge", status: request.status %>
                <span class="text-xs text-gray-400">#<%= request.id %></span>
              </div>
              <h3 class="text-[15px] font-semibold text-gray-900">
                <%= symptom_label(request.symptom_type) %>
              </h3>
              <div class="flex items-center gap-3 mt-1.5 text-sm text-gray-500">
                <span class="flex items-center">
                  <svg class="w-3.5 h-3.5 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <%= truncate(request.address, length: 20) %>
                </span>
                <span class="text-gray-300">|</span>
                <span><%= l(request.created_at, format: :short) rescue request.created_at.strftime("%m/%d %H:%M") %></span>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-300 flex-shrink-0 ml-2 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- 페이지네이션 -->
  <div class="mt-6">
    <%= paginate @requests %>
  </div>
<% else %>
  <%= render "shared/empty_state",
        icon: "water",
        title: "아직 체크 내역이 없어요",
        description: "누수로 고민이시라면 지금 바로 체크하세요",
        cta_text: "체크 접수하기",
        cta_path: new_customers_request_path %>

  <!-- 증상 안내 -->
  <div class="mt-6 bg-primary-50 rounded-2xl p-5">
    <h3 class="text-sm font-bold text-gray-900 mb-3">이런 증상이 있다면 바로 체크하세요</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-700">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">&#10003;</div>
        <span>벽이나 천장에 물방울이 맺혀있어요</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">&#10003;</div>
        <span>벽지가 들뜨거나 변색되었어요</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">&#10003;</div>
        <span>곰팡이 냄새가 나요</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">&#10003;</div>
        <span>수도 요금이 갑자기 많이 나왔어요</span>
      </div>
    </div>
  </div>
<% end %>
