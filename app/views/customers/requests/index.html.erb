<%# 고객 - 내 체크 목록 (역할 맞춤 재설계) %>

<%
  current_status = params.dig(:q, :status_eq).to_s
  current_symptom = params.dig(:q, :symptom_type_eq).to_s
  has_filter = current_status.present? || current_symptom.present?

  status_label = {
    "reported"                => "접수됨",
    "assigned"                => "전문가 배정",
    "visiting"                => "방문 중",
    "detecting"               => "탐지 중",
    "no_leak_found"           => "누수 미확인",
    "estimate_pending"        => "견적 대기",
    "estimate_submitted"      => "견적 확인",
    "construction_agreed"     => "공사 합의",
    "escrow_deposited"        => "결제 완료",
    "constructing"            => "공사 중",
    "construction_completed"  => "완료 확인",
    "closed"                  => "종료",
    "cancelled"               => "취소"
  }

  next_action = ->(req) {
    case req.status
    when "reported"               then "전문가 매칭 중이에요"
    when "assigned"               then "전문가가 일정을 잡고 있어요"
    when "visiting"               then "전문가 방문 예정이에요"
    when "detecting"              then "누수 탐지가 진행 중이에요"
    when "no_leak_found"          then "탐지 결과를 확인해주세요"
    when "estimate_pending"       then "견적을 기다리는 중이에요"
    when "estimate_submitted"     then "견적이 도착했어요 → 확인해주세요"
    when "construction_agreed"    then "공사 일정이 확정됐어요"
    when "escrow_deposited"       then "결제 완료 · 공사 시작 예정이에요"
    when "constructing"           then "공사가 진행 중이에요"
    when "construction_completed" then "공사가 끝났어요 → 완료 확인해주세요"
    else nil
    end
  }
%>

<!-- 헤더 -->
<div class="mb-5 flex items-center justify-between">
  <div>
    <h1 class="text-xl font-bold text-gray-900">내 체크</h1>
    <p class="text-sm text-gray-500 mt-0.5">의뢰하신 누수 체크 현황이에요</p>
  </div>
  <%= link_to new_customers_request_path,
        class: "flex items-center gap-1.5 px-4 py-2 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition-colors shadow-sm" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    새 체크
  <% end %>
</div>


<!-- ── 리스트 ── -->
<% if @requests.any? %>
  <div class="space-y-4">
    <% @requests.each do |request| %>
      <% thumb_photo = request.photos.first %>
      <% thumb_video = request.videos.first %>
      <%= link_to customers_request_path(request), class: "block" do %>
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <%# 썸네일 영역 %>
          <div class="relative w-full h-48 bg-gradient-to-br from-gray-100 to-gray-200">
            <% if thumb_photo.attached? %>
              <%= image_tag thumb_photo.variant(resize_to_fill: [600, 300]), class: "w-full h-full object-cover" %>
            <% elsif thumb_video.attached? %>
              <video src="<%= url_for(thumb_video) %>" class="w-full h-full object-cover" muted preload="metadata" style="pointer-events:none"></video>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 bg-black/40 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            <% else %>
              <div class="w-full h-full flex flex-col items-center justify-center gap-2">
                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="text-xs text-gray-400">사진/영상 없음</span>
              </div>
            <% end %>
            <%# 상태 배지 오버레이 %>
            <div class="absolute top-3 left-3">
              <%= render "shared/status_badge", status: request.status %>
            </div>
            <div class="absolute top-3 right-3 bg-black/30 text-white text-xs font-mono px-2 py-0.5 rounded-full">
              #<%= request.id %>
            </div>
          </div>

          <%# 정보 영역 %>
          <div class="px-4 py-3.5">
            <h3 class="text-base font-bold text-gray-900 mb-1.5"><%= symptom_label(request.symptom_type) %></h3>
            <div class="flex items-center gap-1.5 text-sm text-gray-400 mb-2">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="truncate"><%= request.address %></span>
              <span class="flex-shrink-0 text-gray-200">·</span>
              <span class="flex-shrink-0"><%= request.created_at.strftime("%m.%d") %></span>
            </div>
            <% hint = next_action.call(request) %>
            <% if hint && !%w[closed cancelled].include?(request.status) %>
              <div class="flex items-center gap-2 bg-primary-50 rounded-xl px-3 py-2">
                <div class="w-1.5 h-1.5 rounded-full bg-primary-400 animate-pulse flex-shrink-0"></div>
                <span class="text-xs font-semibold text-primary-700"><%= hint %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-6">
    <%= paginate @requests %>
  </div>

<% else %>
  <%= render "shared/empty_state",
        icon: "water",
        title: has_filter ? "해당 조건의 체크가 없어요" : "아직 체크 내역이 없어요",
        description: has_filter ? "다른 필터를 선택해보세요" : "누수로 고민이시라면 지금 바로 체크하세요",
        cta_text: has_filter ? "전체 보기" : "체크 접수하기",
        cta_path: has_filter ? customers_requests_path : new_customers_request_path %>

  <% unless has_filter %>
    <div class="mt-6 bg-primary-50 rounded-2xl p-5">
      <h3 class="text-sm font-bold text-gray-900 mb-3">이런 증상이 있다면 바로 체크하세요</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-gray-700">
        <% [
          "벽이나 천장에 물방울이 맺혀있어요",
          "벽지가 들뜨거나 변색되었어요",
          "곰팡이 냄새가 나요",
          "수도 요금이 갑자기 많이 나왔어요"
        ].each do |item| %>
          <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">✓</div>
            <span><%= item %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
