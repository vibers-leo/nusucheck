<%# 토스 스타일 초기 분기 질문 — "지금 누수가 발생하고 있나요?" %>
<div class="min-h-screen bg-white flex flex-col">

  <!-- 헤더 -->
  <div class="sticky top-0 z-20 bg-white border-b border-gray-100">
    <div class="max-w-lg mx-auto px-4">
      <div class="flex items-center h-14">
        <%= link_to customers_dashboard_path,
              class: "w-10 h-10 flex items-center justify-center -ml-2 rounded-full hover:bg-gray-100 transition" do %>
          <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        <% end %>
      </div>
    </div>
    <!-- 프로그레스 바 (1단계 표시용 — 가장 얇게) -->
    <div class="h-0.5 bg-gray-100">
      <div class="h-0.5 bg-primary-500 transition-all duration-400" style="width: 0%"></div>
    </div>
  </div>

  <!-- 메인 콘텐츠 -->
  <div class="flex-1 max-w-lg mx-auto w-full px-5 pt-12 pb-36">

    <!-- 질문 -->
    <p class="text-xs font-bold text-primary-500 mb-4 tracking-widest uppercase">Step 1</p>
    <h1 class="text-[1.85rem] font-bold text-gray-900 leading-tight mb-3">
      지금 누수가<br>발생하고 있나요?
    </h1>
    <p class="text-[15px] text-gray-400 mb-10 leading-relaxed">
      상황에 맞는 방법으로 빠르게 도와드릴게요
    </p>

    <!-- 선택 카드 -->
    <div class="space-y-3">

      <!-- YES: 지금 누수 중 -->
      <%= link_to new_customers_request_path(mode: 'expert'),
            class: "block group",
            data: { turbo: false } do %>
        <div class="flex items-center gap-4 p-5 rounded-3xl border-2 border-gray-100 bg-white
                    group-hover:border-red-300 group-hover:bg-red-50
                    active:scale-[0.98] transition-all duration-150 cursor-pointer">
          <div class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center flex-shrink-0
                      group-hover:bg-red-200 transition-colors">
            <span class="text-2xl">🚨</span>
          </div>
          <div class="flex-1">
            <p class="font-bold text-gray-900 text-[16px] mb-0.5">네, 지금 새고 있어요</p>
            <p class="text-sm text-gray-400">영상·사진으로 전문가에게 바로 연결</p>
          </div>
          <svg class="w-5 h-5 text-gray-300 group-hover:text-red-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>

      <!-- NO: 점검/사전진단 필요 -->
      <%= link_to new_customers_request_path(mode: 'diagnosis'),
            class: "block group",
            data: { turbo: false } do %>
        <div class="flex items-center gap-4 p-5 rounded-3xl border-2 border-gray-100 bg-white
                    group-hover:border-primary-300 group-hover:bg-primary-50
                    active:scale-[0.98] transition-all duration-150 cursor-pointer">
          <div class="w-14 h-14 bg-primary-100 rounded-2xl flex items-center justify-center flex-shrink-0
                      group-hover:bg-primary-200 transition-colors">
            <span class="text-2xl">🔍</span>
          </div>
          <div class="flex-1">
            <p class="font-bold text-gray-900 text-[16px] mb-0.5">아니요, 점검이 필요해요</p>
            <p class="text-sm text-gray-400">증상을 파악하고 전문가 예약</p>
          </div>
          <svg class="w-5 h-5 text-gray-300 group-hover:text-primary-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      <% end %>

    </div>

    <!-- 안심 문구 -->
    <div class="mt-10 flex items-center justify-center gap-5 text-center">
      <div>
        <p class="text-sm font-bold text-gray-700">투명</p>
        <p class="text-xs text-gray-400 mt-0.5">표준 검사비</p>
      </div>
      <div class="w-px h-8 bg-gray-200"></div>
      <div>
        <p class="text-sm font-bold text-gray-700">안전</p>
        <p class="text-xs text-gray-400 mt-0.5">에스크로 결제</p>
      </div>
      <div class="w-px h-8 bg-gray-200"></div>
      <div>
        <p class="text-sm font-bold text-gray-700">2년</p>
        <p class="text-xs text-gray-400 mt-0.5">무상 AS</p>
      </div>
    </div>
  </div>

</div>
