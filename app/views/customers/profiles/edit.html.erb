<%# 당근마켓 스타일 프로필 수정 %>

<!-- 헤더 -->
<div class="mb-5">
  <%= link_to customers_profile_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    돌아가기
  <% end %>
  <h1 class="text-xl font-bold text-gray-900">프로필 수정</h1>
</div>

<div class="bg-white rounded-2xl border border-gray-100 p-5">
  <%= form_with(model: @customer, url: customers_profile_path, method: :patch, class: "space-y-5") do |f| %>

    <%= render "shared/form_errors", resource: @customer %>

    <!-- 이름 -->
    <div>
      <%= f.label :name, "이름", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            placeholder: "홍길동",
            class: input_classes(:text),
            required: true %>
      <p class="mt-1 text-xs text-gray-500">실명을 입력해 주세요.</p>
    </div>

    <!-- 전화번호 -->
    <div>
      <%= f.label :phone, "전화번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :phone,
            placeholder: "010-1234-5678",
            class: input_classes(:text),
            pattern: "01[016789]-?\\d{3,4}-?\\d{4}" %>
      <p class="mt-1 text-xs text-gray-500">하이픈(-)은 선택사항입니다.</p>
    </div>

    <!-- 주소 -->
    <div>
      <%= f.label :address, "주소", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :address,
            placeholder: "서울시 강남구 테헤란로 123",
            class: input_classes(:text) %>
      <p class="mt-1 text-xs text-gray-500">자주 사용하는 주소를 등록해두면 편리합니다.</p>
    </div>

    <!-- 제출 버튼 -->
    <div class="flex items-center justify-end gap-2 pt-4 border-t border-gray-100">
      <%= link_to "취소", customers_profile_path, class: btn_classes(:secondary, :md) %>
      <%= f.submit "저장", class: btn_classes(:primary, :md) %>
    </div>
  <% end %>
</div>
