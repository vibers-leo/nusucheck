<%# 프로필 수정 %>

<!-- 헤더 -->
<div class="mb-5">
  <%= link_to customers_profile_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    돌아가기
  <% end %>
  <h1 class="text-xl font-bold text-gray-900">프로필 수정</h1>
</div>

<div class="bg-white rounded-2xl border border-gray-100 p-5" data-controller="address-search">
  <%= form_with(model: @customer, url: customers_profile_path, method: :patch, class: "space-y-5") do |f| %>

    <%= render "shared/form_errors", resource: @customer %>

    <!-- 닉네임 -->
    <div>
      <%= f.label :name, "닉네임", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            placeholder: "물방울1234",
            class: input_classes(:text) %>
      <p class="mt-1 text-xs text-gray-500">다른 사람에게 표시되는 이름이에요.</p>
    </div>

    <!-- 전화번호 -->
    <div>
      <%= f.label :phone, "전화번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :phone,
            placeholder: "010-1234-5678",
            class: input_classes(:text),
            pattern: "01[016789]-?\\d{3,4}-?\\d{4}" %>
      <p class="mt-1 text-xs text-gray-500">하이픈(-)은 선택사항이에요.</p>
    </div>

    <!-- 주소 -->
    <div>
      <%= f.label :address, "주소", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="flex gap-2 items-center">
        <%= f.text_field :address,
              placeholder: "주소를 검색해주세요",
              readonly: true,
              data: { address_search_target: "address", action: "click->address-search#open" },
              class: "flex-1 #{input_classes(:text)} cursor-pointer" %>
        <button type="button"
                data-action="click->address-search#open"
                class="flex-shrink-0 px-4 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition-colors whitespace-nowrap">
          검색
        </button>
      </div>
      <p class="mt-1 text-xs text-gray-500">자주 사용하는 주소를 등록해두면 편리해요.</p>
    </div>

    <!-- 제출 버튼 -->
    <div class="flex items-center justify-end gap-2 pt-4 border-t border-gray-100">
      <%= link_to "취소", customers_profile_path, class: btn_classes(:secondary, :md) %>
      <%= f.submit "저장", class: btn_classes(:primary, :md) %>
    </div>
  <% end %>
</div>
