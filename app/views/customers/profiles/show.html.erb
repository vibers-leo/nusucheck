<%# 당근마켓 스타일 마이페이지 %>

<!-- 프로필 카드 -->
<div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
  <div class="flex items-center gap-4">
    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center flex-shrink-0">
      <span class="text-white font-bold text-xl"><%= @customer.name&.first || "고" %></span>
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="text-lg font-bold text-gray-900"><%= @customer.name || "이름 없음" %></h1>
      <p class="text-sm text-gray-500"><%= @customer.email %></p>
    </div>
    <%= link_to edit_customers_profile_path, class: "flex-shrink-0 px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors" do %>
      프로필 수정
    <% end %>
  </div>
</div>

<!-- 나의 활동 통계 -->
<div class="grid grid-cols-3 gap-3 mb-4">
  <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= @customer.requests.count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">체크 접수</p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
    <p class="text-2xl font-bold text-green-600"><%= @customer.requests.where(status: "closed").count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">완료</p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
    <p class="text-2xl font-bold text-purple-600"><%= Review.where(customer: @customer).count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">리뷰</p>
  </div>
</div>

<!-- 내 정보 -->
<div class="bg-white rounded-2xl border border-gray-100 mb-4">
  <h2 class="px-4 pt-4 pb-2 text-sm font-bold text-gray-500">내 정보</h2>
  <div class="divide-y divide-gray-100">
    <div class="px-4 py-3 flex items-center justify-between">
      <span class="text-sm text-gray-500">이름</span>
      <span class="text-sm font-medium text-gray-900"><%= @customer.name || "-" %></span>
    </div>
    <div class="px-4 py-3 flex items-center justify-between">
      <span class="text-sm text-gray-500">전화번호</span>
      <span class="text-sm font-medium text-gray-900"><%= @customer.phone || "-" %></span>
    </div>
    <div class="px-4 py-3 flex items-center justify-between">
      <span class="text-sm text-gray-500">주소</span>
      <span class="text-sm font-medium text-gray-900 text-right max-w-[60%] truncate"><%= @customer.address || "-" %></span>
    </div>
  </div>
</div>

<!-- 메뉴 리스트 -->
<div class="bg-white rounded-2xl border border-gray-100 mb-4">
  <h2 class="px-4 pt-4 pb-2 text-sm font-bold text-gray-500">나의 서비스</h2>
  <div class="divide-y divide-gray-100">
    <%= link_to customers_requests_path, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-primary-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <span class="text-[15px] text-gray-900">내 체크 내역</span>
      </div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <%= link_to customers_insurance_claims_path, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-purple-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <span class="text-[15px] text-gray-900">보험 신청 내역</span>
      </div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <%= link_to new_leak_inspection_path, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <span class="text-[15px] text-gray-900">AI 누수 진단</span>
      </div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>
</div>

<!-- 설정 메뉴 -->
<div class="bg-white rounded-2xl border border-gray-100 mb-4">
  <h2 class="px-4 pt-4 pb-2 text-sm font-bold text-gray-500">설정</h2>
  <div class="divide-y divide-gray-100">
    <%= link_to edit_customers_profile_path, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <span class="text-[15px] text-gray-900">프로필 수정</span>
      </div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <%= link_to edit_user_registration_path, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <span class="text-[15px] text-gray-900">비밀번호 변경</span>
      </div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>

    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center justify-between px-4 py-3.5 list-item-touch" do %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        </div>
        <span class="text-[15px] text-red-600">로그아웃</span>
      </div>
    <% end %>
  </div>
</div>
