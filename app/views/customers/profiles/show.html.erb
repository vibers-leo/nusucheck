<%# 당근마켓 마이당근 스타일 - 고객 마이페이지 %>
<% content_for :title, "마이페이지" %>

<%
  total_requests  = @customer.requests.count
  completed_count = @customer.requests.where(status: "closed").count
  review_count    = Review.where(customer: @customer).count
  active_count    = @customer.requests.where.not(status: ["closed", "cancelled"]).count
%>

<div class="max-w-lg mx-auto pb-24">

  <!-- ① 프로필 카드 (아바타 + 닉네임, 탭하면 상세 펼침) -->
  <div class="bg-white rounded-2xl border border-gray-100 mb-4 shadow-sm overflow-hidden">
    <button onclick="toggleProfileDetail(this)"
            class="w-full flex items-center gap-4 p-5 active:bg-gray-50 transition-colors text-left">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-2xl font-bold text-white flex-shrink-0">
        <%= @customer.name&.first || "고" %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-bold text-gray-900 text-lg truncate"><%= @customer.name || "이름 없음" %></p>
        <p class="text-xs text-gray-400 mt-0.5">고객</p>
      </div>
      <svg class="w-5 h-5 text-gray-300 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>

    <!-- 펼쳐지는 인증 정보 + 프로필 수정 -->
    <div class="hidden border-t border-gray-50 divide-y divide-gray-50">
      <div class="flex items-center justify-between px-5 py-3.5">
        <span class="text-sm text-gray-500 flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          본인인증
        </span>
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-100 text-gray-400">미인증</span>
      </div>
      <div class="flex items-center justify-between px-5 py-3.5">
        <span class="text-sm text-gray-500 flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
          </svg>
          가입 이메일
        </span>
        <span class="text-xs text-gray-400 truncate max-w-[55%] text-right"><%= @customer.email %></span>
      </div>
      <%# 소셜 로그인 연동 상태 %>
      <div class="flex items-center justify-between px-5 py-3.5 border-t border-gray-50">
        <span class="text-sm text-gray-500 flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M9 0.6C4.03 0.6 0 3.713 0 7.55C0 9.944 1.558 12.065 3.93 13.325L2.933 16.93C2.845 17.246 3.213 17.496 3.486 17.31L7.873 14.39C8.242 14.43 8.617 14.45 9 14.45C13.97 14.45 18 11.337 18 7.55C18 3.713 13.97 0.6 9 0.6Z" fill="<%= @customer.provider == 'kakao' ? '#191919' : '#D1D5DB' %>"/>
          </svg>
          카카오
        </span>
        <% if @customer.provider == "kakao" %>
          <span class="text-xs font-semibold text-yellow-600 bg-yellow-50 px-2 py-0.5 rounded-full">연동됨</span>
        <% else %>
          <%= button_to user_kakao_omniauth_authorize_path, method: :post, data: { turbo: false },
                class: "text-xs font-semibold text-primary-600 bg-primary-50 px-2.5 py-0.5 rounded-full hover:bg-primary-100 transition" do %>
            연동하기
          <% end %>
        <% end %>
      </div>
      <div class="flex items-center justify-between px-5 py-3.5 border-t border-gray-50">
        <span class="text-sm text-gray-500 flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <path d="M13.5 10.6L6.2 0H0v20h6.5V9.4L13.8 20H20V0h-6.5v10.6z" fill="<%= @customer.provider == 'naver' ? '#03C75A' : '#D1D5DB' %>"/>
          </svg>
          네이버
        </span>
        <% if @customer.provider == "naver" %>
          <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">연동됨</span>
        <% elsif respond_to?(:user_naver_omniauth_authorize_path) %>
          <%= button_to user_naver_omniauth_authorize_path, method: :post, data: { turbo: false },
                class: "text-xs font-semibold text-primary-600 bg-primary-50 px-2.5 py-0.5 rounded-full hover:bg-primary-100 transition" do %>
            연동하기
          <% end %>
        <% end %>
      </div>
      <div class="px-5 py-3">
        <%= link_to edit_customers_profile_path, class: "flex items-center justify-center gap-2 w-full py-2.5 bg-primary-50 text-primary-600 rounded-xl text-sm font-semibold hover:bg-primary-100 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          프로필 수정
        <% end %>
      </div>
    </div>
  </div>

  <!-- ② 활동 통계 -->
  <div class="grid grid-cols-3 gap-3 mb-5">
    <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center shadow-sm">
      <p class="text-2xl font-bold text-gray-900"><%= total_requests %></p>
      <p class="text-[11px] text-gray-500 mt-0.5">전체 접수</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center shadow-sm">
      <p class="text-2xl font-bold text-green-600"><%= completed_count %></p>
      <p class="text-[11px] text-gray-500 mt-0.5">완료</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center shadow-sm">
      <p class="text-2xl font-bold text-amber-500"><%= review_count %></p>
      <p class="text-[11px] text-gray-500 mt-0.5">리뷰</p>
    </div>
  </div>

  <!-- ③ 나의 서비스 -->
  <div class="bg-white rounded-2xl border border-gray-100 mb-4 shadow-sm overflow-hidden">
    <h2 class="px-4 pt-4 pb-2 text-sm font-bold text-gray-500">나의 서비스</h2>
    <div class="divide-y divide-gray-50">

      <%= link_to customers_requests_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <div>
            <p class="text-[15px] font-medium text-gray-900">내 체크 내역</p>
            <p class="text-xs text-gray-400">전체 <%= total_requests %>건 · 완료 <%= completed_count %>건</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <% if active_count > 0 %>
            <span class="inline-flex items-center justify-center w-5 h-5 bg-primary-600 text-white text-[10px] font-bold rounded-full"><%= active_count %></span>
          <% end %>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>

      <%= link_to customers_insurance_claims_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-purple-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <p class="text-[15px] font-medium text-gray-900">보험 신청 내역</p>
            <p class="text-xs text-gray-400">누수 보험청구 서류 자동화</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <div>
            <p class="text-[15px] font-medium text-gray-900">AI 사전점검</p>
            <p class="text-xs text-gray-400">사진/영상으로 전문가 사전 확인</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to new_feedback_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div>
            <p class="text-[15px] font-medium text-gray-900">의견 보내기</p>
            <p class="text-xs text-gray-400">서비스 개선 의견을 알려주세요</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

    </div>
  </div>

  <!-- ④ 설정 -->
  <div class="bg-white rounded-2xl border border-gray-100 mb-4 shadow-sm overflow-hidden">
    <h2 class="px-4 pt-4 pb-2 text-sm font-bold text-gray-500">설정</h2>
    <div class="divide-y divide-gray-50">

      <%= link_to edit_customers_profile_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <span class="text-[15px] font-medium text-gray-900">프로필 수정</span>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to notifications_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <span class="text-[15px] font-medium text-gray-900">알림 내역</span>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

      <%= link_to edit_user_registration_path, class: "flex items-center justify-between px-4 py-3.5 active:bg-gray-50 transition-colors" do %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <span class="text-[15px] font-medium text-gray-900">비밀번호 변경</span>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>

    </div>
  </div>

  <!-- ⑤ 로그아웃 -->
  <div class="bg-white rounded-2xl border border-gray-100 mb-4 shadow-sm overflow-hidden">
    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center justify-between px-4 py-4 active:bg-red-50 transition-colors" do %>
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-red-50 rounded-xl flex items-center justify-center">
          <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </div>
        <span class="text-[15px] font-medium text-red-600">로그아웃</span>
      </div>
    <% end %>
  </div>

  <p class="text-center text-xs text-gray-300 pb-2">누수체크 v1.0</p>

</div>

<script>
  function toggleProfileDetail(btn) {
    var detail = btn.nextElementSibling;
    var chevron = btn.querySelector('svg:last-of-type');
    var isHidden = detail.classList.contains('hidden');
    detail.classList.toggle('hidden', !isHidden);
    if (chevron) chevron.style.transform = isHidden ? 'rotate(90deg)' : '';
  }
</script>
