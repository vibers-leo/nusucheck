<%# 당근마켓 스타일 고객 대시보드 %>

<!-- 인사말 -->
<div class="mb-6">
  <h1 class="text-xl font-bold text-gray-900">
    <%= current_user.name || current_user.email %>님, 안녕하세요
  </h1>
  <p class="text-sm text-gray-500 mt-0.5">누수체크 고객 대시보드</p>
</div>

<!-- 빠른 액션 (수평 스크롤) -->
<div class="flex gap-3 mb-6 overflow-x-auto pb-1 -mx-1 px-1">
  <%= link_to new_customers_request_path, class: "flex-shrink-0 flex items-center gap-2 px-4 py-2.5 bg-primary-600 text-white rounded-xl font-semibold text-sm hover:bg-primary-700 transition-colors", data: { turbo: false } do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    새 체크 접수
  <% end %>
  <%= link_to new_leak_inspection_path, class: "flex-shrink-0 flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition-colors" do %>
    AI 진단
  <% end %>
  <%= link_to customers_insurance_claims_path, class: "flex-shrink-0 flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition-colors" do %>
    보험 신청
  <% end %>
</div>

<!-- 미니 통계 -->
<div class="grid grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= @active_requests.count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">진행중</p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= @pending_estimates.count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">견적 대기</p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-gray-900"><%= @monthly_requests_count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">이번 달</p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-lg font-bold text-gray-900"><%= number_to_currency(@monthly_total_spent, unit: "", precision: 0) %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">지출(원)</p>
  </div>
</div>

<!-- 진행 중인 체크 리스트 -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-900">진행 중인 체크</h2>
    <%= link_to "전체 보기", customers_requests_path, class: "text-sm text-primary-600 font-medium" %>
  </div>

  <% if @active_requests.any? %>
    <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
      <% @active_requests.each do |request| %>
        <%= link_to customers_request_path(request), class: "block list-item-touch" do %>
          <div class="px-4 py-3.5">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <%= render "shared/status_badge", status: request.status %>
                  <span class="text-xs text-gray-400"><%= time_ago_in_words(request.created_at) %> 전</span>
                </div>
                <h3 class="text-[15px] font-semibold text-gray-900 truncate">
                  <%= request.symptom_type_label %> - <%= request.building_type_label %>
                </h3>
                <p class="text-sm text-gray-500 mt-0.5 truncate"><%= request.address %></p>
                <% if request.master %>
                  <p class="text-xs text-gray-400 mt-1">담당: <%= request.master.name %></p>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-300 flex-shrink-0 ml-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
          icon: "water",
          title: "진행 중인 체크가 없어요",
          description: "누수가 의심되면 지금 바로 체크하세요",
          cta_text: "새 체크 접수하기",
          cta_path: new_customers_request_path %>
  <% end %>
</div>

<!-- 최근 완료된 체크 -->
<% if @recent_completed.any? %>
  <div class="mb-6">
    <h2 class="text-base font-bold text-gray-900 mb-3">최근 완료</h2>
    <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
      <% @recent_completed.each do |request| %>
        <%= link_to customers_request_path(request), class: "block list-item-touch" do %>
          <div class="px-4 py-3.5">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-green-50 text-green-700">완료</span>
                  <span class="text-xs text-gray-400"><%= request.closed_at&.strftime("%m/%d") %></span>
                </div>
                <h3 class="text-[15px] font-semibold text-gray-900 truncate">
                  <%= request.symptom_type_label %> - <%= request.building_type_label %>
                </h3>
                <p class="text-sm text-gray-500 mt-0.5 truncate"><%= request.address %></p>
              </div>
              <% if request.can_be_reviewed? %>
                <span class="text-xs font-semibold text-primary-600 flex-shrink-0 ml-2">리뷰 작성</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- 최근 알림 -->
<% if @recent_notifications.any? %>
  <div class="mb-6">
    <h2 class="text-base font-bold text-gray-900 mb-3">최근 알림</h2>
    <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
      <% @recent_notifications.each do |notification| %>
        <div class="px-4 py-3 flex items-start gap-3">
          <div class="w-2 h-2 bg-primary-500 rounded-full mt-1.5 flex-shrink-0 <%= 'opacity-0' if notification.read? %>"></div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900"><%= notification.title %></p>
            <p class="text-xs text-gray-500 mt-0.5 truncate"><%= notification.message %></p>
            <p class="text-xs text-gray-400 mt-1"><%= time_ago_in_words(notification.created_at) %> 전</p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- 이용 가이드 -->
<div class="bg-primary-50 rounded-2xl p-5">
  <h3 class="text-sm font-bold text-gray-900 mb-3">이용 가이드</h3>
  <ul class="space-y-2 text-sm text-gray-600">
    <li class="flex items-start gap-2">
      <span class="text-primary-600 mt-0.5">&#8226;</span>
      <span>체크 접수 시 사진이나 동영상을 첨부하면 더 정확한 진단이 가능합니다</span>
    </li>
    <li class="flex items-start gap-2">
      <span class="text-primary-600 mt-0.5">&#8226;</span>
      <span>견적서는 접수 후 24시간 이내에 제공됩니다</span>
    </li>
    <li class="flex items-start gap-2">
      <span class="text-primary-600 mt-0.5">&#8226;</span>
      <span>공사 완료 후 리뷰를 작성하면 다른 고객에게 도움이 됩니다</span>
    </li>
  </ul>
</div>
