<!-- 당근마켓 스타일 고객 대시보드 -->
<div class="min-h-screen bg-gray-50 pb-20 md:pb-8">
  <div class="max-w-4xl mx-auto px-4 py-6">
    <!-- 인사 카드 -->
    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-3xl p-6 mb-6 text-white shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold mb-1">
            안녕하세요, <%= current_user.name || current_user.email.split('@').first %>님! 👋
          </h1>
          <p class="text-blue-100 text-sm">오늘도 안전한 하루 되세요</p>
        </div>
        <%= link_to customers_profile_path, class: "flex-shrink-0 w-12 h-12 bg-white bg-opacity-20 rounded-full flex items-center justify-center hover:bg-opacity-30 transition" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- 빠른 액션 (당근마켓 스타일) -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <%= link_to new_customers_request_path, class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-blue-200" do %>
        <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">누수 체크</p>
        <p class="text-xs text-gray-500 mt-1">새로 접수</p>
      <% end %>

      <%= link_to customers_requests_path, class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-blue-200" do %>
        <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">내 요청</p>
        <p class="text-xs text-gray-500 mt-1"><%= @active_requests.count %>건</p>
      <% end %>

      <%= link_to customers_insurance_claims_path, class: "bg-white rounded-2xl p-5 text-center hover:shadow-lg transition-all border-2 border-gray-100 hover:border-blue-200" do %>
        <div class="w-14 h-14 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <p class="text-sm font-bold text-gray-900">보험 신청</p>
        <p class="text-xs text-gray-500 mt-1">간편하게</p>
      <% end %>
    </div>

    <!-- 통계 카드 (당근마켓 스타일) -->
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-blue-600"><%= @active_requests.count %></p>
        <p class="text-xs text-gray-600 mt-1">진행중</p>
      </div>

      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-orange-600"><%= @pending_estimates.count %></p>
        <p class="text-xs text-gray-600 mt-1">견적대기</p>
      </div>

      <div class="bg-white rounded-2xl p-4 text-center border-2 border-gray-100">
        <p class="text-2xl font-extrabold text-green-600"><%= @recent_completed.count %></p>
        <p class="text-xs text-gray-600 mt-1">완료</p>
      </div>
    </div>

    <!-- 진행 중인 체크 (당근마켓 스타일) -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900">진행 중인 체크</h2>
        <%= link_to "전체 보기 →", customers_requests_path, class: "text-blue-600 hover:text-blue-700 text-sm font-semibold" %>
      </div>

      <% if @active_requests.any? %>
        <div class="space-y-3">
          <% @active_requests.each do |request| %>
            <%= link_to customers_request_path(request), class: "block bg-white rounded-2xl p-5 hover:shadow-lg transition-all border-2 border-gray-100 hover:border-blue-200" do %>
              <!-- 상태 + 시간 -->
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold">
                  <%= request.status_label %>
                </span>
                <span class="text-xs text-gray-500">
                  <%= time_ago_in_words(request.created_at) %> 전
                </span>
              </div>

              <!-- 제목 -->
              <h3 class="font-bold text-gray-900 mb-2 text-base">
                <%= request.symptom_type_label %>
              </h3>

              <!-- 주소 -->
              <div class="flex items-start gap-2 mb-3">
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <p class="text-sm text-gray-600 line-clamp-1"><%= request.address %></p>
              </div>

              <!-- 담당 전문가 -->
              <% if request.master %>
                <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-xl">
                  <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                  <div class="flex-1">
                    <p class="text-xs text-gray-500">담당 전문가</p>
                    <p class="text-sm font-semibold text-gray-900"><%= request.master.name || request.master.email.split('@').first %></p>
                  </div>
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              <% else %>
                <div class="p-3 bg-orange-50 rounded-xl border border-orange-200">
                  <p class="text-sm text-orange-800 font-medium">⏳ 전문가 매칭 중...</p>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-2xl p-10 text-center border-2 border-dashed border-gray-200">
          <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <p class="text-gray-600 mb-4 font-medium">진행 중인 체크가 없어요</p>
          <p class="text-sm text-gray-500 mb-6">누수가 의심되면 바로 체크하세요!</p>
          <%= link_to new_customers_request_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition-all font-bold shadow-md" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>새 체크 접수하기</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- 최근 완료된 체크 -->
    <% if @recent_completed.any? %>
      <div class="mb-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">최근 완료</h2>
        <div class="space-y-3">
          <% @recent_completed.each do |request| %>
            <%= link_to customers_request_path(request), class: "block bg-white rounded-2xl p-4 hover:shadow-lg transition-all border-2 border-gray-100 hover:border-green-200" do %>
              <div class="flex items-center justify-between mb-2">
                <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">
                  ✓ 완료
                </span>
                <span class="text-xs text-gray-500">
                  <%= request.closed_at.strftime("%m/%d") %>
                </span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1 text-sm">
                <%= request.symptom_type_label %>
              </h3>
              <p class="text-xs text-gray-600 line-clamp-1"><%= request.address %></p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- 도움말 카드 -->
    <div class="bg-blue-50 rounded-2xl p-5 border-2 border-blue-100">
      <h3 class="text-sm font-bold text-blue-900 mb-3 flex items-center gap-2">
        <span>💡</span>
        <span>이용 가이드</span>
      </h3>
      <ul class="space-y-2 text-xs text-blue-800">
        <li class="flex items-start gap-2">
          <span class="text-blue-600 font-bold">•</span>
          <span>영상 첨부 시 더 정확한 진단이 가능해요</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-600 font-bold">•</span>
          <span>견적은 24시간 이내에 제공됩니다</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-600 font-bold">•</span>
          <span>완료 후 리뷰로 다른 고객을 도와주세요</span>
        </li>
      </ul>
    </div>
  </div>
</div>
