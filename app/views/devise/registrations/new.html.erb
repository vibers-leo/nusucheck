<div class="max-w-md mx-auto py-8">
  <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">회원가입</h1>
      <p class="mt-2 text-gray-500">이메일과 비밀번호만 입력하세요</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 border border-red-100 rounded-2xl p-4">
          <div class="flex items-center mb-2">
            <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-red-700 font-semibold text-sm"><%= pluralize(resource.errors.count, "개의 오류") %>가 있습니다</span>
          </div>
          <ul class="list-disc list-inside text-sm text-red-600 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= f.hidden_field :type, value: "Customer" %>

      <!-- 이메일 -->
      <div>
        <label for="user_email" class="block text-sm font-semibold text-gray-700 mb-1.5">이메일 <span class="text-red-500">*</span></label>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "your@email.com",
            class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
      </div>

      <!-- 비밀번호 -->
      <div>
        <label for="user_password" class="block text-sm font-semibold text-gray-700 mb-1.5">비밀번호 <span class="text-red-500">*</span></label>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "6자 이상",
            class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
        <p class="mt-1 text-xs text-gray-500">최소 6자 이상</p>
      </div>

      <!-- 비밀번호 확인 -->
      <div>
        <label for="user_password_confirmation" class="block text-sm font-semibold text-gray-700 mb-1.5">비밀번호 확인 <span class="text-red-500">*</span></label>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "비밀번호 다시 입력",
            class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
      </div>

      <!-- 가입 버튼 -->
      <div class="pt-2">
        <%= f.submit "가입하기", class: "w-full h-12 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <!-- 카카오 로그인 -->
    <div class="mt-6">
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">또는</span>
        </div>
      </div>

      <%= button_to "카카오로 3초만에 시작", user_kakao_omniauth_authorize_path, method: :post,
            data: { turbo: false },
            class: "mt-4 w-full h-12 bg-yellow-400 text-gray-900 font-bold rounded-xl hover:bg-yellow-500 transition-colors flex items-center justify-center gap-2" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 3c5.799 0 10.5 3.664 10.5 8.185 0 4.52-4.701 8.184-10.5 8.184a13.5 13.5 0 0 1-1.727-.11l-4.408 2.883c-.501.265-.678.236-.472-.413l.892-3.678c-2.88-1.46-4.785-3.99-4.785-6.866C1.5 6.665 6.201 3 12 3z"/>
        </svg>
        카카오로 3초만에 시작
      <% end %>
    </div>

    <!-- 하단 링크 -->
    <div class="mt-6 text-center text-sm text-gray-500">
      <%= render "devise/shared/links" %>
    </div>
  </div>

  <!-- 전문가 가입 안내 -->
  <div class="mt-6 p-4 bg-gray-50 rounded-2xl text-center border border-gray-200">
    <p class="text-sm text-gray-600">누수 탐지/시공 전문가이신가요?</p>
    <a href="/expert/sign_up" class="inline-flex items-center mt-1.5 text-sm font-semibold text-primary-700 hover:text-primary-800">
      전문가 가입 페이지로 이동
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>
