<div class="max-w-sm mx-auto pt-4">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">회원가입</h1>
    <p class="mt-2 text-sm text-gray-500">누수체크에 가입하고 편리하게 이용하세요</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <% if resource.errors.any? %>
      <div class="bg-red-50 border border-red-100 rounded-2xl p-4">
        <div class="flex items-center mb-2">
          <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-red-700 font-semibold text-sm"><%= pluralize(resource.errors.count, "개의 오류") %>가 있습니다</span>
        </div>
        <ul class="list-disc list-inside text-sm text-red-600 space-y-1">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :type, value: "Customer" %>

    <!-- 이름 -->
    <div>
      <label for="user_name" class="block text-sm font-semibold text-gray-700 mb-1.5">이름 <span class="text-red-500">*</span></label>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "홍길동",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
    </div>

    <!-- 이메일 -->
    <div>
      <label for="user_email" class="block text-sm font-semibold text-gray-700 mb-1.5">이메일 <span class="text-red-500">*</span></label>
      <%= f.email_field :email, autocomplete: "email", placeholder: "example@email.com",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
    </div>

    <!-- 비밀번호 -->
    <div>
      <label for="user_password" class="block text-sm font-semibold text-gray-700 mb-1.5">비밀번호 <span class="text-red-500">*</span></label>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "6자 이상 입력",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
      <p class="mt-1 text-xs text-gray-400">
        <% if @minimum_password_length %>
          최소 <%= @minimum_password_length %>자 이상
        <% end %>
      </p>
    </div>

    <!-- 비밀번호 확인 -->
    <div>
      <label for="user_password_confirmation" class="block text-sm font-semibold text-gray-700 mb-1.5">비밀번호 확인 <span class="text-red-500">*</span></label>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "비밀번호를 다시 입력",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
    </div>

    <!-- 안내 -->
    <div class="bg-primary-50 rounded-2xl p-4">
      <p class="text-sm text-primary-800 flex items-start gap-2">
        <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <span>필요한 정보만 받아요! 누수 체크 시 카카오톡으로 편하게 소통할 수 있어요</span>
      </p>
    </div>

    <!-- 가입 버튼 -->
    <div class="pt-1">
      <%= f.submit "회원가입", class: "w-full h-12 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <!-- 하단 링크 -->
  <div class="mt-6 text-center text-sm text-gray-500">
    <%= render "devise/shared/links" %>
  </div>

  <!-- 전문가 가입 안내 -->
  <div class="mt-4 p-4 bg-gray-50 rounded-2xl text-center">
    <p class="text-sm text-gray-600">누수 탐지/시공 전문가이신가요?</p>
    <a href="/expert" class="inline-flex items-center mt-1.5 text-sm font-semibold text-primary-700 hover:text-primary-800">
      전문가 가입 페이지로 이동
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>
