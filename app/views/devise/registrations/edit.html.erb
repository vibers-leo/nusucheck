<div class="max-w-lg mx-auto pb-24">
  <!-- 헤더 -->
  <div class="mb-5">
    <%= link_to :back, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      돌아가기
    <% end %>
    <h1 class="text-xl font-bold text-gray-900">비밀번호 변경</h1>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 p-5">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- 현재 비밀번호 -->
      <div>
        <%= f.label :current_password, "현재 비밀번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :current_password,
              autocomplete: "current-password",
              placeholder: "현재 비밀번호를 입력하세요",
              class: input_classes(:text) %>
      </div>

      <!-- 새 비밀번호 -->
      <div>
        <%= f.label :password, "새 비밀번호", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password,
              autocomplete: "new-password",
              placeholder: "새 비밀번호 (6자 이상)",
              class: input_classes(:text) %>
        <% if @minimum_password_length %>
          <p class="mt-1 text-xs text-gray-500">최소 <%= @minimum_password_length %>자 이상</p>
        <% end %>
      </div>

      <!-- 새 비밀번호 확인 -->
      <div>
        <%= f.label :password_confirmation, "새 비밀번호 확인", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "새 비밀번호를 다시 입력하세요",
              class: input_classes(:text) %>
      </div>

      <div class="flex items-center justify-end gap-2 pt-4 border-t border-gray-100">
        <%= link_to "취소", :back, class: btn_classes(:secondary, :md) %>
        <%= f.submit "비밀번호 변경", class: btn_classes(:primary, :md) %>
      </div>
    <% end %>
  </div>
</div>
