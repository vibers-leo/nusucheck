<div class="max-w-sm mx-auto pt-8">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-gray-900">로그인</h1>
    <p class="mt-2 text-sm text-gray-500">누수체크 계정으로 로그인하세요</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <% if resource.errors.any? %>
      <div class="bg-red-50 border border-red-100 rounded-2xl p-4">
        <ul class="text-sm text-red-600 space-y-1">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- 이메일 -->
    <div>
      <label for="user_email" class="block text-sm font-semibold text-gray-700 mb-1.5">이메일</label>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
    </div>

    <!-- 비밀번호 -->
    <div>
      <label for="user_password" class="block text-sm font-semibold text-gray-700 mb-1.5">비밀번호</label>
      <%= f.password_field :password, autocomplete: "current-password", placeholder: "비밀번호 입력",
          class: "w-full h-12 px-4 rounded-2xl border border-gray-200 text-base focus:border-primary-500 focus:ring-primary-500 transition-colors" %>
    </div>

    <!-- Remember Me -->
    <div class="flex items-center justify-between">
      <label class="flex items-center cursor-pointer">
        <%= f.check_box :remember_me, checked: true, class: "w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" %>
        <span class="ml-2 text-sm text-gray-600">로그인 상태 유지</span>
      </label>
      <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
        <%= link_to "비밀번호 찾기", new_password_path(resource_name), class: "text-sm text-primary-600 hover:text-primary-700 font-medium" %>
      <% end %>
    </div>

    <!-- 로그인 버튼 -->
    <div class="pt-1">
      <%= f.submit "로그인", class: "w-full h-12 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <!-- 구분선 -->
  <div class="relative my-6">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-gray-100"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-4 bg-white text-gray-400">또는</span>
    </div>
  </div>

  <!-- 소셜 로그인 -->
  <div class="space-y-3">
    <% if respond_to?(:user_kakao_omniauth_authorize_path) %>
      <%= button_to user_kakao_omniauth_authorize_path, method: :post, data: { turbo: false },
          class: "w-full h-12 rounded-xl font-bold text-sm flex items-center justify-center gap-2 transition-colors cursor-pointer",
          style: "background-color: #FEE500; color: #191919;" do %>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M9 0.6C4.03 0.6 0 3.713 0 7.55C0 9.944 1.558 12.065 3.93 13.325L2.933 16.93C2.845 17.246 3.213 17.496 3.486 17.31L7.873 14.39C8.242 14.43 8.617 14.45 9 14.45C13.97 14.45 18 11.337 18 7.55C18 3.713 13.97 0.6 9 0.6Z" fill="#191919"/>
        </svg>
        카카오로 시작
      <% end %>
    <% end %>

    <% if respond_to?(:user_naver_omniauth_authorize_path) %>
      <%= button_to user_naver_omniauth_authorize_path, method: :post, data: { turbo: false },
          class: "w-full h-12 rounded-xl font-bold text-sm flex items-center justify-center gap-2 transition-colors cursor-pointer",
          style: "background-color: #03C75A; color: #FFFFFF;" do %>
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
          <path d="M13.5 10.6L6.2 0H0v20h6.5V9.4L13.8 20H20V0h-6.5v10.6z" fill="#FFFFFF"/>
        </svg>
        네이버로 시작
      <% end %>
    <% end %>

    <% if respond_to?(:user_google_oauth2_omniauth_authorize_path) %>
      <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
          class: "w-full h-12 rounded-xl font-bold text-sm flex items-center justify-center gap-2 transition-colors cursor-pointer border border-gray-200 hover:bg-gray-50",
          style: "background-color: #FFFFFF; color: #3c4043;" do %>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Google로 시작
      <% end %>
    <% end %>
  </div>

  <!-- 회원가입 링크 -->
  <div class="text-center mt-6">
    <p class="text-sm text-gray-500">
      아직 계정이 없으신가요?
      <%= link_to "회원가입", new_registration_path(resource_name), class: "text-primary-600 hover:text-primary-700 font-semibold ml-1" %>
    </p>
  </div>
</div>
