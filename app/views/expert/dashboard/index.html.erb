<%# 당근마켓 스타일 전문가 대시보드 %>

<!-- 인사말 + 공개 오더 -->
<div class="flex items-center justify-between mb-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900"><%= current_user.name %>님</h1>
    <p class="text-sm text-gray-500 mt-0.5">오늘도 화이팅하세요</p>
  </div>
  <%= link_to open_orders_masters_requests_path, class: "flex items-center gap-1.5 px-3.5 py-2 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition-colors" do %>
    공개 오더
    <% if @open_orders_count > 0 %>
      <span class="bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center"><%= @open_orders_count %></span>
    <% end %>
  <% end %>
</div>

<!-- 수익 카드 -->
<div class="bg-gradient-to-br from-primary-600 to-primary-800 rounded-2xl p-5 mb-4">
  <p class="text-sm text-primary-100 mb-1">이번 달 수익</p>
  <p class="text-3xl font-extrabold text-white"><%= number_to_currency(@monthly_settled, unit: "", precision: 0) %><span class="text-lg ml-0.5">원</span></p>
  <div class="flex items-center gap-4 mt-3 text-sm text-primary-200">
    <span>완료 <%= @monthly_completed %>건</span>
    <% if @pending_payout > 0 %>
      <span class="text-yellow-200">지급대기 <%= number_to_currency(@pending_payout, unit: "", precision: 0) %>원</span>
    <% end %>
  </div>
</div>

<!-- 통계 3칸 -->
<div class="grid grid-cols-3 gap-3 mb-4">
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-primary-600"><%= @active_requests.size %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">진행중</p>
  </div>
  <%
    estimate_pending_count = current_user.assigned_requests
                                         .where(status: :estimate_pending)
                                         .count
  %>
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-orange-600"><%= estimate_pending_count %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">견적 대기</p>
  </div>
  <%
    total_reviews = current_user.assigned_requests.joins(:review).count
    avg_rating = total_reviews > 0 ? current_user.assigned_requests.joins(:review).average('reviews.rating').to_f : 4.8
    manner_temp = (avg_rating * 10).round(1)
  %>
  <div class="bg-white rounded-2xl border border-gray-100 p-3 text-center">
    <p class="text-2xl font-bold text-green-600"><%= manner_temp %></p>
    <p class="text-[11px] text-gray-500 mt-0.5">매너온도</p>
  </div>
</div>

<!-- 진행 중인 오더 -->
<div class="mb-4">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-bold text-gray-900">진행 중인 오더</h2>
    <%= link_to "전체 보기", masters_requests_path, class: "text-sm text-primary-600 font-medium" %>
  </div>

  <% if @active_requests.empty? %>
    <%= render "shared/empty_state",
          icon: "water",
          title: "진행 중인 오더가 없어요",
          description: "공개 오더에서 새로운 건을 찾아보세요",
          cta_text: "공개 오더 보기",
          cta_path: open_orders_masters_requests_path %>
  <% else %>
    <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
      <% @active_requests.each do |req| %>
        <%= link_to masters_request_path(req), class: "block list-item-touch" do %>
          <div class="px-4 py-3.5">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <%= render "shared/status_badge", status: req.status %>
                  <span class="text-xs text-gray-400">#<%= req.id %></span>
                </div>
                <h3 class="text-[15px] font-semibold text-gray-900 truncate">
                  <%= symptom_label(req.symptom_type) %>
                </h3>
                <p class="text-sm text-gray-500 mt-0.5 truncate"><%= req.address.truncate(30) %></p>
                <% if req.preferred_date %>
                  <p class="text-xs text-gray-400 mt-1">방문 예정: <%= req.preferred_date.strftime("%m/%d %H:%M") %></p>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-300 flex-shrink-0 ml-2 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- 최근 완료 -->
<% if @recent_completed.any? %>
  <div class="mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-bold text-gray-900">최근 완료</h2>
      <%= link_to "정산 내역", expert_settlements_path, class: "text-sm text-primary-600 font-medium" %>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
      <% @recent_completed.each do |req| %>
        <%= link_to masters_request_path(req), class: "block list-item-touch" do %>
          <div class="px-4 py-3.5">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-green-50 text-green-700">완료</span>
                  <span class="text-xs text-gray-400">#<%= req.id %></span>
                </div>
                <h3 class="text-[15px] font-semibold text-gray-900 truncate">
                  <%= symptom_label(req.symptom_type) %>
                </h3>
                <p class="text-sm text-gray-500 mt-0.5 truncate"><%= req.address.truncate(30) %></p>
                <% settled_amount = req.escrow_transactions.where(status: :settled).sum(:master_payout) %>
                <% if settled_amount > 0 %>
                  <p class="text-xs font-medium text-green-600 mt-1">정산: <%= number_to_currency(settled_amount, unit: "", precision: 0) %>원</p>
                <% end %>
              </div>
              <div class="flex flex-col items-end flex-shrink-0 ml-2">
                <% if req.review %>
                  <div class="flex items-center text-yellow-500">
                    <% req.review.rating.times do %>
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    <% end %>
                  </div>
                <% end %>
                <svg class="w-5 h-5 text-gray-300 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- 빠른 메뉴 -->
<div class="bg-white rounded-2xl border border-gray-100 p-4">
  <h2 class="text-sm font-bold text-gray-500 mb-3">빠른 메뉴</h2>
  <div class="grid grid-cols-4 gap-3">
    <%= link_to open_orders_masters_requests_path, class: "flex flex-col items-center gap-1.5 p-2 rounded-xl hover:bg-gray-50 transition-colors" do %>
      <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <span class="text-xs text-gray-700 text-center">공개 오더</span>
    <% end %>

    <%= link_to masters_requests_path, class: "flex flex-col items-center gap-1.5 p-2 rounded-xl hover:bg-gray-50 transition-colors" do %>
      <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <span class="text-xs text-gray-700 text-center">내 오더</span>
    <% end %>

    <%= link_to expert_settlements_path, class: "flex flex-col items-center gap-1.5 p-2 rounded-xl hover:bg-gray-50 transition-colors" do %>
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <span class="text-xs text-gray-700 text-center">정산 내역</span>
    <% end %>

    <%= link_to edit_masters_profile_path, class: "flex flex-col items-center gap-1.5 p-2 rounded-xl hover:bg-gray-50 transition-colors" do %>
      <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
      </div>
      <span class="text-xs text-gray-700 text-center">내 프로필</span>
    <% end %>
  </div>
</div>
