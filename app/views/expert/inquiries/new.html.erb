<div class="max-w-lg mx-auto py-4">

  <% if flash[:notice] %>
    <!-- 접수 완료 -->
    <div class="bg-primary-50 border border-primary-100 rounded-2xl p-8 text-center">
      <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-900 mb-2">문의가 접수되었습니다</h2>
      <p class="text-sm text-gray-500 leading-relaxed">검토 후 입력하신 연락처로 개별 연락드리겠습니다.<br>보통 1~3 영업일 내에 연락드립니다.</p>
      <%= link_to "홈으로", root_path, class: "inline-flex mt-6 px-6 py-2.5 bg-primary-500 text-white text-sm font-semibold rounded-xl hover:bg-primary-600 transition-colors" %>
    </div>

  <% else %>
    <!-- 문의 폼 -->
    <div class="mb-5">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-wider mb-1">전문가 등록</p>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">파트너 전문가 문의</h1>
      <p class="text-sm text-gray-500 leading-relaxed">
        누수체크 파트너 전문가는 <strong>검수 후 개별 등록</strong>으로 진행됩니다.<br>
        아래 양식을 작성해주시면 담당자가 확인 후 연락드립니다.
      </p>
    </div>

    <!-- 프로세스 안내 -->
    <div class="flex items-center gap-2 mb-5 text-xs text-gray-400">
      <div class="flex items-center gap-1.5">
        <span class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">1</span>
        <span>문의 접수</span>
      </div>
      <div class="flex-1 border-t border-dashed border-gray-200"></div>
      <div class="flex items-center gap-1.5">
        <span class="w-5 h-5 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">2</span>
        <span>서류 검토</span>
      </div>
      <div class="flex-1 border-t border-dashed border-gray-200"></div>
      <div class="flex items-center gap-1.5">
        <span class="w-5 h-5 bg-gray-200 text-gray-500 rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">3</span>
        <span>개별 연락 &amp; 등록</span>
      </div>
    </div>

    <!-- 등록 비용 안내 -->
    <div class="mb-5 bg-blue-50 border border-blue-100 rounded-2xl p-4 flex items-start gap-3">
      <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-blue-900 mb-0.5">등록 및 유지 비용 안내</p>
        <p class="text-sm text-blue-800">
          파트너 전문가 등록 후 <strong>월 99,000원 (VAT 포함)</strong>의 구독료가 발생합니다.
        </p>
        <p class="text-xs text-blue-600 mt-1">매월 자동 결제 · 언제든 해지 가능</p>
      </div>
      <!-- 혜택 보기 버튼 -->
      <button type="button" onclick="openBenefitsModal()"
        class="flex-shrink-0 inline-flex items-center gap-1 px-3 py-1.5 bg-blue-600 text-white text-xs font-semibold rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/>
        </svg>
        혜택 보기
      </button>
    </div>

    <!-- 폼 -->
    <%= form_with url: expert_inquiry_submit_path, method: :post, class: "space-y-4" do |f| %>

      <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-50">

        <div class="px-4 py-3.5">
          <label class="block text-xs font-semibold text-gray-500 mb-1.5">이름 <span class="text-red-400">*</span></label>
          <input type="text" name="name" required placeholder="홍길동"
            class="w-full text-sm text-gray-900 border-0 p-0 focus:ring-0 placeholder-gray-300 bg-transparent">
        </div>

        <div class="px-4 py-3.5">
          <label class="block text-xs font-semibold text-gray-500 mb-1.5">연락처 <span class="text-red-400">*</span></label>
          <input type="tel" name="phone" required placeholder="010-0000-0000"
            class="w-full text-sm text-gray-900 border-0 p-0 focus:ring-0 placeholder-gray-300 bg-transparent">
        </div>

        <div class="px-4 py-3.5">
          <label class="block text-xs font-semibold text-gray-500 mb-1.5">이메일</label>
          <input type="email" name="email" placeholder="expert@email.com"
            class="w-full text-sm text-gray-900 border-0 p-0 focus:ring-0 placeholder-gray-300 bg-transparent">
        </div>

        <div class="px-4 py-3.5">
          <label class="block text-xs font-semibold text-gray-500 mb-1.5">간단 소개 <span class="text-gray-300 font-normal">(경력·전문분야 등)</span></label>
          <textarea name="message" rows="4" placeholder="예) 15년 경력 누수 탐지 전문가입니다. 서울/경기 지역 아파트 욕실·옥상 방수 공사를 주로 합니다."
            class="w-full text-sm text-gray-900 border-0 p-0 focus:ring-0 placeholder-gray-300 bg-transparent resize-none"></textarea>
        </div>

      </div>

      <button type="submit"
        class="w-full py-3.5 bg-primary-500 text-white text-sm font-bold rounded-xl hover:bg-primary-600 transition-colors shadow-sm">
        문의 접수하기
      </button>

    <% end %>

    <p class="mt-4 text-center text-xs text-gray-400">
      이미 계정이 있으신가요?
      <%= link_to "로그인", new_user_session_path, class: "text-primary-600 font-medium" %>
    </p>
  <% end %>

</div>

<!-- ── 혜택 모달 ─────────────────────────────────────────────────────── -->
<div id="benefitsModal"
     class="hidden fixed inset-0 bg-black/60 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4"
     onclick="if(event.target===this) closeBenefitsModal()">
  <div class="bg-white w-full sm:max-w-md rounded-t-3xl sm:rounded-2xl overflow-hidden shadow-2xl">

    <!-- 헤더 -->
    <div class="relative bg-gradient-to-br from-primary-600 to-blue-700 px-6 pt-6 pb-8">
      <!-- 닫기 -->
      <button onclick="closeBenefitsModal()" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/30 transition-colors">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-blue-200 font-medium">파트너 전문가 혜택</p>
          <h2 class="text-lg font-bold text-white">월 99,000원으로 누리는 것</h2>
        </div>
      </div>

      <!-- 핵심 지표 -->
      <div class="grid grid-cols-3 gap-2 mt-4">
        <div class="bg-white/15 rounded-xl p-3 text-center">
          <p class="text-xl font-bold text-white">3~5</p>
          <p class="text-[10px] text-blue-200 mt-0.5">지역당 배정 건수</p>
        </div>
        <div class="bg-white/15 rounded-xl p-3 text-center">
          <p class="text-xl font-bold text-white">우선</p>
          <p class="text-[10px] text-blue-200 mt-0.5">접수건 배정 방식</p>
        </div>
        <div class="bg-white/15 rounded-xl p-3 text-center">
          <p class="text-xl font-bold text-white">독점</p>
          <p class="text-[10px] text-blue-200 mt-0.5">구역 선점 권한</p>
        </div>
      </div>
    </div>

    <!-- 혜택 목록 -->
    <div class="px-6 py-5 space-y-4">

      <!-- 혜택 1: 구역 선점 배정 -->
      <div class="flex items-start gap-3.5">
        <div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900">담당 구역 우선 배정</p>
          <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">
            등록 시 선택한 지역에서 접수되는 누수 체크 건이 <strong>우선적으로 배정</strong>됩니다.
            지역당 <strong>3~5명</strong> 한정으로 경쟁 없이 안정적으로 일감을 확보하세요.
          </p>
        </div>
      </div>

      <!-- 혜택 2: 독점 구역 선점 -->
      <div class="flex items-start gap-3.5">
        <div class="w-9 h-9 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900">구역 선점으로 경쟁 차단</p>
          <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">
            내가 선점한 구역은 정원이 다 찰 때까지 다른 전문가가 진입할 수 없어요.
            먼저 등록할수록 <strong>유리한 구역을 선점</strong>할 수 있습니다.
          </p>
        </div>
      </div>

      <!-- 혜택 3: AI 매칭 -->
      <div class="flex items-start gap-3.5">
        <div class="w-9 h-9 bg-purple-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900">AI 사전점검 연동 고객</p>
          <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">
            AI 누수 진단을 마친 고객이 전문가 방문을 요청할 때, 담당 구역 전문가에게 <strong>자동 연결</strong>됩니다. 별도 영업 없이 고객이 찾아옵니다.
          </p>
        </div>
      </div>

      <!-- 혜택 4: 보험청구 지원 -->
      <div class="flex items-start gap-3.5">
        <div class="w-9 h-9 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900">보험청구서 자동 작성 도구</p>
          <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">
            공사 완료 후 보험청구서를 플랫폼에서 바로 작성하고 고객에게 전송할 수 있어요. PDF 자동 생성으로 <strong>고객 만족도와 재방문율</strong>을 높이세요.
          </p>
        </div>
      </div>

      <!-- 구역 현황 예시 -->
      <div class="mt-2 bg-gray-50 rounded-xl p-4">
        <p class="text-xs font-semibold text-gray-700 mb-2.5 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/>
          </svg>
          구역별 잔여 슬롯 (예시)
        </p>
        <div class="space-y-2">
          <% [
            { name: "서울 강남", used: 2, max: 3, color: "bg-primary-500" },
            { name: "서울 송파·강동", used: 1, max: 3, color: "bg-primary-500" },
            { name: "서울 마포·서대문", used: 0, max: 3, color: "bg-green-500" },
            { name: "부산 해운대", used: 0, max: 3, color: "bg-green-500" },
          ].each do |zone| %>
            <div class="flex items-center gap-2.5">
              <span class="text-xs text-gray-600 w-28 flex-shrink-0"><%= zone[:name] %></span>
              <div class="flex-1 bg-gray-200 rounded-full h-1.5">
                <div class="<%= zone[:color] %> h-1.5 rounded-full transition-all"
                     style="width: <%= (zone[:used].to_f / zone[:max] * 100).round %>%"></div>
              </div>
              <span class="text-[10px] font-semibold <%= zone[:used] >= zone[:max] ? 'text-red-400' : 'text-green-600' %> w-12 text-right flex-shrink-0">
                잔여 <%= zone[:max] - zone[:used] %>/<%= zone[:max] %>
              </span>
            </div>
          <% end %>
        </div>
        <p class="text-[10px] text-gray-400 mt-2.5">* 실제 슬롯 현황은 등록 심사 후 안내드립니다</p>
      </div>

    </div>

    <!-- 하단 CTA -->
    <div class="px-6 pb-6">
      <button onclick="closeBenefitsModal()"
        class="w-full py-3.5 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition-colors">
        알겠어요, 문의 접수할게요
      </button>
      <p class="text-center text-[11px] text-gray-400 mt-2">언제든 해지 가능 · 위약금 없음</p>
    </div>

  </div>
</div>

<script>
function openBenefitsModal() {
  document.getElementById('benefitsModal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function closeBenefitsModal() {
  document.getElementById('benefitsModal').classList.add('hidden');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeBenefitsModal();
});
</script>
