<div class="space-y-6 py-8">
  <!-- 헤더 -->
  <div class="text-center mb-8">
    <div class="inline-flex items-center px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-3">
      선착순 오더
    </div>
    <h1 class="text-3xl font-bold text-gray-900">공개 오더 목록</h1>
    <p class="mt-2 text-gray-600">먼저 수락하는 전문가가 배정됩니다</p>
  </div>

  <!-- 탭 네비게이션 -->
  <div class="flex border-b border-gray-200 mb-6">
    <%= link_to masters_requests_path, class: "px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 transition-colors" do %>
      내 진행 중 작업
    <% end %>
    <span class="px-4 py-2 text-sm font-medium text-primary-700 border-b-2 border-emerald-500">
      공개 오더
      <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold bg-primary-500 text-white rounded-full">
        <%= @requests.total_count %>
      </span>
    </span>
  </div>

  <!-- 지역 필터 토글 -->
  <% if @my_areas.any? %>
    <div class="flex items-center gap-3 p-3 bg-primary-50 border border-primary-100 rounded-xl">
      <svg class="w-5 h-5 text-primary-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
      </svg>
      <div class="flex-1 min-w-0">
        <p class="text-sm text-primary-800">
          <strong>내 서비스 지역:</strong>
          <%= @my_areas.join(", ") %>
        </p>
      </div>
      <% if @filter_my_area %>
        <%= link_to open_orders_masters_requests_path(params.permit(:q).to_h),
              class: "flex-shrink-0 px-3 py-1.5 bg-primary-600 text-white text-xs font-bold rounded-lg" do %>
          내 지역만 보는 중
        <% end %>
        <%= link_to open_orders_masters_requests_path(params.permit(:q).merge(my_area: "0").to_h),
              class: "flex-shrink-0 px-3 py-1.5 bg-white text-primary-700 border border-primary-300 text-xs font-medium rounded-lg" do %>
          전체 보기
        <% end %>
      <% else %>
        <%= link_to open_orders_masters_requests_path(params.permit(:q).merge(my_area: "1").to_h),
              class: "flex-shrink-0 px-3 py-1.5 bg-primary-600 text-white text-xs font-bold rounded-lg hover:bg-primary-700 transition" do %>
          내 지역만 보기
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- 필터 -->
  <div class="bg-white rounded-2xl border border-gray-100 p-4">
    <%= search_form_for @q, url: open_orders_masters_requests_path, html: { method: :get, class: "flex flex-col sm:flex-row gap-3" } do |f| %>
      <% if @filter_my_area %>
        <%= hidden_field_tag :my_area, "1" %>
      <% end %>
      <div class="flex-1">
        <%= f.select :symptom_type_eq,
              options_for_select([
                ["전체 증상", ""],
                ["벽면 누수", "wall_leak"],
                ["천장 누수", "ceiling_leak"],
                ["바닥 누수", "floor_leak"],
                ["배관 누수", "pipe_leak"],
                ["화장실 누수", "toilet_leak"],
                ["외부 누수", "outdoor_leak"]
              ], params.dig(:q, :symptom_type_eq)),
              {}, class: input_classes(:select) %>
      </div>
      <div class="flex-1">
        <%= f.select :building_type_eq,
              options_for_select([
                ["전체 건물 유형", ""],
                ["아파트", "apartment"],
                ["빌라/다세대", "villa"],
                ["단독주택", "house"],
                ["사무실", "office"],
                ["상가", "retail_store"],
                ["공장", "factory"],
                ["기타", "other_building"]
              ], params.dig(:q, :building_type_eq)),
              {}, class: input_classes(:select) %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "필터 적용", class: btn_classes(:primary, :md) %>
        <%= link_to "초기화", open_orders_masters_requests_path, class: btn_classes(:secondary, :md) %>
      </div>
    <% end %>
  </div>

  <!-- 오더 목록 (당근마켓 스타일) -->
  <% if @requests.any? %>
    <div class="space-y-3">
      <% @requests.each do |request| %>
        <%
          # 내 지역 여부 확인
          is_my_area = @my_areas.any? { |area| request.address.include?(area) }

          # AI 추천 예상가 계산 (간단한 로직 - 나중에 실제 AI로 대체)
          base_price = case request.symptom_type
            when "wall_leak" then 350000
            when "ceiling_leak" then 450000
            when "floor_leak" then 400000
            when "pipe_leak" then 300000
            when "toilet_leak" then 250000
            when "outdoor_leak" then 500000
            else 350000
          end

          building_multiplier = case request.building_type
            when "apartment" then 1.0
            when "villa" then 0.9
            when "house" then 1.1
            when "office", "retail_store" then 1.3
            when "factory" then 1.5
            else 1.0
          end

          estimated_price = (base_price * building_multiplier).to_i
          price_range_min = (estimated_price * 0.8).to_i
          price_range_max = (estimated_price * 1.2).to_i
        %>

        <%= link_to masters_request_path(request), class: "block bg-white rounded-2xl border-2 border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all p-5" do %>
          <!-- 헤더: 시간 + 지역 뱃지 -->
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="text-xs font-medium text-gray-500">
                <%= time_ago_in_words(request.created_at) %> 전
              </span>
              <% if is_my_area %>
                <span class="px-2 py-0.5 bg-primary-100 text-primary-700 text-xs font-bold rounded-full">
                  내 지역
                </span>
              <% end %>
            </div>
            <span class="text-xs font-mono text-gray-400">#<%= request.id %></span>
          </div>

          <!-- 제목 (증상 유형) -->
          <h3 class="text-lg font-bold text-gray-900 mb-2">
            <%= symptom_label(request.symptom_type) %>
          </h3>

          <!-- 거리 + 주소 (강조) -->
          <div class="flex items-start gap-2 mb-3">
            <svg class="w-5 h-5 text-primary-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900"><%= truncate(request.address, length: 40) %></p>
              <% if is_my_area %>
                <p class="text-xs text-primary-600 font-medium mt-0.5">🎯 가까운 지역이에요</p>
              <% end %>
            </div>
          </div>

          <!-- 건물 유형 + AI 추천가 -->
          <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-100">
            <% if request.building_type.present? %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-medium rounded-lg">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
                <%= t("activerecord.enums.request.building_type.#{request.building_type}", default: request.building_type) %>
              </span>
            <% else %>
              <div></div>
            <% end %>

            <div class="text-right">
              <p class="text-xs text-gray-500 mb-0.5">AI 예상 견적</p>
              <p class="text-sm font-bold text-purple-600">
                <%= number_to_currency(price_range_min, unit: "", precision: 0) %>~<%= number_to_currency(price_range_max, unit: "", precision: 0) %>원
              </p>
            </div>
          </div>

          <!-- 설명 -->
          <% if request.description.present? %>
            <p class="text-sm text-gray-600 line-clamp-2 mb-3">
              <%= truncate(request.description, length: 80) %>
            </p>
          <% end %>

          <!-- 액션 버튼 영역 -->
          <div class="flex gap-2 mt-4">
            <span class="flex-1 text-center px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-200 transition-colors">
              상세보기
            </span>
            <%= button_to "수락하기",
                  claim_masters_request_path(request),
                  method: :post,
                  class: "flex-1 text-center px-4 py-2.5 bg-gradient-to-r from-primary-600 to-primary-700 text-white text-sm font-bold rounded-xl hover:from-primary-700 hover:to-primary-800 transition-all shadow-md",
                  data: { confirm: "이 오더를 수락하시겠습니까? 선착순이므로 이미 다른 전문가가 수락했을 수 있습니다." },
                  form: { class: "flex-1" } %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="mt-6">
      <%= paginate @requests %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
          icon: "document",
          title: "현재 공개된 오더가 없어요",
          description: "새로운 오더가 등록되면 바로 알려드릴게요" %>

    <div class="mt-6 bg-primary-50 rounded-xl p-6 border border-emerald-100 text-center">
      <p class="text-primary-700 text-sm font-medium">
        고객이 누수 체크를 신청하면 관리자가 검토 후 공개 등록합니다.
        <br>등록 즉시 알림을 받으실 수 있도록 알림을 켜두세요.
      </p>
    </div>
  <% end %>
</div>
