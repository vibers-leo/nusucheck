<%# 전문가 - 내 작업 목록 (역할 맞춤 재설계) %>

<%
  current_status = params.dig(:q, :status_eq).to_s
  current_symptom = params.dig(:q, :symptom_type_eq).to_s
  has_filter = current_status.present? || current_symptom.present?
%>

<!-- 헤더 -->
<div class="mb-5">
  <h1 class="text-xl font-bold text-gray-900">내 작업</h1>
  <p class="text-sm text-gray-500 mt-0.5">배정된 작업을 확인하고 관리하세요</p>
</div>

<!-- 미승인 전문가 안내 -->
<% unless current_user.master_profile&.verified? %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-4 mb-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div class="flex-1">
        <h3 class="text-sm font-semibold text-yellow-900">승인 대기 중</h3>
        <p class="text-xs text-yellow-800 mt-0.5">관리자가 프로필을 검토 중이에요. 승인 완료 후 오더를 받을 수 있어요.</p>
        <%= link_to "프로필 완성하기", edit_masters_profile_path, class: "inline-block text-xs font-semibold text-yellow-900 underline mt-1" %>
      </div>
    </div>
  </div>
<% end %>

<!-- 탭: 내 작업 / 오더 피드 -->
<div class="flex gap-1 mb-4 bg-gray-100 rounded-xl p-1">
  <span class="flex-1 text-center py-2 text-sm font-semibold text-primary-700 bg-white rounded-lg shadow-sm">
    내 작업
  </span>
  <%= link_to open_orders_masters_requests_path, class: "flex-1 text-center py-2 text-sm font-medium text-gray-500 rounded-lg hover:text-gray-700 transition-colors" do %>
    오더 피드
    <% if @open_count.to_i > 0 %>
      <span class="ml-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= @open_count %></span>
    <% end %>
  <% end %>
</div>

<!-- ── 액션 필요 배너 (필터 없을 때 + 긴급 건 있을 때) ── -->
<% if !has_filter && @needs_action_count > 0 %>
  <div class="mb-4 flex items-center gap-3 p-4 bg-orange-50 border border-orange-200 rounded-2xl">
    <div class="w-9 h-9 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
    </div>
    <div class="flex-1">
      <p class="text-sm font-bold text-orange-800">입력이 필요한 작업 <%= @needs_action_count %>건</p>
      <p class="text-xs text-orange-600 mt-0.5">탐지 결과 입력 또는 견적 작성이 필요해요</p>
    </div>
  </div>
<% end %>

<!-- ── 필터 버튼 (드롭다운 없이 나열) ── -->
<div class="space-y-3 mb-5">

  <!-- 상태 필터 -->
  <div>
    <p class="text-xs font-semibold text-gray-400 mb-2">상태</p>
    <div class="flex gap-2 flex-wrap">
      <% [
        ["전체", ""],
        ["배정됨", "assigned"],
        ["방문중", "visiting"],
        ["탐지중", "detecting"],
        ["견적 작성", "estimate_pending"],
        ["공사중", "constructing"],
        ["완료 처리", "construction_completed"],
        ["종료", "closed"]
      ].each do |label, value| %>
        <%
          is_active = current_status == value || (value.empty? && current_status.empty?)
          href = masters_requests_path(q: { status_eq: value.presence, symptom_type_eq: current_symptom.presence }.compact)
        %>
        <%= link_to label, href,
              class: "flex-none px-3.5 py-1.5 rounded-full text-xs font-semibold transition-colors #{
                is_active ? 'bg-primary-500 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:border-primary-300 hover:text-primary-600'
              }" %>
      <% end %>
    </div>
  </div>

  <!-- 증상 필터 -->
  <div>
    <p class="text-xs font-semibold text-gray-400 mb-2">증상</p>
    <div class="flex gap-2 flex-wrap">
      <% [
        ["전체", ""],
        ["벽면 💧", "wall_leak"],
        ["천장 💧", "ceiling_leak"],
        ["바닥 💧", "floor_leak"],
        ["배관 🔧", "pipe_leak"],
        ["화장실 🚽", "toilet_leak"],
        ["외부 🏠", "outdoor_leak"]
      ].each do |label, value| %>
        <%
          is_active = current_symptom == value || (value.empty? && current_symptom.empty?)
          href = masters_requests_path(q: { status_eq: current_status.presence, symptom_type_eq: value.presence }.compact)
        %>
        <%= link_to label, href,
              class: "flex-none px-3.5 py-1.5 rounded-full text-xs font-semibold transition-colors #{
                is_active ? 'bg-primary-500 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:border-primary-300 hover:text-primary-600'
              }" %>
      <% end %>
    </div>
  </div>
</div>

<!-- ── 작업 리스트 ── -->
<% if @requests.any? %>
  <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-50">
    <% @requests.each do |request| %>
      <%= link_to masters_request_path(request), class: "block hover:bg-gray-50 transition-colors" do %>
        <div class="px-4 py-4">
          <div class="flex items-start gap-3">
            <!-- 영상/사진 썸네일 -->
            <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-100 flex-shrink-0">
              <% if request.videos.attached? %>
                <div class="w-full h-full bg-gray-800 flex items-center justify-center relative">
                  <video src="<%= rails_blob_url(request.videos.first) %>" class="w-full h-full object-cover" preload="metadata"></video>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-6 h-6 bg-white/70 rounded-full flex items-center justify-center">
                      <svg class="w-3 h-3 text-gray-800 ml-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
                      </svg>
                    </div>
                  </div>
                </div>
              <% elsif request.photos.attached? %>
                <%= image_tag rails_blob_url(request.photos.first), class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <%= render "shared/status_badge", status: request.status %>
                <% if %w[detecting estimate_pending].include?(request.status) %>
                  <span class="text-[10px] font-bold text-orange-500 bg-orange-50 px-1.5 py-0.5 rounded-full">입력 필요</span>
                <% end %>
              </div>

              <h3 class="text-[15px] font-semibold text-gray-900 mb-1">
                <%= symptom_label(request.symptom_type) %>
                <span class="text-gray-400 font-normal">· <%= request.customer&.name || "고객" %></span>
              </h3>

              <div class="flex items-center gap-2 text-xs text-gray-400">
                <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="truncate"><%= truncate(request.address, length: 22) %></span>
                <% if request.assigned_at.present? %>
                  <span class="text-gray-200 flex-shrink-0">·</span>
                  <span class="flex-shrink-0"><%= request.assigned_at.strftime("%m.%d") %> 배정</span>
                <% end %>
              </div>

              <!-- 내가 해야 할 것 힌트 -->
              <%
                master_hint = case request.status
                when "assigned"               then "방문 일정을 잡아주세요"
                when "visiting"               then "현장 도착 후 탐지를 시작하세요"
                when "detecting"              then "탐지 결과를 입력해주세요"
                when "estimate_pending"       then "견적서를 작성해주세요"
                when "estimate_submitted"     then "고객의 견적 수락을 기다리는 중이에요"
                when "construction_agreed",
                     "escrow_deposited"       then "공사를 시작할 준비가 됐어요"
                when "constructing"           then "공사 완료 후 보고해주세요"
                when "construction_completed" then "고객의 최종 확인을 기다리는 중이에요"
                end
              %>
              <% if master_hint %>
                <p class="mt-1.5 text-xs font-semibold <%= %w[detecting estimate_pending].include?(request.status) ? 'text-orange-500' : 'text-primary-500' %>">
                  → <%= master_hint %>
                </p>
              <% end %>
            </div>

            <svg class="w-4 h-4 text-gray-300 flex-shrink-0 ml-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-6">
    <%= paginate @requests %>
  </div>

<% else %>
  <%= render "shared/empty_state",
        icon: "water",
        title: has_filter ? "해당 조건의 작업이 없어요" : "현재 배정된 작업이 없어요",
        description: has_filter ? "다른 필터를 선택해보세요" : "오더 피드에서 새로운 건을 찾아보세요",
        cta_text: has_filter ? "전체 보기" : "오더 피드 보기",
        cta_path: has_filter ? masters_requests_path : open_orders_masters_requests_path %>

  <% unless has_filter %>
    <div class="mt-4 bg-primary-50 rounded-2xl p-5">
      <h3 class="text-sm font-bold text-gray-900 mb-3">새 작업 받는 방법</h3>
      <div class="space-y-2 text-sm text-gray-700">
        <% [
          "오더 피드에서 내 지역 건을 확인하세요",
          "신청하면 고객이 직접 전문가를 선택해요",
          "선택되면 즉시 알림을 드려요"
        ].each_with_index do |item, i| %>
          <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0"><%= i + 1 %></div>
            <span><%= item %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
