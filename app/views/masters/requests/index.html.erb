<%# 당근마켓 스타일 전문가 작업 목록 %>

<!-- 헤더 -->
<div class="mb-5">
  <h1 class="text-xl font-bold text-gray-900">내 작업 목록</h1>
  <p class="text-sm text-gray-500 mt-0.5">진행 중인 작업을 확인하고 관리하세요</p>
</div>

<!-- 미승인 전문가 안내 -->
<% unless current_user.master_profile&.verified? %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-4 mb-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div class="flex-1">
        <h3 class="text-sm font-semibold text-yellow-900">승인 대기 중</h3>
        <p class="text-xs text-yellow-800 mt-0.5">관리자가 프로필을 검토 중입니다. 승인이 완료되면 공개 오더를 선택할 수 있어요.</p>
        <%= link_to "프로필 완성하기", edit_masters_profile_path, class: "inline-block text-xs font-semibold text-yellow-900 underline mt-1" %>
      </div>
    </div>
  </div>
<% end %>

<!-- 탭 네비게이션 -->
<div class="flex gap-1 mb-4 bg-gray-100 rounded-xl p-1">
  <span class="flex-1 text-center py-2 text-sm font-semibold text-primary-700 bg-white rounded-lg">
    내 작업
  </span>
  <%= link_to open_orders_masters_requests_path, class: "flex-1 text-center py-2 text-sm font-medium text-gray-500 rounded-lg hover:text-gray-700 transition-colors" do %>
    공개 오더
    <% if @open_count.to_i > 0 %>
      <span class="ml-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= @open_count %></span>
    <% end %>
  <% end %>
</div>

<!-- 필터 -->
<div class="bg-white rounded-2xl border border-gray-100 p-4 mb-4">
  <%= search_form_for @q, url: masters_requests_path, html: { method: :get, class: "flex flex-col sm:flex-row gap-3" } do |f| %>
    <div class="flex-1">
      <%= f.select :status_eq,
            options_for_select([
              ["전체 상태", ""],
              ["마스터 배정", "assigned"],
              ["방문 중", "visiting"],
              ["탐지 중", "detecting"],
              ["누수 미확인", "no_leak_found"],
              ["견적 대기", "estimate_pending"],
              ["견적 제출", "estimate_submitted"],
              ["공사 합의", "construction_agreed"],
              ["에스크로 입금", "escrow_deposited"],
              ["공사 진행", "constructing"],
              ["공사 완료", "construction_completed"],
              ["종료", "closed"],
              ["취소", "cancelled"]
            ], params.dig(:q, :status_eq)),
            {}, class: input_classes(:select) %>
    </div>
    <div class="flex-1">
      <%= f.select :symptom_type_eq,
            options_for_select([
              ["전체 증상", ""],
              ["벽면 누수", "wall_leak"],
              ["천장 누수", "ceiling_leak"],
              ["바닥 누수", "floor_leak"],
              ["배관 누수", "pipe_leak"],
              ["화장실 누수", "toilet_leak"],
              ["외부 누수", "outdoor_leak"]
            ], params.dig(:q, :symptom_type_eq)),
            {}, class: input_classes(:select) %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "검색", class: btn_classes(:primary, :md) %>
      <%= link_to "초기화", masters_requests_path, class: btn_classes(:secondary, :md) %>
    </div>
  <% end %>
</div>

<!-- 리스트 -->
<% if @requests.any? %>
  <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-100">
    <% @requests.each do |request| %>
      <%= link_to masters_request_path(request), class: "block list-item-touch" do %>
        <div class="px-4 py-4">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <%= render "shared/status_badge", status: request.status %>
                <span class="text-xs text-gray-400">#<%= request.id %></span>
              </div>
              <h3 class="text-[15px] font-semibold text-gray-900">
                <%= symptom_label(request.symptom_type) %> · <%= request.customer&.name || "고객" %>
              </h3>
              <div class="flex items-center gap-3 mt-1.5 text-sm text-gray-500">
                <span class="flex items-center">
                  <svg class="w-3.5 h-3.5 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <%= truncate(request.address, length: 20) %>
                </span>
                <% if request.assigned_at.present? %>
                  <span class="text-gray-300">|</span>
                  <span>배정 <%= time_ago_in_words(request.assigned_at) %> 전</span>
                <% end %>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-300 flex-shrink-0 ml-2 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-6">
    <%= paginate @requests %>
  </div>
<% else %>
  <%= render "shared/empty_state",
        icon: "water",
        title: "현재 배정된 작업이 없어요",
        description: "공개 오더에서 새로운 건을 찾아보세요",
        cta_text: "공개 오더 보기",
        cta_path: open_orders_masters_requests_path %>

  <!-- 대기 중 안내 -->
  <div class="mt-4 bg-primary-50 rounded-2xl p-5">
    <h3 class="text-sm font-bold text-gray-900 mb-3">배정 대기 중이에요</h3>
    <div class="space-y-2 text-sm text-gray-700">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">1</div>
        <span>가까운 곳의 체크가 우선 배정돼요</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">2</div>
        <span>새 체크가 등록되면 알림을 보내드려요</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-primary-500 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">3</div>
        <span>에스크로로 대금을 안전하게 받을 수 있어요</span>
      </div>
    </div>
  </div>
<% end %>
