<% content_for :title, "누수 전문가 찾기" %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 헤더 -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium mb-3">
        검증된 전문가
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-3">누수 전문가 찾기</h1>
      <p class="text-lg text-gray-600">
        지역과 전문분야를 선택하여 나에게 맞는 전문가를 찾아보세요
      </p>
    </div>

    <!-- 검색 필터 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-8">
      <%= form_with url: masters_path, method: :get, html: { class: "grid grid-cols-1 md:grid-cols-3 gap-4" } do |f| %>
        <!-- 지역 필터 -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            서비스 지역
          </label>
          <%= text_field_tag :service_area, params[:service_area],
                placeholder: "예: 서울 강남구",
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <!-- 전문분야 필터 -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
            </svg>
            전문 분야
          </label>
          <%= select_tag :specialty,
                options_for_select([
                  ["전체", ""],
                  ["수도배관", "수도배관"],
                  ["방수", "방수"],
                  ["욕실", "욕실"],
                  ["옥상", "옥상"],
                  ["바닥", "바닥"],
                  ["외벽", "외벽"]
                ], params[:specialty]),
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <!-- 검색 버튼 -->
        <div class="flex items-end gap-2">
          <%= f.submit "검색", class: "flex-1 px-6 py-2.5 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors" %>
          <%= link_to "초기화", masters_path, class: "px-4 py-2.5 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors" %>
        </div>
      <% end %>
    </div>

    <!-- 전문가 수 표시 -->
    <div class="mb-6 flex items-center justify-between">
      <p class="text-sm text-gray-600">
        총 <span class="font-bold text-gray-900"><%= @masters.total_count %></span>명의 전문가
      </p>
      <% if params[:service_area].present? || params[:specialty].present? %>
        <div class="flex items-center gap-2 text-sm text-blue-600">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd"/>
          </svg>
          <span>필터 적용 중</span>
        </div>
      <% end %>
    </div>

    <!-- 전문가 카드 그리드 -->
    <% if @masters.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @masters.each do |master| %>
          <% profile = master.master_profile %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-shadow flex flex-col">
            <div class="p-6 flex-1">
              <!-- 프로필 헤더 -->
              <div class="flex items-start gap-4 mb-4">
                <!-- 아바타 -->
                <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center flex-shrink-0">
                  <span class="text-white font-bold text-2xl"><%= master.name&.first || "?" %></span>
                </div>

                <!-- 이름 + 인증 -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-bold text-lg text-gray-900 truncate"><%= master.name || "익명" %></h3>
                    <% if profile&.verified? %>
                      <svg class="w-5 h-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                    <% end %>
                  </div>

                  <!-- 별점 + 리뷰 수 -->
                  <% avg_rating = master.respond_to?(:avg_rating) && master.avg_rating || master.average_rating %>
                  <% review_count = master.respond_to?(:review_count) ? master.review_count : master.reviews.count %>

                  <% if avg_rating.to_f > 0 %>
                    <div class="flex items-center gap-1">
                      <div class="flex">
                        <% 5.times do |i| %>
                          <svg class="w-4 h-4 <%= i < avg_rating.to_f.round ? 'text-yellow-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                          </svg>
                        <% end %>
                      </div>
                      <span class="text-sm font-semibold text-gray-900"><%= number_with_precision(avg_rating, precision: 1) %></span>
                      <span class="text-xs text-gray-500">(<%= review_count %>)</span>
                    </div>
                  <% else %>
                    <span class="text-xs text-gray-400">리뷰 없음</span>
                  <% end %>
                </div>
              </div>

              <!-- 통계 -->
              <div class="flex items-center gap-4 mb-4 text-sm text-gray-600">
                <% if profile&.experience_years.to_i > 0 %>
                  <div class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span><%= profile.experience_years %>년</span>
                  </div>
                <% end %>

                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span><%= master.assigned_requests.where(status: "closed").count %>건 완료</span>
                </div>
              </div>

              <!-- 전문 분야 -->
              <% if profile&.specialty_types_list.any? %>
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-500 uppercase mb-2">전문 분야</p>
                  <div class="flex flex-wrap gap-1.5">
                    <% profile.specialty_types_list.take(3).each do |specialty| %>
                      <span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs font-medium rounded-full">
                        <%= specialty %>
                      </span>
                    <% end %>
                    <% if profile.specialty_types_list.size > 3 %>
                      <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full">
                        +<%= profile.specialty_types_list.size - 3 %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- 서비스 지역 -->
              <% if profile&.service_areas_list.any? %>
                <div class="mb-4">
                  <p class="text-xs font-semibold text-gray-500 uppercase mb-2">서비스 지역</p>
                  <div class="flex flex-wrap gap-1.5">
                    <% profile.service_areas_list.take(3).each do |area| %>
                      <span class="flex items-center gap-1 px-2 py-1 bg-green-50 text-green-700 text-xs rounded-full">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                        </svg>
                        <%= area %>
                      </span>
                    <% end %>
                    <% if profile.service_areas_list.size > 3 %>
                      <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full">
                        +<%= profile.service_areas_list.size - 3 %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <!-- 소개글 -->
              <% if profile&.bio.present? %>
                <p class="text-sm text-gray-600 line-clamp-2">
                  <%= profile.bio %>
                </p>
              <% end %>
            </div>

            <!-- 프로필 보기 버튼 -->
            <div class="p-4 border-t border-gray-100">
              <%= link_to master_path(master), class: "block w-full text-center px-4 py-2.5 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors" do %>
                프로필 보기
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 페이지네이션 -->
      <div class="mt-8">
        <%= paginate @masters %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">검색 결과가 없습니다</h3>
        <p class="text-gray-600 mb-6">
          다른 지역이나 전문분야로 검색해보세요
        </p>
        <%= link_to "전체 전문가 보기", masters_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
