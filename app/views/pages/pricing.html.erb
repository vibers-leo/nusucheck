<%# 가격 참고 안내 페이지 (간결 버전) %>

<div class="max-w-2xl mx-auto py-4">

  <!-- 헤더 -->
  <div class="mb-8">
    <p class="text-xs font-semibold text-primary-600 uppercase tracking-wider mb-1">가격 안내</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">누수 수리 비용 참고</h1>
    <p class="text-sm text-gray-500">아래 금액은 일반적인 시장 참고가격입니다. 실제 비용은 현장 상황에 따라 달라질 수 있으며, 전문가가 방문 후 견적을 제공합니다.</p>
  </div>

  <!-- 비용 항목 카드 -->
  <div class="bg-white rounded-2xl border border-gray-100 divide-y divide-gray-50 mb-6">

    <!-- 출장비 -->
    <div class="flex items-center gap-4 px-5 py-4">
      <div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">출장비</p>
        <p class="text-xs text-gray-400 mt-0.5">현장 방문 기본 비용</p>
      </div>
      <div class="text-right">
        <p class="text-sm font-bold text-gray-900">₩50,000 ~</p>
        <p class="text-xs text-gray-400">지역·거리에 따라 상이</p>
      </div>
    </div>

    <!-- 탐지비 -->
    <div class="flex items-center gap-4 px-5 py-4">
      <div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">탐지비</p>
        <p class="text-xs text-gray-400 mt-0.5">누수 위치 정밀 탐지</p>
      </div>
      <div class="text-right">
        <p class="text-sm font-bold text-gray-900">₩100,000 ~</p>
        <p class="text-xs text-gray-400">탐지 방식에 따라 상이</p>
      </div>
    </div>

    <!-- 수리비 -->
    <div class="flex items-center gap-4 px-5 py-4">
      <div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">수리 공사비</p>
        <p class="text-xs text-gray-400 mt-0.5">누수 위치·범위에 따라 크게 달라짐</p>
      </div>
      <div class="text-right">
        <p class="text-sm font-bold text-gray-900">₩200,000 ~</p>
        <p class="text-xs text-gray-400">VAT 포함</p>
      </div>
    </div>

    <!-- 플랫폼 이용료 -->
    <div class="flex items-center gap-4 px-5 py-4 bg-primary-50/50">
      <div class="w-9 h-9 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">고객 플랫폼 이용료</p>
        <p class="text-xs text-gray-400 mt-0.5">누수체크 서비스 이용 수수료</p>
      </div>
      <div class="text-right">
        <p class="text-sm font-bold text-primary-600">무료</p>
        <p class="text-xs text-gray-400">별도 비용 없음</p>
      </div>
    </div>

  </div>

  <!-- 안내 메시지 -->
  <div class="bg-amber-50 border border-amber-100 rounded-xl px-4 py-3 flex gap-3 mb-8">
    <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <p class="text-xs text-amber-700 leading-relaxed">
      모든 비용은 전문가가 현장 확인 후 제출하는 <strong>표준 견적서</strong>를 통해 투명하게 공개됩니다. 고객이 견적을 승인해야만 결제가 진행됩니다.
    </p>
  </div>

  <!-- 전문가 수수료 -->
  <div class="mb-8">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">전문가 수수료</h2>
    <div class="bg-white rounded-2xl border border-gray-100 px-5 py-4 flex items-center gap-4">
      <div class="text-3xl font-extrabold text-gray-900">15%</div>
      <div>
        <p class="text-sm font-medium text-gray-700">공사비 기준 성공 수수료</p>
        <p class="text-xs text-gray-400 mt-0.5">작업 완료·정산 시에만 발생 · 출장비·탐지비는 수수료 제외</p>
      </div>
    </div>
  </div>

  <!-- FAQ 간결 버전 -->
  <div>
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">자주 묻는 질문</h2>
    <div class="space-y-2">

      <details class="bg-white rounded-xl border border-gray-100 px-4 py-3 group">
        <summary class="text-sm font-medium text-gray-800 cursor-pointer flex justify-between items-center">
          고객이 내는 비용은 어떻게 결정되나요?
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">전문가가 현장 방문 후 출장비·탐지비·공사비를 포함한 견적서를 제출합니다. 고객이 견적을 확인·승인한 후에만 에스크로 결제가 진행됩니다.</p>
      </details>

      <details class="bg-white rounded-xl border border-gray-100 px-4 py-3 group">
        <summary class="text-sm font-medium text-gray-800 cursor-pointer flex justify-between items-center">
          에스크로 결제란 무엇인가요?
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">고객이 결제한 금액을 플랫폼이 보관하다가, 작업 완료 확인 후 전문가에게 지급합니다. 문제가 생기면 환불 요청이 가능합니다.</p>
      </details>

      <details class="bg-white rounded-xl border border-gray-100 px-4 py-3 group">
        <summary class="text-sm font-medium text-gray-800 cursor-pointer flex justify-between items-center">
          수수료가 언제 발생하나요?
          <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">공사 완료 후 정산 시점에만 수수료가 발생합니다. 작업이 진행되지 않았거나 취소된 경우 수수료는 없습니다.</p>
      </details>

    </div>
  </div>

</div>
