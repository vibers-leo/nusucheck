          </a>
          <a href="#" class="inline-flex items-center gap-2.5 px-4 py-2.5 bg-gray-900 text-white rounded-xl hover:bg-gray-800 transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.18 23.76c.3.17.64.24.99.19l.06-.03 11.62-6.71-2.53-2.54-10.14 9.09zm15.52-11.22L16.14 11 3.08.25c-.09-.06-.19-.1-.29-.13l12.43 12.42 3.48-2zm2.5 3.07l-2.96-1.71-2.8 2.8 2.8 2.8 2.98-1.72c.85-.49.85-1.68-.02-2.17zM3.08 23.75l-.01-.01c.01.01.01.01.01.01l.06.04c.01 0 .02-.01.03-.01L3.08 23.75zM3.18.24L3.13.21 3.07.18C2.22-.31 1.18.2 1.18 1.2V22.8c0 1 1.04 1.51 1.89 1.02l.01-.01L3.18.24z"/>
            </svg>
            <div class="text-left">
              <p class="text-[10px] text-gray-300">Get it on</p>
              <p class="text-sm font-semibold -mt-0.5">Google Play</p>
            </div>
          </a>
        </div>
        <p class="mt-3 text-xs text-gray-400">* 앱 출시 준비 중입니다. 웹에서 먼저 이용하세요.</p>
      </div>
      <div class="flex-shrink-0">
        <div class="w-48 h-48 bg-primary-50 rounded-3xl flex items-center justify-center">
          <div class="text-center text-primary-600">
            <svg class="w-16 h-16 mx-auto mb-2 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            <p class="font-bold text-sm">누수체크 앱</p>
            <p class="text-xs opacity-60">Coming Soon</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA 섹션 -->
<% unless user_signed_in? %>
<section class="bg-gray-50 py-10 border-t border-gray-100">
  <div class="max-w-lg mx-auto md:max-w-3xl px-4 md:px-6 text-center">
    <h2 class="text-xl font-bold text-gray-900 mb-2">지금 바로 시작하세요</h2>
    <p class="text-sm text-gray-500 mb-6">누수 걱정, 더 이상 혼자 고민하지 마세요</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-6 py-3.5 text-base font-bold rounded-2xl bg-primary-600 text-white hover:bg-primary-700 transition-colors" do %>
        무료 회원가입
      <% end %>
      <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold rounded-2xl bg-white border-2 border-gray-200 text-gray-700 hover:bg-gray-50 transition-colors" do %>
        AI 점검 먼저 해보기
      <% end %>
    </div>
  </div>
</section>

<!-- 전문가 초대 배너 -->
<section class="bg-white py-8 border-t border-gray-100">
  <div class="max-w-lg mx-auto md:max-w-3xl px-4 md:px-6">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="text-base font-bold text-gray-900">누수 전문가이신가요?</h3>
        <p class="text-sm text-gray-500 mt-0.5">낮은 수수료로 더 많은 수익을 올리세요</p>
      </div>
      <%= link_to expert_root_path, class: "flex-shrink-0 inline-flex items-center px-4 py-2.5 bg-primary-50 text-primary-700 font-semibold rounded-xl hover:bg-primary-100 transition-colors text-sm" do %>
        알아보기
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
  </div>
</section>
<% end %>
