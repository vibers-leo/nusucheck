<%# 당근마켓 스타일 홈페이지 - 깔끔하고 따뜻한 느낌 %>

<!-- Hero Section - 심플한 흰 배경 + 큰 타이포 -->
<section class="bg-white py-10 md:py-16">
  <div class="max-w-lg mx-auto md:max-w-4xl px-4 md:px-6">
    <div class="text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight">
        우리 동네<br class="md:hidden"> 누수 전문가를<br>만나보세요
      </h1>
      <p class="mt-3 text-base text-gray-500 leading-relaxed">
        검증된 전문가 매칭부터 에스크로 결제까지<br>안심하고 누수 문제를 해결하세요
      </p>
    </div>

    <!-- AI 진단 카드 (메인 CTA) -->
    <div class="bg-primary-50 rounded-3xl p-6 md:p-8 mb-6">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 bg-primary-600 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900">AI 사전점검</h2>
          <p class="text-sm text-gray-600">영상이 가장 정확해요! 예상 수리비와 원인을 분석해드려요</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <% if user_signed_in? && current_user.customer? %>
          <%= link_to new_customers_request_path, class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 text-base font-bold rounded-2xl bg-primary-600 text-white hover:bg-primary-700 transition-colors", data: { turbo: false } do %>
            누수 체크하기
          <% end %>
        <% elsif user_signed_in? && current_user.master? %>
          <%= link_to masters_requests_path, class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 text-base font-bold rounded-2xl bg-primary-600 text-white hover:bg-primary-700 transition-colors" do %>
            오더 목록 보기
          <% end %>
        <% else %>
          <%= link_to new_customers_request_path, class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 text-base font-bold rounded-2xl bg-primary-600 text-white hover:bg-primary-700 transition-colors", data: { turbo: false } do %>
            무료로 시작하기
          <% end %>
        <% end %>
        <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold rounded-2xl bg-white border-2 border-primary-600 text-primary-700 hover:bg-primary-50 transition-colors" do %>
          AI 빠른 점검
        <% end %>
      </div>
    </div>

    <!-- 신뢰 지표 (간소화) -->
    <div class="flex justify-center gap-6 text-center mb-2">
      <div>
        <p class="text-xl font-bold text-gray-900">150+</p>
        <p class="text-xs text-gray-500">검증된 전문가</p>
      </div>
      <div class="w-px bg-gray-200"></div>
      <div>
        <p class="text-xl font-bold text-gray-900">95%</p>
        <p class="text-xs text-gray-500">매칭 성공률</p>
      </div>
      <div class="w-px bg-gray-200"></div>
      <div>
        <p class="text-xl font-bold text-gray-900">2시간</p>
        <p class="text-xs text-gray-500">평균 배정</p>
      </div>
    </div>
  </div>
</section>

<!-- 핵심 기능 아이콘 메뉴 (당근마켓 스타일) -->
<section class="bg-white border-t border-gray-100 py-6">
  <div class="max-w-lg mx-auto md:max-w-4xl px-4 md:px-6">
    <div class="grid grid-cols-4 gap-3 md:gap-6">
      <div class="flex flex-col items-center">
        <div class="w-14 h-14 bg-primary-50 rounded-2xl flex items-center justify-center mb-2">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
        </div>
        <span class="text-xs font-semibold text-gray-700 text-center">누수 체크</span>
        <span class="text-[10px] text-gray-400">무료 보증</span>
      </div>

      <div class="flex flex-col items-center">
        <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mb-2">
          <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <span class="text-xs font-semibold text-gray-700 text-center">안심 결제</span>
        <span class="text-[10px] text-gray-400">에스크로</span>
      </div>

      <div class="flex flex-col items-center">
        <div class="w-14 h-14 bg-violet-50 rounded-2xl flex items-center justify-center mb-2">
          <svg class="w-7 h-7 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <span class="text-xs font-semibold text-gray-700 text-center">2년 보증</span>
        <span class="text-[10px] text-gray-400">무상 AS</span>
      </div>

      <div class="flex flex-col items-center">
        <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center mb-2">
          <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <span class="text-xs font-semibold text-gray-700 text-center">보험 자동화</span>
        <span class="text-[10px] text-gray-400">서류 간편</span>
      </div>
    </div>
  </div>
</section>

<!-- 활동 중인 전문가 미리보기 -->
<% masters_preview = Master.joins(:master_profile).where(master_profiles: { verified: true }).includes(:master_profile).limit(3) %>
<% if masters_preview.any? %>
<section class="bg-white border-t border-gray-100 py-6">
  <div class="max-w-lg mx-auto md:max-w-4xl px-4 md:px-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-bold text-gray-900">활동 중인 전문가</h2>
      <%= link_to customers_masters_path, class: "text-sm text-primary-600 font-semibold" do %>전체보기 →<% end %>
    </div>
    <div class="space-y-2.5">
      <% masters_preview.each do |master| %>
        <%
          m_completed = master.assigned_requests.where(status: 'closed').count rescue 0
          m_reviews = master.reviews.count rescue 0
          m_avg = master.reviews.average("(punctuality_rating + skill_rating + kindness_rating + cleanliness_rating + price_rating) / 5.0").to_f.round(1) rescue 0
          m_years = master.master_profile&.experience_years || 0
        %>
        <%= link_to customers_master_path(master), class: "flex items-center gap-3 p-3.5 bg-white rounded-2xl border border-gray-100 hover:border-primary-200 hover:shadow-sm transition-all block" do %>
          <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-xl font-bold flex-shrink-0">
            <%= master.name&.first %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span class="font-semibold text-gray-900 text-sm"><%= master.name %></span>
              <span class="text-xs px-1.5 py-0.5 bg-primary-100 text-primary-700 rounded-full font-semibold">인증</span>
            </div>
            <p class="text-xs text-gray-400 truncate mb-1"><%= master.master_profile&.bio&.truncate(25) || '누수 전문가' %></p>
            <div class="flex items-center gap-3 text-xs text-gray-500">
              <% if m_avg > 0 %>
                <span class="flex items-center gap-0.5 font-semibold text-yellow-600">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <%= m_avg %>
                </span>
              <% end %>
              <% if m_completed > 0 %>
                <span>완료 <%= m_completed %>건</span>
              <% end %>
              <% if m_years > 0 %>
                <span>경력 <%= m_years %>년</span>
              <% end %>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- 왜 누수체크? - 간결한 장점 리스트 -->
<section class="bg-gray-50 py-10 md:py-14" data-controller="scroll-reveal">
  <div class="max-w-lg mx-auto md:max-w-3xl px-4 md:px-6">
    <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6">왜 누수체크인가요?</h2>

    <div class="space-y-4">
      <div class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 opacity-0" data-scroll-reveal-target="item">
        <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-[15px] font-bold text-gray-900">검증된 전문가만</h3>
          <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">자격증, 경력, 보험 가입 여부를 철저히 심사합니다</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 opacity-0" data-scroll-reveal-target="item">
        <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-[15px] font-bold text-gray-900">단계별 에스크로</h3>
          <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">출장비 -> 검사비 -> 공사비를 단계별로 안전하게 보관합니다</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 opacity-0" data-scroll-reveal-target="item">
        <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-[15px] font-bold text-gray-900">표준 견적 시스템</h3>
          <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">마케팅 수수료 없이 투명한 가격을 제공합니다</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 opacity-0" data-scroll-reveal-target="item">
        <div class="w-10 h-10 bg-violet-50 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-[15px] font-bold text-gray-900">보험서류 자동화</h3>
          <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">탐지 보고서, 견적서, 완료 보고서를 PDF로 자동 생성합니다</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AI 빠른 점검 CTA -->
<section class="bg-primary-600 py-10 md:py-14">
  <div class="max-w-lg mx-auto md:max-w-3xl px-4 md:px-6 text-center text-white">
    <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
    </div>
    <h2 class="text-2xl font-bold mb-2">AI로 누수 여부를 즉시 확인하세요</h2>
    <p class="text-primary-100 mb-6">영상이 가장 정확해요! 로그인 없이 무료로 이용하세요.</p>
    <%= link_to new_customers_request_path(mode: 'diagnosis'), class: "inline-flex items-center px-6 py-3.5 bg-white text-primary-700 rounded-2xl font-bold hover:bg-gray-50 transition-colors" do %>
      AI 빠른 점검 시작
    <% end %>
  </div>
</section>

<!-- 앱 다운로드 배너 -->
<section class="bg-white py-10 md:py-14">
  <div class="max-w-lg mx-auto md:max-w-3xl px-4 md:px-6">
    <div class="flex flex-col md:flex-row items-center gap-8">
      <div class="flex-1 text-center md:text-left">
        <span class="inline-block px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-xs font-semibold mb-3">모바일 앱</span>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">언제 어디서나<br>누수체크 앱으로</h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-5">
          사진 촬영부터 실시간 진행 확인, 전문가 채팅까지<br>모바일에서 더 편리하게 이용하세요
