<!-- 서비스 소개 페이지 (토스+당근마켓 스타일) -->
<div class="min-h-screen bg-gray-50">
  <!-- 히어로 섹션 -->
  <div class="bg-gradient-to-br from-primary-600 via-primary-700 to-purple-700 text-white">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
          누수, <span class="text-yellow-300">10분</span>이면<br class="md:hidden"/> 해결됩니다
        </h1>
        <p class="text-xl md:text-2xl text-primary-100 mb-10">
          영상 하나로 AI가 진단하고,<br class="md:hidden"/>
          검증된 전문가가 24시간 내 견적을 드려요
        </p>
        <%= link_to new_user_registration_path, class: "inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-700 rounded-2xl hover:shadow-2xl transition-all font-bold text-lg" do %>
          <span>무료로 시작하기</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 프로세스 (3단계) -->
  <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        이렇게 간단해요
      </h2>
      <p class="text-lg text-gray-600">
        누구나 쉽게 따라할 수 있는 3단계 프로세스
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-20">
      <!-- Step 1: 영상 촬영 -->
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-all">
        <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl mb-6 shadow-lg">
          <span class="text-3xl">📹</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">1. 영상 촬영</h3>
        <p class="text-gray-700 mb-4 leading-relaxed">
          누수 부위를 스마트폰으로 10초 이상 촬영하세요. AI가 자동으로 분석합니다.
        </p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>모바일 촬영만으로 OK</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>10초 이상 권장</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>물 떨어지는 소리까지 녹음</span>
          </li>
        </ul>
      </div>

      <!-- Step 2: AI 진단 + 전문가 매칭 -->
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-all">
        <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl mb-6 shadow-lg">
          <span class="text-3xl">🤖</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">2. AI 진단</h3>
        <p class="text-gray-700 mb-4 leading-relaxed">
          AI가 영상을 분석하고, 주변 검증된 전문가에게 자동 매칭합니다.
        </p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-purple-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>평균 2시간 내 응답</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-purple-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>내 주변 전문가 자동 매칭</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-purple-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>정확한 견적 제공</span>
          </li>
        </ul>
      </div>

      <!-- Step 3: 안심 수리 -->
      <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-all">
        <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl mb-6 shadow-lg">
          <span class="text-3xl">✅</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">3. 안심 수리</h3>
        <p class="text-gray-700 mb-4 leading-relaxed">
          에스크로 결제로 안전하게 수리하고, 보험청구까지 자동 처리됩니다.
        </p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-pink-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>완료 후 결제 (에스크로)</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-pink-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>보험서류 자동 생성</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-pink-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>하자보수 보증 최대 1년</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-3xl p-10 shadow-sm border border-gray-100">
      <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">
        자주 묻는 질문
      </h2>

      <div class="space-y-6 max-w-3xl mx-auto">
        <!-- FAQ 1 -->
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none p-4 rounded-xl hover:bg-gray-50 transition-colors">
            <h3 class="font-bold text-gray-900 text-lg">정말 10분이면 신청이 완료되나요?</h3>
            <svg class="w-6 h-6 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="text-gray-600 mt-3 px-4 leading-relaxed">
            네, 스마트폰으로 영상 촬영 후 간단한 정보만 입력하시면 10분 이내에 신청이 완료됩니다.
            복잡한 서류 작성이나 전화 통화가 필요 없습니다.
          </p>
        </details>

        <!-- FAQ 2 -->
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none p-4 rounded-xl hover:bg-gray-50 transition-colors">
            <h3 class="font-bold text-gray-900 text-lg">비용은 얼마나 드나요?</h3>
            <svg class="w-6 h-6 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="text-gray-600 mt-3 px-4 leading-relaxed">
            신청 자체는 <strong>무료</strong>입니다.
            전문가 견적을 받은 후 마음에 드는 견적을 선택하시면,
            표준 견적 기준으로 투명하게 비용이 책정됩니다.
            보험 가입자는 보험 처리도 가능합니다.
          </p>
        </details>

        <!-- FAQ 3 -->
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none p-4 rounded-xl hover:bg-gray-50 transition-colors">
            <h3 class="font-bold text-gray-900 text-lg">전문가는 어떻게 선정되나요?</h3>
            <svg class="w-6 h-6 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="text-gray-600 mt-3 px-4 leading-relaxed">
            누수체크에 등록된 전문가는 모두 자격증 검증을 거친 분들입니다.
            고객 위치 기반으로 주변 전문가가 자동 매칭되며,
            평점, 리뷰, 경력 등을 확인하신 후 직접 선택하실 수 있습니다.
          </p>
        </details>

        <!-- FAQ 4 -->
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none p-4 rounded-xl hover:bg-gray-50 transition-colors">
            <h3 class="font-bold text-gray-900 text-lg">보험청구는 어떻게 하나요?</h3>
            <svg class="w-6 h-6 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="text-gray-600 mt-3 px-4 leading-relaxed">
            누수체크는 보험청구 서류를 <strong>자동 생성</strong>합니다.
            수리 완료 후 대시보드에서 "보험청구" 버튼을 클릭하시면,
            필요한 서류(탐지보고서, 견적서, 완료보고서)가 PDF로 자동 생성되어
            바로 보험사에 제출하실 수 있습니다.
          </p>
        </details>

        <!-- FAQ 5 -->
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none p-4 rounded-xl hover:bg-gray-50 transition-colors">
            <h3 class="font-bold text-gray-900 text-lg">결제는 언제 하나요?</h3>
            <svg class="w-6 h-6 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <p class="text-gray-600 mt-3 px-4 leading-relaxed">
            누수체크는 <strong>에스크로 결제</strong>를 사용합니다.
            공사비는 사전에 결제하지만, 수리가 완료되고 고객님이 확인 버튼을 누르기 전까지는
            전문가에게 지급되지 않습니다. 만족스럽지 않으면 환불 가능합니다.
          </p>
        </details>
      </div>
    </div>
  </div>

  <!-- CTA 섹션 -->
  <div class="bg-gradient-to-r from-primary-600 to-purple-600 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        지금 바로 시작하세요
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        무료로 가입하고 24시간 내 견적 받아보세요
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to new_user_registration_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-5 bg-white text-primary-700 rounded-2xl hover:shadow-2xl transition-all font-bold text-lg" do %>
          <span>무료로 시작하기</span>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
        <%= link_to customers_masters_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-5 bg-transparent text-white rounded-2xl border-2 border-white hover:bg-white hover:text-primary-700 transition-all font-bold text-lg" do %>
          <span>전문가 둘러보기</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
