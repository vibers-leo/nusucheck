<!-- 리뷰/후기 페이지 (당근마켓 스타일) -->
<%= render "shared/customer_nav" if user_signed_in? %>

<div class="min-h-screen bg-gray-50 <%= user_signed_in? ? 'pb-20 md:pb-8' : '' %>">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- 헤더 -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
        ⭐ 고객 후기
      </h1>
      <p class="text-lg text-gray-600">
        <%= @reviews.total_count %>개의 솔직한 후기를 확인하세요
      </p>
    </div>

    <!-- 필터 -->
    <div class="mb-8 flex flex-wrap gap-3">
      <!-- 평점 필터 -->
      <%= link_to "전체", reviews_path, class: "px-4 py-2 rounded-full #{params[:rating].blank? ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>

      <% [5, 4, 3].each do |rating| %>
        <%= link_to "#{rating}점 ⭐", reviews_path(rating: rating), class: "px-4 py-2 rounded-full #{params[:rating] == rating.to_s ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <% end %>

      <!-- 증상 유형 필터 -->
      <% {
        wall_leak: "벽면 누수",
        ceiling_leak: "천장 누수",
        floor_leak: "바닥 누수",
        pipe_leak: "배관 누수"
      }.each do |type, label| %>
        <%= link_to label, reviews_path(symptom_type: type), class: "px-4 py-2 rounded-full #{params[:symptom_type] == type.to_s ? 'bg-primary-600 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'} font-medium transition-colors" %>
      <% end %>
    </div>

    <!-- 리뷰 카드 그리드 -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @reviews.each do |review| %>
        <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:shadow-lg transition-all">
          <!-- 상단: 고객 정보 + 평점 -->
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <!-- 고객 아이콘 -->
              <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-purple-500 rounded-full flex items-center justify-center">
                <span class="text-xl text-white font-bold">
                  <%= review.customer.name[0] %>
                </span>
              </div>
              <div>
                <p class="font-bold text-gray-900">
                  <%= review.customer.name[0] %>**
                </p>
                <p class="text-xs text-gray-500">
                  <%= time_ago_in_words(review.created_at) %> 전
                </p>
              </div>
            </div>

            <!-- 평점 -->
            <div class="flex items-center gap-1">
              <% review.rating.to_i.times do %>
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
              <% (5 - review.rating.to_i).times do %>
                <svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
            </div>
          </div>

          <!-- 증상 유형 배지 -->
          <div class="mb-3">
            <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-xs font-medium">
              <%= I18n.t("activerecord.attributes.request.symptom_types.#{review.request.symptom_type}") %>
            </span>
          </div>

          <!-- 리뷰 내용 -->
          <p class="text-gray-700 leading-relaxed mb-4 line-clamp-4">
            <%= review.comment %>
          </p>

          <!-- 전문가 정보 -->
          <div class="border-t border-gray-100 pt-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
            </svg>
            <p class="text-sm text-gray-600">
              전문가: <span class="font-semibold text-gray-900"><%= review.master.name %></span>
            </p>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 리뷰 없을 때 -->
    <% if @reviews.empty? %>
      <div class="text-center py-20">
        <div class="inline-block p-6 bg-gray-100 rounded-full mb-4">
          <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">
          아직 후기가 없습니다
        </h3>
        <p class="text-gray-600 mb-6">
          첫 번째 리뷰를 남겨주세요!
        </p>
      </div>
    <% end %>

    <!-- 페이지네이션 -->
    <div class="mt-8 flex justify-center">
      <%= paginate @reviews %>
    </div>

    <!-- CTA (하단) -->
    <% unless user_signed_in? %>
      <div class="mt-16 text-center bg-white rounded-3xl p-10 border border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          누수 문제, 지금 바로 해결하세요
        </h2>
        <p class="text-gray-600 mb-6">
          검증된 전문가가 24시간 내 견적을 보내드립니다
        </p>
        <%= link_to "무료로 시작하기", new_user_registration_path, class: "inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-2xl font-bold text-lg hover:shadow-lg transition-all" %>
      </div>
    <% end %>
  </div>
</div>
