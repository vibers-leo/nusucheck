<%# 커뮤니티 페이지 — 누수 정보 게시글 + 리뷰 %>
<% content_for :title, "커뮤니티" %>

<!-- 헤더 -->
<div class="mb-6">
  <h1 class="text-xl font-bold text-gray-900">커뮤니티</h1>
  <p class="text-sm text-gray-500 mt-1">누수 관련 정보와 실제 해결 후기를 확인하세요</p>
</div>

<!-- 탭 -->
<div class="flex gap-2 mb-6 border-b border-gray-100 -mx-4 px-4">
  <button class="pb-3 text-sm font-semibold text-primary-600 border-b-2 border-primary-600 -mb-px" id="tab-posts" onclick="switchTab('posts')">
    누수 정보
  </button>
  <button class="pb-3 text-sm font-medium text-gray-400 hover:text-gray-600 -mb-px" id="tab-reviews" onclick="switchTab('reviews')">
    해결 후기
  </button>
</div>

<!-- 누수 정보 탭 -->
<div id="section-posts">
  <div class="space-y-3">

    <!-- 정보 카드 1 -->
    <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">누수 상식</span>
          </div>
          <h3 class="font-semibold text-gray-900 text-[15px] leading-snug">천장 누수, 그냥 두면 어떻게 될까요?</h3>
          <p class="text-sm text-gray-500 mt-1 leading-relaxed">천장 누수를 방치하면 곰팡이, 구조물 손상, 전기 합선 위험까지 이어질 수 있어요. 초기에 발견할수록 수리 비용이 크게 줄어듭니다.</p>
          <p class="text-xs text-gray-400 mt-2">누수체크 가이드</p>
        </div>
      </div>
    </div>

    <!-- 정보 카드 2 -->
    <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">보험 정보</span>
          </div>
          <h3 class="font-semibold text-gray-900 text-[15px] leading-snug">누수 피해, 보험으로 보상받을 수 있어요</h3>
          <p class="text-sm text-gray-500 mt-1 leading-relaxed">화재보험, 일상생활배상책임보험 등을 통해 누수로 인한 피해를 보상받을 수 있습니다. 전문가와 함께 서류를 준비하면 훨씬 수월해요.</p>
          <p class="text-xs text-gray-400 mt-2">누수체크 가이드</p>
        </div>
      </div>
    </div>

    <!-- 정보 카드 3 -->
    <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">예방 팁</span>
          </div>
          <h3 class="font-semibold text-gray-900 text-[15px] leading-snug">누수 예방을 위한 5가지 체크리스트</h3>
          <p class="text-sm text-gray-500 mt-1 leading-relaxed">수도계량기 확인, 배수구 정기 청소, 실리콘 줄눈 상태 점검 등 간단한 점검으로 누수를 미리 예방할 수 있어요.</p>
          <p class="text-xs text-gray-400 mt-2">누수체크 가이드</p>
        </div>
      </div>
    </div>

    <!-- 정보 카드 4 -->
    <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full">영상 진단</span>
          </div>
          <h3 class="font-semibold text-gray-900 text-[15px] leading-snug">영상 하나로 전문가 진단을 받아보세요</h3>
          <p class="text-sm text-gray-500 mt-1 leading-relaxed">누수가 의심되는 부위를 촬영해서 올리면, 전문가가 현장 방문 전에 미리 상태를 파악하고 정확한 견적을 드려요.</p>
          <p class="text-xs text-gray-400 mt-2">누수체크 서비스</p>
        </div>
      </div>
    </div>

  </div>

  <!-- 누수체크 CTA -->
  <div class="mt-6 bg-gradient-to-r from-primary-500 to-primary-600 rounded-2xl p-4 text-white">
    <h3 class="font-bold text-[15px] mb-1">지금 누수가 걱정되시나요?</h3>
    <p class="text-sm text-primary-100 mb-3">영상을 올리면 전문가가 바로 확인해드려요</p>
    <%= link_to new_customers_request_path, class: "inline-flex items-center gap-2 bg-white text-primary-600 text-sm font-bold px-4 py-2 rounded-xl hover:bg-primary-50 transition-colors", data: { turbo: false } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
      </svg>
      누수 체크하기
    <% end %>
  </div>
</div>

<!-- 해결 후기 탭 -->
<div id="section-reviews" class="hidden">
  <% if @reviews.any? %>
    <div class="space-y-3">
      <% @reviews.each do |review| %>
        <div class="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
          <!-- 별점 -->
          <div class="flex items-center gap-1 mb-2">
            <% review.overall_rating.times do %>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            <% end %>
            <% (5 - review.overall_rating).times do %>
              <svg class="w-4 h-4 text-gray-200" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            <% end %>
            <% if review.request %>
              <span class="ml-1 text-xs text-gray-400"><%= symptom_label(review.request.symptom_type) %></span>
            <% end %>
          </div>

          <!-- 내용 -->
          <p class="text-sm text-gray-700 leading-relaxed"><%= review.comment %></p>

          <!-- 작성자 -->
          <div class="flex items-center gap-2 mt-3">
            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0">
              <%= review.customer&.name&.first || "?" %>
            </div>
            <span class="text-xs text-gray-500"><%= review.customer&.name&.gsub(/.(?=.{1})/, '*') || "익명" %></span>
            <span class="text-xs text-gray-300">·</span>
            <span class="text-xs text-gray-400"><%= time_ago_in_words(review.created_at) %> 전</span>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 더 보기 링크 -->
    <div class="mt-4 text-center">
      <%= link_to reviews_path, class: "text-sm font-semibold text-primary-600 hover:text-primary-700" do %>
        후기 더 보기
        <svg class="w-4 h-4 inline-block ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

  <% else %>
    <%= render "shared/empty_state",
          icon: "star",
          title: "아직 후기가 없어요",
          description: "첫 번째 리뷰를 남겨보세요",
          cta_text: nil,
          cta_path: nil %>
  <% end %>
</div>

<script>
  function switchTab(tab) {
    document.getElementById('section-posts').classList.toggle('hidden', tab !== 'posts');
    document.getElementById('section-reviews').classList.toggle('hidden', tab !== 'reviews');
    document.getElementById('tab-posts').className = tab === 'posts'
      ? 'pb-3 text-sm font-semibold text-primary-600 border-b-2 border-primary-600 -mb-px'
      : 'pb-3 text-sm font-medium text-gray-400 hover:text-gray-600 -mb-px';
    document.getElementById('tab-reviews').className = tab === 'reviews'
      ? 'pb-3 text-sm font-semibold text-primary-600 border-b-2 border-primary-600 -mb-px'
      : 'pb-3 text-sm font-medium text-gray-400 hover:text-gray-600 -mb-px';
  }
</script>
