<%# 커뮤니티 — 당근마켓 스타일 피드 %>
<% content_for :title, "커뮤니티" %>

<div class="max-w-2xl mx-auto px-4 pb-24">

  <!-- 헤더 -->
  <div class="flex items-center justify-between pt-4 pb-3 sticky top-0 bg-gray-50 z-10">
    <h1 class="text-xl font-bold text-gray-900">커뮤니티</h1>
    <% if user_signed_in? %>
      <%= link_to new_post_path, class: "flex items-center gap-1.5 px-3 py-2 bg-primary-600 text-white rounded-xl text-sm font-semibold hover:bg-primary-700 transition shadow-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
        </svg>
        글쓰기
      <% end %>
    <% end %>
  </div>

  <!-- 카테고리 탭 -->
  <div class="flex gap-2 overflow-x-auto pb-2 mb-4 scrollbar-hide -mx-4 px-4">
    <%= link_to community_path, class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-semibold transition #{@category.blank? ? 'bg-primary-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary-400'}" do %>
      전체
    <% end %>
    <% [["tip", "💧 누수 팁"], ["review", "⭐ 해결 후기"], ["question", "❓ 질문"], ["general", "💬 일반"]] .each do |cat, label| %>
      <%= link_to community_path(category: cat), class: "flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-semibold transition #{@category == cat ? 'bg-primary-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary-400'}" do %>
        <%= label %>
      <% end %>
    <% end %>
  </div>

  <!-- 게시글 목록 (당근마켓 스타일 카드) -->
  <% if @posts.any? %>
    <div class="space-y-0 divide-y divide-gray-100 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <% @posts.each do |post| %>
        <%= link_to post_path(post), class: "flex items-start gap-3 p-4 hover:bg-gray-50 transition-colors group" do %>

          <!-- 이미지 썸네일 (있는 경우) -->
          <% if post.image.attached? %>
            <div class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-gray-100">
              <%= image_tag post.image.variant(resize_to_fill: [160, 160]), class: "w-full h-full object-cover", alt: post.title %>
            </div>
          <% else %>
            <!-- 기본 이미지 플레이스홀더 -->
            <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-gradient-to-br from-primary-50 to-teal-50 border border-primary-100 flex items-center justify-center">
              <span class="text-2xl">
                <% icons = {"tip" => "💧", "review" => "⭐", "question" => "❓", "general" => "💬"} %>
                <%= icons[post.category] || "📝" %>
              </span>
            </div>
          <% end %>

          <!-- 텍스트 영역 -->
          <div class="flex-1 min-w-0">
            <!-- 카테고리 뱃지 + 제목 -->
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full <%= post.category_color %>">
                <%= post.category_label %>
              </span>
            </div>
            <h2 class="font-semibold text-gray-900 text-[15px] leading-snug truncate group-hover:text-primary-600 transition-colors">
              <%= post.title %>
            </h2>
            <p class="text-sm text-gray-500 mt-1 line-clamp-2 leading-relaxed">
              <%= post.content.truncate(80) %>
            </p>

            <!-- 메타 정보 -->
            <div class="flex items-center gap-3 mt-2">
              <span class="text-xs text-gray-400 font-medium">
                <%= post.user.name&.first&.then { |c| "#{c}*" } || "익명" %>
              </span>
              <span class="text-xs text-gray-300">•</span>
              <span class="text-xs text-gray-400">
                <%= time_ago_in_words(post.created_at) %> 전
              </span>
              <% if post.views_count > 0 %>
                <span class="text-xs text-gray-300">•</span>
                <span class="text-xs text-gray-400 flex items-center gap-0.5">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <%= post.views_count %>
                </span>
              <% end %>
            </div>
          </div>

          <!-- 화살표 -->
          <svg class="w-4 h-4 text-gray-300 flex-shrink-0 mt-1 group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>

        <% end %>
      <% end %>
    </div>

    <!-- 페이지네이션 -->
    <% if @posts.total_pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%= paginate @posts %>
      </div>
    <% end %>

  <% else %>
    <!-- 빈 상태 -->
    <div class="text-center py-16 bg-white rounded-2xl border border-gray-100 shadow-sm">
      <div class="w-16 h-16 mx-auto bg-primary-50 rounded-2xl flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
      </div>
      <p class="text-gray-500 font-medium mb-1">아직 게시글이 없어요</p>
      <p class="text-sm text-gray-400 mb-4">
        <% if @category.present? %>
          이 카테고리에 아직 글이 없어요
        <% else %>
          첫 번째 글을 작성해보세요!
        <% end %>
      </p>
      <% if user_signed_in? %>
        <%= link_to "글쓰기", new_post_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white rounded-xl text-sm font-semibold hover:bg-primary-700 transition shadow-sm" %>
      <% end %>
    </div>
  <% end %>

  <!-- 하단 정보 배너 (글 없거나 로그아웃 상태) -->
  <% unless user_signed_in? %>
    <div class="mt-6 p-4 bg-primary-50 rounded-2xl border border-primary-100">
      <p class="text-sm font-semibold text-primary-800 mb-1">💬 커뮤니티에 참여하세요</p>
      <p class="text-xs text-primary-600 mb-3">로그인하면 글을 쓰고 다른 사람과 소통할 수 있어요</p>
      <div class="flex gap-2">
        <%= link_to "로그인", new_user_session_path, class: "px-4 py-2 bg-white text-primary-700 border border-primary-200 rounded-lg text-sm font-semibold hover:bg-primary-50 transition" %>
        <%= link_to "회원가입", new_user_registration_path, class: "px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-semibold hover:bg-primary-700 transition" %>
      </div>
    </div>
  <% end %>

</div>
