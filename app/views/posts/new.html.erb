<%# 새 게시글 작성 %>
<% content_for :title, "글쓰기" %>

<div class="max-w-2xl mx-auto px-4 pb-24">

  <!-- 헤더 -->
  <div class="flex items-center gap-3 pt-4 pb-4">
    <%= link_to community_path, class: "w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition -ml-2" do %>
      <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-lg font-bold text-gray-900">글쓰기</h1>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
    <%= render "form", post: @post %>
  </div>

</div>
