<%# 게시글 상세 %>
<% content_for :title, @post.title %>

<div class="max-w-2xl mx-auto px-4 pb-24">

  <!-- 헤더 -->
  <div class="flex items-center gap-3 pt-4 pb-2">
    <%= link_to community_path, class: "w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition -ml-2" do %>
      <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <span class="text-sm font-medium text-gray-500">커뮤니티</span>
  </div>

  <!-- 카드 본문 -->
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <!-- 이미지 (있을 때) -->
    <% if @post.image.attached? %>
      <div class="aspect-video bg-gray-100">
        <%= image_tag @post.image, class: "w-full h-full object-cover", alt: @post.title %>
      </div>
    <% end %>

    <div class="p-5">
      <!-- 카테고리 + 작성일 -->
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%= @post.category_color %>">
          <%= @post.category_label %>
        </span>
        <span class="text-xs text-gray-400">
          <%= @post.created_at.strftime("%Y.%m.%d %H:%M") %>
        </span>
      </div>

      <!-- 제목 -->
      <h1 class="text-xl font-bold text-gray-900 leading-snug mb-2">
        <%= @post.title %>
      </h1>

      <!-- 작성자 정보 -->
      <div class="flex items-center gap-2 mb-4 pb-4 border-b border-gray-100">
        <div class="w-8 h-8 bg-gradient-to-br from-primary-400 to-teal-500 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
          <%= @post.user.name&.first || "?" %>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-800">
            <%= @post.user.name&.first&.then { |c| "#{c}*" } || "익명" %>
          </p>
          <p class="text-xs text-gray-400"><%= time_ago_in_words(@post.created_at) %> 전</p>
        </div>
        <div class="ml-auto flex items-center gap-1 text-xs text-gray-400">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          <%= @post.views_count %>
        </div>
      </div>

      <!-- 본문 -->
      <div class="text-gray-700 text-[15px] leading-relaxed whitespace-pre-wrap">
        <%= @post.content %>
      </div>
    </div>
  </div>

  <!-- 수정/삭제 (작성자 or 관리자) -->
  <% if user_signed_in? && (@post.user == current_user || current_user.admin?) %>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to edit_post_path(@post), class: "px-4 py-2 text-xs font-medium text-gray-500 hover:text-gray-800 transition" do %>
        수정
      <% end %>
      <%= button_to post_path(@post), method: :delete,
            form: { data: { turbo_confirm: "정말 삭제할까요?" }, class: "inline" },
            class: "px-4 py-2 text-xs font-medium text-gray-400 hover:text-red-500 transition" do %>
        삭제
      <% end %>
    </div>
  <% end %>

  <!-- 댓글 섹션 -->
  <div class="mt-6" id="comments">
    <h2 class="text-sm font-bold text-gray-700 mb-4">댓글 <%= @comments.sum { |c| 1 + c.replies.size } %>개</h2>

    <!-- 댓글 목록 -->
    <% if @comments.any? %>
      <div class="space-y-1 mb-6">
        <% @comments.each do |comment| %>
          <%= render "comments/comment", comment: comment, post: @post %>
        <% end %>
      </div>
    <% end %>

    <!-- 댓글 작성 폼 -->
    <% if user_signed_in? %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <%= form_with model: [@post, @comment], local: true do |f| %>
          <%= f.hidden_field :parent_id, value: nil %>
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-gradient-to-br from-primary-400 to-teal-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mt-0.5">
              <%= current_user.name&.first || "?" %>
            </div>
            <div class="flex-1">
              <%= f.text_area :content, rows: 2,
                    placeholder: "댓글을 남겨보세요",
                    class: "w-full text-sm text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary-300 resize-none" %>
              <div class="flex justify-end mt-2">
                <%= f.submit "등록", class: "px-4 py-1.5 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition cursor-pointer" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-2xl p-4 text-center">
        <p class="text-sm text-gray-500">
          <%= link_to "로그인", new_user_session_path, class: "text-primary-600 font-semibold" %>하면 댓글을 남길 수 있어요
        </p>
      </div>
    <% end %>
  </div>

  <!-- 다른 글 보기 CTA -->
  <div class="mt-6 p-5 bg-gray-50 rounded-2xl text-center">
    <%= link_to community_path, class: "text-sm text-primary-600 font-semibold hover:text-primary-700 transition" do %>
      ← 커뮤니티 목록으로
    <% end %>
  </div>

</div>
