<%# 게시글 작성/수정 폼 %>
<%= render "shared/form_errors", resource: post %>

<%= form_with model: post, html: { multipart: true } do |f| %>

  <!-- 카테고리 선택 -->
  <div class="mb-5">
    <label class="block text-sm font-semibold text-gray-700 mb-2">카테고리</label>
    <div class="grid grid-cols-2 gap-2">
      <% [["tip", "💧 누수 팁"], ["review", "⭐ 해결 후기"], ["question", "❓ 질문"], ["general", "💬 일반"]] .each do |value, label| %>
        <label class="cursor-pointer">
          <%= f.radio_button :category, value, class: "sr-only peer", id: "category_#{value}" %>
          <div class="peer-checked:border-primary-500 peer-checked:bg-primary-50 peer-checked:text-primary-700 border-2 border-gray-200 rounded-xl p-3 text-sm font-semibold text-gray-600 text-center hover:border-gray-300 transition select-none">
            <%= label %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <!-- 제목 -->
  <div class="mb-4">
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">제목</label>
    <%= f.text_field :title,
          placeholder: "어떤 내용인지 알 수 있는 제목을 써주세요",
          class: "w-full px-4 py-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-primary-500 focus:bg-white focus:outline-none text-base transition-all",
          maxlength: 100 %>
  </div>

  <!-- 본문 -->
  <div class="mb-4">
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">내용</label>
    <%= f.text_area :content,
          placeholder: "누수 관련 팁, 해결 후기, 궁금한 점 등을 자유롭게 적어주세요",
          rows: 8,
          class: "w-full px-4 py-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-primary-500 focus:bg-white focus:outline-none text-base transition-all resize-none",
          minlength: 10 %>
    <p class="text-xs text-gray-400 mt-1">최소 10자 이상 입력해주세요</p>
  </div>

  <!-- 이미지 첨부 -->
  <div class="mb-6">
    <label class="block text-sm font-semibold text-gray-700 mb-1.5">사진 첨부 (선택)</label>
    <div class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center hover:border-primary-400 transition cursor-pointer bg-gray-50">
      <%= f.file_field :image,
            accept: "image/jpeg,image/png,image/webp,image/gif",
            class: "hidden",
            id: "post_image_upload" %>
      <label for="post_image_upload" class="cursor-pointer">
        <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <p class="text-sm text-gray-500">이미지를 선택하세요</p>
        <p class="text-xs text-gray-400 mt-1">JPG, PNG, WebP · 최대 10MB</p>
      </label>
    </div>

    <!-- 현재 이미지 미리보기 (수정 시) -->
    <% if post.image.attached? %>
      <div class="mt-3 flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-200">
        <% begin %>
          <%= image_tag post.image.variant(resize_to_fill: [60, 60]), class: "w-12 h-12 rounded-lg object-cover flex-shrink-0", alt: "현재 이미지" %>
        <% rescue %>
          <%= image_tag post.image, class: "w-12 h-12 rounded-lg object-cover flex-shrink-0", alt: "현재 이미지" rescue nil %>
        <% end %>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-medium text-gray-700">현재 이미지</p>
          <p class="text-xs text-gray-400">새 이미지를 선택하면 교체돼요</p>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 제출 버튼 -->
  <%= f.submit post.new_record? ? "등록하기" : "수정하기",
        class: "w-full py-4 bg-primary-600 text-white rounded-xl font-bold text-base hover:bg-primary-700 transition shadow-sm cursor-pointer" %>

<% end %>
